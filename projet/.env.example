# Copier ce fichier en .env.local et renseigner les valeurs.
# NE JAMAIS committer .env.local (il est dans .gitignore).

# OBLIGATOIRE en production : générer une clé secrète avec :
#   php -r "echo bin2hex(random_bytes(32));"
# Sans APP_SECRET, la protection CSRF et les sessions ne sont pas sécurisées.
APP_SECRET=votre_cle_secrete_generee_ci_dessus

# Optionnel : surcharge des paramètres métier (voir config/packages/app.yaml)
# APP_COMMISSION_TAUX=0.10
# APP_VALIDATION_DEBUT_OFFSET=-2 hours
# APP_VALIDATION_FIN_OFFSET=+4 hours
