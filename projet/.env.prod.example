# ============================================
# Configuration Production - TalChif
# ============================================
# IMPORTANT: Copier ce fichier en .env.prod et remplir avec les vraies valeurs

# ── Application ──
APP_ENV=prod
APP_DEBUG=0
APP_SECRET=CHANGE_ME_GENERATE_RANDOM_SECRET_HERE

# ── Base de données ──
DB_NAME=talchif
DB_USER=talchif_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Redis ──
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ── Email ──
MAILER_DSN=smtp://user:pass@smtp.example.com:587

# ── Mobile Money ──
# MoMo API (à configurer selon le provider)
MOMO_API_KEY=your_api_key_here
MOMO_API_SECRET=your_api_secret_here
MOMO_MERCHANT_ID=your_merchant_id

# Airtel Money API
AIRTEL_API_KEY=your_api_key_here
AIRTEL_API_SECRET=your_api_secret_here

# Orange Money API
ORANGE_API_KEY=your_api_key_here
ORANGE_API_SECRET=your_api_secret_here

# ── Sécurité ──
TRUSTED_PROXIES=127.0.0.1,REMOTE_ADDR
TRUSTED_HOSTS=^(localhost|talchif\.td)$

# ── Monitoring (optionnel) ──
SENTRY_DSN=https://your_sentry_dsn_here

# ── Stockage (optionnel) ──
# Pour stockage S3/MinIO des images
S3_ENDPOINT=https://s3.amazonaws.com
S3_BUCKET=talchif-uploads
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
