<svg xmlns="http://www.w3.org/2000/svg" width="400" height="200" viewBox="0 0 400 200">
  <!-- Background gradient -->
  <defs>
    <linearGradient id="goldGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#fbbf24;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#f59e0b;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <rect width="400" height="200" fill="url(#goldGradient)"/>
  
  <!-- Ticket border -->
  <rect x="10" y="10" width="380" height="180" fill="none" stroke="#d97706" stroke-width="3" rx="10"/>
  
  <!-- Left section -->
  <rect x="20" y="20" width="200" height="160" fill="#fffbeb" rx="5"/>
  
  <!-- VIP icon -->
  <rect x="95" y="45" width="50" height="30" fill="#f59e0b" rx="3"/>
  <text x="120" y="65" text-anchor="middle" font-family="Arial, sans-serif" font-size="14" font-weight="bold" fill="white">VIP</text>
  
  <!-- Crown icon -->
  <path d="M120 35 L125 40 L130 35 L135 40 L140 35 L140 45 L120 45 Z" fill="#fbbf24"/>
  <circle cx="125" cy="40" r="2" fill="#fffbeb"/>
  <circle cx="135" cy="40" r="2" fill="#fffbeb"/>
  
  <!-- Title -->
  <text x="120" y="100" text-anchor="middle" font-family="Arial, sans-serif" font-size="16" font-weight="bold" fill="#d97706">VIP</text>
  <text x="120" y="120" text-anchor="middle" font-family="Arial, sans-serif" font-size="12" fill="#64748b">PREMIUM</text>
  
  <!-- Right section -->
  <rect x="230" y="20" width="150" height="160" fill="url(#goldGradient)" rx="5"/>
  
  <!-- QR Code placeholder -->
  <rect x="250" y="40" width="110" height="110" fill="white" rx="5"/>
  <rect x="260" y="50" width="90" height="90" fill="#f59e0b" rx="3"/>
  
  <!-- QR Code pattern -->
  <rect x="270" y="60" width="10" height="10" fill="white"/>
  <rect x="285" y="60" width="10" height="10" fill="white"/>
  <rect x="300" y="60" width="10" height="10" fill="white"/>
  <rect x="315" y="60" width="10" height="10" fill="white"/>
  <rect x="330" y="60" width="10" height="10" fill="white"/>
  
  <rect x="270" y="75" width="10" height="10" fill="white"/>
  <rect x="285" y="75" width="10" height="10" fill="#f59e0b"/>
  <rect x="300" y="75" width="10" height="10" fill="white"/>
  <rect x="315" y="75" width="10" height="10" fill="#f59e0b"/>
  <rect x="330" y="75" width="10" height="10" fill="white"/>
  
  <rect x="270" y="90" width="10" height="10" fill="white"/>
  <rect x="285" y="90" width="10" height="10" fill="white"/>
  <rect x="300" y="90" width="10" height="10" fill="#f59e0b"/>
  <rect x="315" y="90" width="10" height="10" fill="white"/>
  <rect x="330" y="90" width="10" height="10" fill="white"/>
  
  <rect x="270" y="105" width="10" height="10" fill="white"/>
  <rect x="285" y="105" width="10" height="10" fill="#f59e0b"/>
  <rect x="300" y="105" width="10" height="10" fill="white"/>
  <rect x="315" y="105" width="10" height="10" fill="#f59e0b"/>
  <rect x="330" y="105" width="10" height="10" fill="white"/>
  
  <rect x="270" y="120" width="10" height="10" fill="white"/>
  <rect x="285" y="120" width="10" height="10" fill="white"/>
  <rect x="300" y="120" width="10" height="10" fill="white"/>
  <rect x="315" y="120" width="10" height="10" fill="white"/>
  <rect x="330" y="120" width="10" height="10" fill="white"/>
</svg>
