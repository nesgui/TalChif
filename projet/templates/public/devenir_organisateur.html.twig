{% extends 'base.html.twig' %}

{% block title %}Devenir Organisateur - TalChif{% endblock %}

{% block body %}
<section class="section devenir-org-section">
    <div class="devenir-org-shell">
        <div class="devenir-org-hero">
            <p class="devenir-org-kicker">Partenariat TalChif</p>
            <h1>Faites grandir vos événements avec une billetterie pensée pour les organisateurs</h1>
            <p class="devenir-org-lead">
                Lancez vos ventes rapidement, suivez vos performances en direct et gardez un contrôle total sur
                vos entrées, vos revenus et vos règlements.
            </p>

            <div class="devenir-org-pill-row">
                <span class="devenir-org-pill">Billets sécurisés QR</span>
                <span class="devenir-org-pill">Commission claire</span>
                <span class="devenir-org-pill">Validation rapide sur site</span>
            </div>

            <div class="devenir-org-grid">
                <article class="devenir-org-card">
                    <h3>Avant l’événement</h3>
                    <p>Création de pages d’événement pro, prix SIMPLE/VIP, capacité et visuels en quelques minutes.</p>
                </article>
                <article class="devenir-org-card">
                    <h3>Pendant la vente</h3>
                    <p>Suivi en temps réel des commandes, validation des paiements et statistiques de conversion.</p>
                </article>
                <article class="devenir-org-card">
                    <h3>Le jour J</h3>
                    <p>Contrôle des accès avec scan QR, historique des scans et gestion anti-fraude intégrée.</p>
                </article>
            </div>
        </div>

        <aside class="devenir-org-whatsapp" aria-label="Contact WhatsApp">
            <div class="devenir-org-whatsapp-badge" aria-hidden="true">
                <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" fill="currentColor">
                    <path d="M16 3A13 13 0 0 0 4.7 22.4L3 29l6.8-1.8A13 13 0 1 0 16 3Zm0 23.7c-2 0-3.9-.5-5.6-1.5l-.4-.2-4.1 1.1 1.1-4-.3-.4a10.6 10.6 0 1 1 9.3 5Z"/>
                    <path d="M22 19c-.3-.2-2-1-2.3-1.1-.3-.1-.5-.1-.7.2l-1 1.2c-.2.2-.4.3-.7.1-1.8-.9-3-2.3-3.5-3.2-.2-.3 0-.4.1-.6l.5-.5c.2-.2.3-.4.4-.6.1-.2.1-.3 0-.5l-1-2.2c-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4s-1 1-1 2.5 1 3 1.2 3.2c.1.2 2.1 3.3 5.2 4.5.7.3 1.3.5 1.8.6.8.2 1.5.2 2 .1.6-.1 1.9-.8 2.1-1.5.3-.7.3-1.3.2-1.5-.1-.1-.3-.2-.6-.4Z"/>
                </svg>
            </div>
            <p class="devenir-org-whatsapp-title">Parlons de votre prochain événement</p>
            <p class="devenir-org-whatsapp-text">
                Notre équipe vous accompagne pour publier, vendre et gérer vos billets efficacement.
            </p>
            <a href="https://wa.me/23563519678" class="devenir-org-whatsapp-btn" target="_blank" rel="noopener noreferrer">
                Contacter sur WhatsApp
            </a>

            <ul class="devenir-org-steps">
                <li><span>1</span>Contact rapide sur WhatsApp</li>
                <li><span>2</span>Validation de votre profil organisateur</li>
                <li><span>3</span>Mise en ligne de votre premier événement</li>
            </ul>
        </aside>
    </div>

    <div class="devenir-org-footnote">
        <p>TalChif travaille avec des événements culturels, sportifs et corporate partout au Tchad.</p>
    </div>
</section>
{% endblock %}
