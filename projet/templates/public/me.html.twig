{% extends 'base.html.twig' %}

{% block title %}Moi - TalChif{% endblock %}

{% block body %}
<section class="public-me-page">
    <h1 class="section-title">Moi</h1>

    {% if not app.user %}
        <div class="public-me-login">
            <div class="public-me-login-title">Veuillez vous connecter</div>
            <a class="btn btn-primary" href="{{ path('auth.login') }}">Se connecter</a>
        </div>
    {% endif %}

    <div class="public-me-list" role="list">
        <a class="public-me-item" role="listitem" href="{{ path('public.devenir_organisateur') }}">
            <span class="public-me-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 2v20" />
                    <path d="M2 12h20" />
                </svg>
            </span>
            <span class="public-me-label">Devenir Organisateur</span>
        </a>

        <a class="public-me-item" role="listitem" href="{{ path('public.infos') }}">
            <span class="public-me-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10" />
                    <path d="M12 16v-4" />
                    <path d="M12 8h.01" />
                </svg>
            </span>
            <span class="public-me-label">Plus d'informations</span>
        </a>

        <a class="public-me-item" role="listitem" href="{{ path('public.a_propos') }}">
            <span class="public-me-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 20h9" />
                    <path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z" />
                </svg>
            </span>
            <span class="public-me-label">A propos de nous</span>
        </a>
    </div>
</section>
{% endblock %}
