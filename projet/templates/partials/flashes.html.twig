{# 
   Messages Flash TalChif
   Collecte unique des flash messages (app.flashes se consomme à la lecture),
   puis fallback HTML + conversion en toasts JS via NotificationService.
#}

{% set _flashes = app.flashes %}

{# Fallback HTML visible immédiatement (masqué par JS si toasts disponibles) #}
{% for type, messages in _flashes %}
    {% for message in messages %}
        <div class="flash-message flash-{{ type }}" role="alert">
            <strong>
                {%- if type == 'success' -%}
                    Succès
                {%- elseif type == 'error' or type == 'danger' -%}
                    Erreur
                {%- elseif type == 'warning' -%}
                    Attention
                {%- else -%}
                    Information
                {%- endif -%}
            </strong> : {{ message }}
        </div>
    {% endfor %}
{% endfor %}

{# Conversion flash → toasts NotificationService #}
{% if _flashes is not empty %}
<script>
(function() {
    'use strict';

    var flashMessages = [
        {% for type, messages in _flashes %}
            {% for message in messages %}
                { type: '{{ type }}', message: {{ message|json_encode|raw }} },
            {% endfor %}
        {% endfor %}
    ];

    var typeMap  = { success:'success', error:'error', danger:'error', warning:'warning', info:'info' };
    var titleMap = { success:'Succès', error:'Erreur', danger:'Erreur', warning:'Attention', info:'Information' };

    function display() {
        if (!window.NotificationService || !window.NotificationService.isInitialized) return false;
        flashMessages.forEach(function(f) {
            var t = typeMap[f.type] || 'info';
            window.NotificationService.show(t, titleMap[t] || 'Information', f.message);
        });
        document.querySelectorAll('.flash-message').forEach(function(el) { el.style.display = 'none'; });
        return true;
    }

    function poll(n) {
        if (display()) return;
        if (n < 60) setTimeout(function() { poll(n + 1); }, 50);
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', function() { poll(0); });
    } else {
        poll(0);
    }
})();
</script>
{% endif %}
