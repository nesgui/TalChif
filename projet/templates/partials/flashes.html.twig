{# Messages visibles immédiatement (fallback si JS désactivé ou erreur) #}
{% for type, messages in app.flashes %}
    {% for message in messages %}
        <div class="flash-message flash-{{ type }}" role="alert" data-flash-toast>
            <strong>{{ type == 'success' ? 'Succès' : type == 'error' ? 'Erreur' : type == 'warning' ? 'Attention' : 'Information' }} :</strong> {{ message }}
        </div>
        <script>
            if (!window.flashMessages) { window.flashMessages = []; }
            window.flashMessages.push({ type: '{{ type }}', message: {{ message|json_encode|raw }} });
        </script>
    {% endfor %}
{% endfor %}
<script>
(function() {
    function runToasts() {
        if (!window.NotificationService || !window.flashMessages || window.flashMessages.length === 0) return;
        window.flashMessages.forEach(function(flash) {
            var title = flash.type === 'success' ? 'Succès' : flash.type === 'error' ? 'Erreur' : flash.type === 'warning' ? 'Attention' : 'Information';
            var duration = flash.type === 'error' ? 6000 : flash.type === 'warning' ? 5000 : 4000;
            if (flash.type === 'success') window.NotificationService.success(title, flash.message, { duration: duration });
            else if (flash.type === 'error') window.NotificationService.error(title, flash.message, { duration: duration });
            else if (flash.type === 'warning') window.NotificationService.warning(title, flash.message, { duration: duration });
            else window.NotificationService.info(title, flash.message, { duration: duration });
        });
        window.flashMessages = [];
        document.querySelectorAll('[data-flash-toast]').forEach(function(el) { el.remove(); });
    }
    if (window.NotificationService) {
        runToasts();
    } else {
        document.addEventListener('DOMContentLoaded', function() { setTimeout(runToasts, 150); });
    }
})();
</script>
