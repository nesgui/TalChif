{% extends 'layout/dashboard.html.twig' %}

{% set section = 'admin' %}

{% block title %}Gestion des utilisateurs{% endblock %}

{% block dashboard_title %}Gestion des utilisateurs{% endblock %}

{% block dashboard_actions %}
    <a class="btn btn-primary" href="{{ path('admin.user.create') }}">Créer un utilisateur</a>
{% endblock %}

{% block dashboard_content %}
<p class="page-subtitle">Gestion des comptes utilisateurs (clients, organisateurs, administrateurs)</p>

<div class="grid">
    <section class="card">
        <h2 class="card-title">Liste des utilisateurs</h2>
        <p class="card-meta">
            {% if total > 0 %}
                Affichage de {{ (page - 1) * limit + 1 }} à {{ (page - 1) * limit + users|length }} sur {{ total }} utilisateurs.
                {% if totalPages > 1 %}Page {{ page }}/{{ totalPages }}.{% endif %}
            {% else %}
                Aucun utilisateur inscrit.
            {% endif %}
        </p>

        <form method="get" action="{{ path('admin.user.index') }}" class="search-zone">
            <input type="hidden" name="page" value="1">
            <label for="user-search" class="search-zone-label">Rechercher</label>
            <input type="search" id="user-search" name="q" value="{{ search|default('') }}" class="form-control search-zone-input" placeholder="Email ou nom...">
            <button type="submit" class="btn btn-primary btn-sm">Rechercher</button>
            {% if search %}
                <a href="{{ path('admin.user.index') }}" class="pagination-link">Effacer</a>
            {% endif %}
        </form>
        
        <div class="table-responsive admin-users-table-wrap">
        <table id="users-table" class="dt-table admin-users-table" data-order="[[0, 'asc']]">
            <thead>
                <tr>
                    <th class="col-id">ID</th>
                    <th class="col-email">Email</th>
                    <th class="col-name">Nom complet</th>
                    <th class="col-phone">Téléphone</th>
                    <th class="col-role" data-no-sort>Rôle</th>
                    <th class="col-status" data-no-sort>Statut</th>
                    <th class="col-date">Date d'inscription</th>
                    <th class="col-actions" data-no-sort>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for user in users %}
                <tr>
                    <td class="cell-id">{{ user.id }}</td>
                    <td class="cell-email">{{ user.email }}</td>
                    <td class="cell-name">{{ user.nom }}</td>
                    <td class="cell-phone">{{ user.telephone ?: 'Non renseigné' }}</td>
                    <td class="cell-role">
                        {% if user.role == 'CLIENT' %}
                            <span class="pill pill-info admin-user-pill">Client</span>
                        {% elseif user.role == 'ORGANISATEUR' %}
                            <span class="pill pill-success admin-user-pill">Organisateur</span>
                        {% elseif user.role == 'ADMIN' %}
                            <span class="pill pill-warning admin-user-pill">Admin</span>
                        {% endif %}
                    </td>
                    <td class="cell-status">
                        {% if user.actif %}
                            <span class="pill pill-success admin-user-pill">Actif</span>
                        {% else %}
                            <span class="pill pill-danger admin-user-pill">Désactivé</span>
                        {% endif %}
                    </td>
                    <td class="cell-date">{{ user.createdAt ? user.createdAt|date('d/m/Y') : 'N/A' }}</td>
                    <td class="cell-actions">
                        <div class="btn-group admin-users-actions">
                            <a href="{{ path('admin.user.edit', {id: user.id}) }}" class="btn btn-sm btn-primary">Modifier</a>
                            {% if user != app.user %}
                                <form method="post" action="{{ path('admin.user.toggle_actif', {id: user.id}) }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('toggle_actif' ~ user.id) }}">
                                    {% if user.actif %}
                                        <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Désactiver le compte de {{ user.nom }} ? Il ne pourra plus se connecter.')">Désactiver</button>
                                    {% else %}
                                        <button type="submit" class="btn btn-sm btn-success" onclick="return confirm('Réactiver le compte de {{ user.nom }} ?')">Activer</button>
                                    {% endif %}
                                </form>
                            {% else %}
                                <button type="button" class="btn btn-sm" disabled title="Vous ne pouvez pas désactiver votre propre compte">Vous</button>
                            {% endif %}
                        </div>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="8" class="text-center">Aucun utilisateur trouvé</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        </div>

        {% if total > 0 %}
            <nav class="table-pagination" aria-label="Pagination utilisateurs">
                <div class="pagination-inner">
                    {% if page > 1 %}
                        <a href="{{ path('admin.user.index', {page: page - 1, q: search}) }}" class="pagination-link">← Précédent</a>
                    {% else %}
                        <span class="pagination-link disabled">← Précédent</span>
                    {% endif %}
                    <span class="pagination-info">Page {{ page }} / {{ totalPages }}</span>
                    {% if page < totalPages %}
                        <a href="{{ path('admin.user.index', {page: page + 1, q: search}) }}" class="pagination-link">Suivant →</a>
                    {% else %}
                        <span class="pagination-link disabled">Suivant →</span>
                    {% endif %}
                </div>
            </nav>
        {% endif %}
    </section>
</div>

<style>
.admin-users-table {
    width: 100%;
    table-layout: fixed;
}

.admin-users-table .col-id,
.admin-users-table .cell-id {
    width: 60px;
    white-space: nowrap;
}

.admin-users-table .col-role,
.admin-users-table .cell-role,
.admin-users-table .col-status,
.admin-users-table .cell-status {
    width: 112px;
    text-align: center;
}

.admin-users-table .col-date,
.admin-users-table .cell-date {
    width: 118px;
    white-space: nowrap;
}

.admin-users-table .col-actions,
.admin-users-table .cell-actions {
    width: 190px;
}

.admin-users-table .cell-email,
.admin-users-table .cell-phone,
.admin-users-table .cell-name {
    word-break: break-word;
}

.admin-user-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 84px;
    white-space: nowrap;
}

.admin-users-actions {
    display: flex;
    gap: .5rem;
    flex-wrap: wrap;
    align-items: center;
}

.admin-users-actions form {
    margin: 0;
}

.admin-users-actions .btn {
    min-width: 92px;
    justify-content: center;
    white-space: nowrap;
}

@media (max-width: 980px) {
    .admin-users-table {
        min-width: 960px;
    }
}

@media (max-width: 768px) {
    .admin-users-actions .btn {
        min-width: 84px;
    }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Initialiser DataTables pour les utilisateurs
    if (typeof DataTableOS !== 'undefined') {
        DataTableOS.init('#users-table', {
            order: [[0, 'asc']], // Tri par ID (croissant)
            columns: [
                { width: '60px' },
                null,
                null,
                null,
                { width: '112px', orderable: false },
                { width: '112px', orderable: false },
                { width: '118px' },
                { width: '190px', orderable: false }
            ]
        });
    }
});
</script>
{% endblock %}
