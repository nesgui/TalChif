{% extends 'layout/dashboard.html.twig' %}

{% set section = 'admin' %}

{% block title %}Admin - Organisateurs{% endblock %}

{% block dashboard_title %}Organisateurs{% endblock %}

{% block dashboard_content %}
<p class="page-subtitle">Gestion des comptes organisateurs.</p>

<div class="card">
    <h2 class="card-title">Liste des Organisateurs</h2>
    <p class="card-meta">Tous les comptes organisateurs avec tri et recherche</p>
    
    <div class="table-responsive admin-organizers-table-wrap">
        <table id="organizers-table" class="dt-table admin-organizers-table" data-order="[[0, 'asc']]">
        <thead>
            <tr>
                <th class="col-id">ID</th>
                <th class="col-name">Nom</th>
                <th class="col-email">Email</th>
                <th class="col-phone">Téléphone</th>
                <th class="col-status" data-no-sort>Statut</th>
                <th class="col-commission">Commission</th>
                <th class="col-events">Événements</th>
                <th class="col-date">Inscription</th>
                <th class="col-actions" data-no-sort>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for organisateur in organisateurs %}
            <tr>
                <td class="cell-id">{{ organisateur.id }}</td>
                <td class="cell-name">{{ organisateur.nom }}</td>
                <td class="cell-email">{{ organisateur.email }}</td>
                <td class="cell-phone">{{ organisateur.telephone ?: 'Non renseigné' }}</td>
                <td class="cell-status">
                    {% if organisateur.actif %}
                        <span class="pill pill-success admin-organizer-pill">Actif</span>
                    {% else %}
                        <span class="pill pill-warning admin-organizer-pill">Inactif</span>
                    {% endif %}
                </td>
                <td class="cell-commission">-</td>
                <td class="cell-events">-</td>
                <td class="cell-date">{{ organisateur.createdAt ? organisateur.createdAt|date('d/m/Y') : 'N/A' }}</td>
                <td class="cell-actions">
                    <div class="btn-group admin-organizers-actions">
                        <a href="{{ path('admin.organisateur.show', {id: organisateur.id}) }}" class="btn btn-sm btn-primary">Voir</a>
                        <a href="{{ path('admin.organisateur.edit', {id: organisateur.id}) }}" class="btn btn-sm btn-secondary">Modifier</a>
                        <form method="post" action="{{ path('admin.organisateur.toggle_actif', {id: organisateur.id}) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('toggle_organisateur_' ~ organisateur.id) }}">
                            {% if organisateur.actif %}
                                <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Suspendre le compte de {{ organisateur.nom }} ?')">Suspendre</button>
                            {% else %}
                                <button type="submit" class="btn btn-sm btn-success" onclick="return confirm('Réactiver le compte de {{ organisateur.nom }} ?')">Réactiver</button>
                            {% endif %}
                        </form>
                    </div>
                </td>
            </tr>
            {% else %}
            <tr>
                <td colspan="9" class="text-center">Aucun organisateur trouvé</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
    </div>
</div>

<style>
.admin-organizers-table {
    width: 100%;
    table-layout: fixed;
}

.admin-organizers-table .col-id,
.admin-organizers-table .cell-id {
    width: 54px;
    white-space: nowrap;
}

.admin-organizers-table .col-status,
.admin-organizers-table .cell-status,
.admin-organizers-table .col-commission,
.admin-organizers-table .cell-commission,
.admin-organizers-table .col-events,
.admin-organizers-table .cell-events,
.admin-organizers-table .col-date,
.admin-organizers-table .cell-date {
    width: 96px;
    text-align: center;
    white-space: nowrap;
}

.admin-organizers-table .col-actions,
.admin-organizers-table .cell-actions {
    width: 220px;
}

.admin-organizers-table .cell-email,
.admin-organizers-table .cell-phone,
.admin-organizers-table .cell-name {
    word-break: break-word;
}

.admin-organizer-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 84px;
    white-space: nowrap;
}

.admin-organizers-actions {
    display: flex;
    flex-wrap: wrap;
    gap: .45rem;
    align-items: center;
}

.admin-organizers-actions form {
    margin: 0;
}

.admin-organizers-actions .btn {
    min-width: 88px;
    justify-content: center;
    white-space: nowrap;
}

@media (max-width: 980px) {
    .admin-organizers-table {
        min-width: 1040px;
    }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Initialiser DataTables pour les organisateurs
    if (typeof DataTableOS !== 'undefined') {
        DataTableOS.init('#organizers-table', {
            order: [[0, 'asc']], // Tri par ID
            columns: [
                { width: '54px' },
                null,
                null,
                null,
                { width: '96px', orderable: false },
                { width: '96px' },
                { width: '96px' },
                { width: '96px' },
                { width: '220px', orderable: false }
            ]
        });
    }
});
</script>
{% endblock %}
