    if (typeof DataTableOS !== 'undefined') {
        DataTableOS.init('#organizers-table', {
            order: [[0, 'asc']], // Tri par ID
            columns: [
                { width: '50px' },
                null,
                null,
                null,
                { width: '80px', orderable: false },
                { width: '80px' },
                { width: '80px' },
                { width: '100px' },
                { width: '150px', orderable: false }
