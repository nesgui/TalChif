<script>
document.addEventListener('DOMContentLoaded', function() {
    // Initialiser DataTables pour les transactions
    if (typeof DataTableOS !== 'undefined') {
        DataTableOS.init('#transactions-table', {
            order: [[8, 'desc']], // Tri par date (décroissant)
            columns: [
                { width: '80px' },
                null,
                null,
                { width: '80px', orderable: false },
                { width: '100px' },
                { width: '100px' },
                { width: '120px' },
                { width: '150px' },
                { width: '80px', orderable: false }
            ]
        });
    }
});
</script>
