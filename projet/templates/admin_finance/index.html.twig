{% extends 'base.html.twig' %}

{% block title %}Admin - Finance{% endblock %}

{% block body %}
<h1 class="page-title">Admin - Finance & paiements</h1>
<p class="page-subtitle">Suivi des transactions, commissions et reversements (prototype UI).</p>

<div class="grid">
    <section class="card">
        <h2 class="card-title">Commission standard</h2>
        <p class="card-meta"><span class="pill">10%</span> (modifiable plus tard)</p>
        <div class="card-actions">
            <a class="btn btn-primary" href="#">Modifier (prototype)</a>
        </div>
    </section>

    <section class="card">
        <h2 class="card-title">Transactions récentes</h2>
        <table class="table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Événement</th>
                    <th>Montant</th>
                    <th>Moyen</th>
                    <th>Statut</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>TX-1001</td>
                    <td>Concert Live</td>
                    <td>10 000 XAF</td>
                    <td>Mobile Money</td>
                    <td><span class="pill">OK</span></td>
                </tr>
                <tr>
                    <td>TX-1002</td>
                    <td>Match de foot</td>
                    <td>2 000 XAF</td>
                    <td>Carte</td>
                    <td><span class="pill">OK</span></td>
                </tr>
            </tbody>
        </table>
        <div class="card-actions">
            <a class="btn" href="{{ path('admin.dashboard') }}">Retour dashboard</a>
        </div>
    </section>
</div>
{% endblock %}
