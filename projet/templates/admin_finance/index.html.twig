{% extends 'layout/dashboard.html.twig' %}

{% set section = 'admin' %}

{% block title %}Admin - Finance{% endblock %}

{% block dashboard_title %}Finance & paiements{% endblock %}

{% block dashboard_content %}
<p class="page-subtitle">Suivi des transactions, commissions et reversements.</p>

<div class="finance-tabs" data-finance-tabs>
    <div class="finance-tablist" role="tablist" aria-label="Navigation finance">
        <button type="button" class="finance-tab is-active" role="tab" id="finance-tab-summary" aria-controls="finance-panel-summary" aria-selected="true">Synthèse</button>
        <button type="button" class="finance-tab" role="tab" id="finance-tab-transactions" aria-controls="finance-panel-transactions" aria-selected="false" tabindex="-1">Transactions</button>
        <button type="button" class="finance-tab" role="tab" id="finance-tab-settings" aria-controls="finance-panel-settings" aria-selected="false" tabindex="-1">Paramètres</button>
    </div>

    <div class="finance-panel" role="tabpanel" id="finance-panel-summary" aria-labelledby="finance-tab-summary">
        <div class="grid">
            <section class="card">
                <h2 class="card-title">Indicateurs</h2>
                <p class="card-meta">Vue rapide des montants et commandes</p>

                <div class="finance-kpis">
                    <div class="finance-kpi">
                        <div class="finance-kpi-label">Total encaissé</div>
                        <div class="finance-kpi-value">{{ totalEncaisse|number_format(0, '.', ' ') }} FCFA</div>
                    </div>
                    <div class="finance-kpi">
                        <div class="finance-kpi-label">Commissions</div>
                        <div class="finance-kpi-value">{{ totalCommission|number_format(0, '.', ' ') }} FCFA</div>
                    </div>
                    <div class="finance-kpi">
                        <div class="finance-kpi-label">Net organisateurs</div>
                        <div class="finance-kpi-value">{{ totalNetOrganisateurs|number_format(0, '.', ' ') }} FCFA</div>
                    </div>
                    <div class="finance-kpi">
                        <div class="finance-kpi-label">Commandes payées</div>
                        <div class="finance-kpi-value">{{ nbCommandesPaid }}</div>
                    </div>
                    <div class="finance-kpi">
                        <div class="finance-kpi-label">Commandes en attente</div>
                        <div class="finance-kpi-value">{{ nbCommandesPending }}</div>
                    </div>
                </div>
            </section>

            <section class="card">
                <h2 class="card-title">Événements à payer</h2>
                <p class="card-meta">Événements passés dont le reversement organisateur n'est pas encore effectué</p>

                <div class="table-responsive">
                    <table class="table admin-finance-payouts">
                        <thead>
                            <tr>
                                <th>Événement</th>
                                <th>Organisateur</th>
                                <th>Brut</th>
                                <th>Net</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for item in evenementsAPayer %}
                                <tr>
                                    <td>{{ item.evenement.nom }}</td>
                                    <td>{{ item.evenement.organisateur.nom }}</td>
                                    <td style="white-space: nowrap; text-align: right;">{{ item.soldeBrut|number_format(0, '.', ' ') }} FCFA</td>
                                    <td style="white-space: nowrap; text-align: right;">{{ item.soldeNet|number_format(0, '.', ' ') }} FCFA</td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="4" class="text-center">Aucun événement à payer.</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </section>
        </div>
    </div>

    <div class="finance-panel" role="tabpanel" id="finance-panel-transactions" aria-labelledby="finance-tab-transactions" hidden>
        <div class="grid">
            <section class="card">
                <h2 class="card-title">Transactions récentes</h2>
                <p class="card-meta">Historique complet des paiements et commissions</p>
                <p class="card-meta" style="margin-top: -.35rem;">Astuce : utilisez le bouton <strong>Colonnes</strong> pour afficher/masquer les informations secondaires.</p>
                
