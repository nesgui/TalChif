{% extends 'layout/dashboard.html.twig' %}

{% set section = 'admin' %}

{% block title %}Admin - Finance{% endblock %}

{% block dashboard_title %}Finance & paiements{% endblock %}

{% block dashboard_content %}
<p class="page-subtitle">Suivi des transactions, commissions et reversements.</p>

<div class="grid">
    <section class="card">
        <h2 class="card-title">Commission standard</h2>
        <p class="card-meta"><span class="pill">10%</span> (modifiable plus tard)</p>
        <div class="card-actions">
            <a class="btn btn-primary" href="#">Modifier</a>
        </div>
    </section>

    <section class="card">
        <h2 class="card-title">Transactions récentes</h2>
        <p class="card-meta">Historique complet des paiements et commissions</p>
        
        <table id="transactions-table" class="table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Événement</th>
                    <th>Organisateur</th>
                    <th>Type</th>
                    <th>Montant</th>
                    <th>Commission</th>
                    <th>Moyen</th>
                    <th>Date</th>
                    <th>Statut</th>
                </tr>
            </thead>
            <tbody>
