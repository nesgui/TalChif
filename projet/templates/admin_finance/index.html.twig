            </section>
        </div>
    </div>

    <div class="finance-panel" role="tabpanel" id="finance-panel-settings" aria-labelledby="finance-tab-settings" hidden>
        <div class="grid">
            <section class="card">
                <h2 class="card-title">Commission standard</h2>
                <p class="card-meta"><span class="pill">10%</span> (modifiable plus tard)</p>
                <div class="card-actions">
                    <a class="btn btn-primary" href="#">Modifier</a>
