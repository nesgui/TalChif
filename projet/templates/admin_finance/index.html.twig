{% extends 'layout/dashboard.html.twig' %}

{% set section = 'admin' %}

{% block title %}Admin - Finance{% endblock %}

{% block dashboard_title %}Finance & paiements{% endblock %}

{% block dashboard_content %}
<p class="page-subtitle">Suivi des transactions, commissions et reversements.</p>

<div class="grid">
    <section class="card">
        <h2 class="card-title">Commission standard</h2>
        <p class="card-meta"><span class="pill">10%</span> (modifiable plus tard)</p>
        <div class="card-actions">
            <a class="btn btn-primary" href="#">Modifier</a>
        </div>
    </section>

    <section class="card">
        <h2 class="card-title">Transactions récentes</h2>
        <p class="card-meta">Historique complet des paiements et commissions</p>
        
        <div class="table-responsive admin-finance-table-wrap">
        <table id="transactions-table" class="table admin-finance-table">
            <thead>
                <tr>
                    <th class="col-id">ID</th>
                    <th class="col-event">Événement</th>
                    <th class="col-organizer">Organisateur</th>
                    <th class="col-type">Type</th>
                    <th class="col-amount">Montant</th>
                    <th class="col-commission">Commission</th>
                    <th class="col-method">Moyen</th>
                    <th class="col-date">Date</th>
                    <th class="col-status">Statut</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td class="cell-id">TX-1001</td>
                    <td class="cell-event">Concert Live N'Djamena</td>
                    <td class="cell-organizer">Alpha Events</td>
                    <td class="cell-type"><span class="pill pill-success admin-finance-pill">Vente</span></td>
                    <td class="cell-amount">10 000 XAF</td>
                    <td class="cell-commission">1 000 XAF</td>
                    <td class="cell-method">Mobile Money</td>
                    <td class="cell-date">2024-02-10 14:30</td>
                    <td class="cell-status"><span class="pill pill-success admin-finance-pill">Confirmé</span></td>
                </tr>
                <tr>
                    <td class="cell-id">TX-1002</td>
                    <td class="cell-event">Match Foot Étoile vs Djamena</td>
                    <td class="cell-organizer">Beta Productions</td>
                    <td class="cell-type"><span class="pill pill-success admin-finance-pill">Vente</span></td>
                    <td class="cell-amount">2 000 XAF</td>
                    <td class="cell-commission">200 XAF</td>
                    <td class="cell-method">Carte Bancaire</td>
                    <td class="cell-date">2024-02-10 16:45</td>
                    <td class="cell-status"><span class="pill pill-success admin-finance-pill">Confirmé</span></td>
                </tr>
                <tr>
                    <td class="cell-id">TX-1003</td>
                    <td class="cell-event">Soirée Urbaine VIP</td>
                    <td class="cell-organizer">Alpha Events</td>
                    <td class="cell-type"><span class="pill pill-warning admin-finance-pill">Remboursement</span></td>
                    <td class="cell-amount">-500 XAF</td>
                    <td class="cell-commission">0 XAF</td>
                    <td class="cell-method">Mobile Money</td>
                    <td class="cell-date">2024-02-09 11:20</td>
                    <td class="cell-status"><span class="pill pill-success admin-finance-pill">Traité</span></td>
                </tr>
                <tr>
                    <td class="cell-id">TX-1004</td>
                    <td class="cell-event">Festival de Musique</td>
                    <td class="cell-organizer">Delta Shows</td>
                    <td class="cell-type"><span class="pill pill-success admin-finance-pill">Vente</span></td>
                    <td class="cell-amount">25 000 XAF</td>
                    <td class="cell-commission">3 750 XAF</td>
                    <td class="cell-method">Carte Bancaire</td>
                    <td class="cell-date">2024-02-09 18:00</td>
                    <td class="cell-status"><span class="pill pill-success admin-finance-pill">Confirmé</span></td>
                </tr>
                <tr>
                    <td class="cell-id">TX-1005</td>
                    <td class="cell-event">Conférence Tech</td>
                    <td class="cell-organizer">Gamma Concerts</td>
                    <td class="cell-type"><span class="pill pill-warning admin-finance-pill">Remboursement</span></td>
                    <td class="cell-amount">-1 200 XAF</td>
                    <td class="cell-commission">0 XAF</td>
                    <td class="cell-method">Mobile Money</td>
                    <td class="cell-date">2024-02-08 09:15</td>
                    <td class="cell-status"><span class="pill pill-error admin-finance-pill">Échoué</span></td>
                </tr>
                <tr>
                    <td class="cell-id">TX-1006</td>
                    <td class="cell-event">Match Foot Étoile vs Djamena</td>
                    <td class="cell-organizer">Beta Productions</td>
                    <td class="cell-type"><span class="pill pill-success admin-finance-pill">Vente</span></td>
                    <td class="cell-amount">3 500 XAF</td>
                    <td class="cell-commission">350 XAF</td>
                    <td class="cell-method">Mobile Money</td>
                    <td class="cell-date">2024-02-08 20:30</td>
                    <td class="cell-status"><span class="pill pill-success admin-finance-pill">Confirmé</span></td>
                </tr>
                <tr>
                    <td class="cell-id">TX-1007</td>
                    <td class="cell-event">Concert Live N'Djamena</td>
                    <td class="cell-organizer">Alpha Events</td>
                    <td class="cell-type"><span class="pill pill-info admin-finance-pill">Commission</span></td>
                    <td class="cell-amount">1 000 XAF</td>
                    <td class="cell-commission">0 XAF</td>
                    <td class="cell-method">Virement</td>
                    <td class="cell-date">2024-02-07 12:00</td>
                    <td class="cell-status"><span class="pill pill-success admin-finance-pill">Payé</span></td>
                </tr>
                <tr>
                    <td class="cell-id">TX-1008</td>
                    <td class="cell-event">Soirée Urbaine VIP</td>
                    <td class="cell-organizer">Alpha Events</td>
                    <td class="cell-type"><span class="pill pill-success admin-finance-pill">Vente</span></td>
                    <td class="cell-amount">8 000 XAF</td>
                    <td class="cell-commission">800 XAF</td>
                    <td class="cell-method">Mobile Money</td>
                    <td class="cell-date">2024-02-07 19:45</td>
                    <td class="cell-status"><span class="pill pill-success admin-finance-pill">Confirmé</span></td>
                </tr>
            </tbody>
        </table>
        </div>
    </section>
</div>

<style>
.admin-finance-table {
    width: 100%;
    table-layout: fixed;
}

.admin-finance-table .col-id,
.admin-finance-table .cell-id {
    width: 92px;
    white-space: nowrap;
}

.admin-finance-table .col-type,
.admin-finance-table .cell-type,
.admin-finance-table .col-status,
.admin-finance-table .cell-status {
    width: 112px;
    text-align: center;
}

.admin-finance-table .col-amount,
.admin-finance-table .cell-amount,
.admin-finance-table .col-commission,
.admin-finance-table .cell-commission,
.admin-finance-table .col-date,
.admin-finance-table .cell-date {
    width: 120px;
    white-space: nowrap;
}

.admin-finance-table .col-method,
.admin-finance-table .cell-method {
    width: 120px;
}

.admin-finance-table .cell-event,
.admin-finance-table .cell-organizer,
.admin-finance-table .cell-method {
    word-break: break-word;
}

.admin-finance-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 88px;
    white-space: nowrap;
}

@media (max-width: 980px) {
    .admin-finance-table {
        min-width: 1140px;
    }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Initialiser DataTables pour les transactions
    if (typeof DataTableOS !== 'undefined') {
        DataTableOS.init('#transactions-table', {
            order: [[8, 'desc']], // Tri par date (décroissant)
            columns: [
                { width: '92px' },
                null,
                null,
                { width: '112px', orderable: false },
                { width: '120px' },
                { width: '120px' },
                { width: '120px' },
                { width: '120px' },
                { width: '112px', orderable: false }
            ]
        });
    }
});
</script>
{% endblock %}
