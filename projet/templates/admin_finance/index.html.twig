                            <td class="cell-organizer">Alpha Events</td>
                            <td class="cell-type"><span class="pill pill-warning admin-finance-pill">Remboursement</span></td>
                            <td class="cell-amount">-500 XAF</td>
                            <td class="cell-commission">0 XAF</td>
                            <td class="cell-method">Mobile Money</td>
                            <td class="cell-date">2024-02-09 11:20</td>
