</div>

<style>
.finance-tablist {
    display: flex;
    flex-wrap: wrap;
    gap: .5rem;
    margin-bottom: 1rem;
}

.finance-tab {
    border: 1px solid var(--couleur-bordure);
    background: var(--couleur-surface);
    color: var(--couleur-texte);
    border-radius: 12px;
    padding: .55rem .85rem;
    font-weight: 800;
    cursor: pointer;
}

.finance-tab.is-active {
    background: color-mix(in srgb, var(--couleur-secondaire) 14%, var(--couleur-surface));
    border-color: color-mix(in srgb, var(--couleur-secondaire) 45%, var(--couleur-bordure));
}

.finance-panel[hidden] {
    display: none;
}

.finance-kpis {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: .75rem;
    margin-top: .75rem;
}

.finance-kpi {
    border: 1px solid var(--couleur-bordure);
    background: var(--couleur-surface);
    border-radius: 12px;
    padding: .85rem;
    display: grid;
    gap: .35rem;
}

.finance-kpi-label {
    font-size: .8rem;
    font-weight: 800;
    color: var(--couleur-texte-secondaire);
    text-transform: uppercase;
    letter-spacing: .06em;
}

.finance-kpi-value {
    font-size: 1.1rem;
    font-weight: 900;
    color: var(--couleur-texte);
}

.admin-finance-table {
    width: 100%;
    table-layout: fixed;
}

.admin-finance-table .col-id,
.admin-finance-table .cell-id {
    width: 92px;
    white-space: nowrap;
}

.admin-finance-table .col-event,
.admin-finance-table .cell-event {
    width: 220px;
}

.admin-finance-table .col-organizer,
.admin-finance-table .cell-organizer {
    width: 180px;
}

.admin-finance-table .col-type,
.admin-finance-table .cell-type,
.admin-finance-table .col-status,
.admin-finance-table .cell-status {
    width: 112px;
    text-align: center;
}

.admin-finance-table .col-amount,
.admin-finance-table .cell-amount,
.admin-finance-table .col-commission,
.admin-finance-table .cell-commission,
.admin-finance-table .col-date,
.admin-finance-table .cell-date {
    width: 120px;
    white-space: nowrap;
}

.admin-finance-table .col-method,
.admin-finance-table .cell-method {
    width: 120px;
}

.admin-finance-table .cell-event,
.admin-finance-table .cell-organizer,
.admin-finance-table .cell-method {
    white-space: normal;
    word-break: normal;
    overflow-wrap: anywhere;
}

.admin-finance-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 88px;
    white-space: nowrap;
}

@media (max-width: 980px) {
    .admin-finance-table {
        min-width: 1140px;
    }
}

</style>

<script>
function initFinanceTabs() {
    const root = document.querySelector('[data-finance-tabs]');
    if (!root || root.dataset.financeTabsBound === '1') return;
    root.dataset.financeTabsBound = '1';

    const tabs = Array.from(root.querySelectorAll('[role="tab"]'));
    const panels = Array.from(root.querySelectorAll('[role="tabpanel"]'));

    function setActiveTab(activeTab) {
        tabs.forEach((tab) => {
            const isActive = tab === activeTab;
            tab.classList.toggle('is-active', isActive);
            tab.setAttribute('aria-selected', isActive ? 'true' : 'false');
            tab.tabIndex = isActive ? 0 : -1;
        });

        panels.forEach((panel) => {
            panel.hidden = panel.id !== activeTab.getAttribute('aria-controls');
        });
    }

    tabs.forEach((tab) => {
        tab.addEventListener('click', () => setActiveTab(tab));
        tab.addEventListener('keydown', (e) => {
            if (e.key !== 'ArrowLeft' && e.key !== 'ArrowRight') return;
            e.preventDefault();
            const index = tabs.indexOf(tab);
            const dir = e.key === 'ArrowRight' ? 1 : -1;
            const next = tabs[(index + dir + tabs.length) % tabs.length];
            next.focus();
            setActiveTab(next);
        });
    });
}

function initFinanceTransactionsTable() {
    const tableEl = document.getElementById('transactions-table');
    if (!tableEl || tableEl.dataset.dtInit === '1') return;
    tableEl.dataset.dtInit = '1';

    if (typeof DataTableOS === 'undefined') return;
    DataTableOS.init('#transactions-table', {
        order: [[8, 'desc']],
        columns: [
            { width: '92px' },
            null,
            null,
            { width: '112px', orderable: false },
            { width: '120px' },
            { width: '120px' },
            { width: '120px' },
            { width: '120px' },
            { width: '112px', orderable: false }
        ],
        columnDefs: [
            { targets: [2, 3, 6], visible: false }
        ]
    });
}

function initFinancePage() {
    initFinanceTabs();
    initFinanceTransactionsTable();
}

document.addEventListener('DOMContentLoaded', initFinancePage);
document.addEventListener('turbo:load', initFinancePage);
</script>
{% endblock %}
