{% extends 'base.html.twig' %}

{% block title %}{{ evenement.titre }}{% endblock %}

{% block body %}

<section class="product-page">
    <div class="product-hero">
        <div class="product-hero-media">
            <img class="product-hero-img" src="{{ evenement.image ?: '/images/placeholders/banniere-home.svg' }}" alt="{{ evenement.titre }}" />
        </div>

        <div class="product-hero-body">
            <h1 class="page-title">{{ evenement.titre }}</h1>
            <p class="page-subtitle">
                <span class="pill">{{ evenement.date|date('d/m/Y H:i') }}</span>
                <span class="pill">{{ evenement.lieu }}</span>
            </p>

            <div class="product-price">À partir de <strong>{{ evenement.prix_min }} XAF</strong></div>

            <div class="card-actions">
                <a class="btn btn-sm btn-secondary" href="{{ path('evenement.index') }}">Retour</a>
                <a class="btn btn-sm btn-primary" href="{{ path('achat.evenement', {slug: evenement.slug, id: evenement.id}) }}">Acheter</a>
                <form method="post" action="{{ path('panier.ajouter', {id: evenement.id}) }}">
                    <input type="hidden" name="quantite" value="1" />
                    <input type="hidden" name="redirect" value="panier" />
                    <button class="btn btn-sm btn-success" type="submit">Ajouter au panier</button>
                </form>
            </div>
        </div>
    </div>

    <div class="grid">
        <section class="card">
            <h2 class="card-title">Description</h2>
            <p class="card-meta">{{ evenement.description }}</p>
        </section>

        <section class="card">
            <h2 class="card-title">Billets disponibles</h2>
            <p class="card-meta">Gestion complète des types de billets et réservations</p>
            
            <div class="tickets-preview">
                <div class="preview-info">
                    <h4>Types de billets disponibles</h4>
                    <p>Consultez la page de gestion des billets pour voir tous les types, prix, disponibilités et l'historique des réservations.</p>
                </div>
                
                <div class="preview-stats">
                    <div class="stat-item">
                        <span class="stat-label">Types disponibles</span>
                        <span class="stat-value">4</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-label">Places totales</span>
                        <span class="stat-value">370</span>
                    </div>
                </div>
                
                <div class="preview-actions">
                    <a href="{{ path('event.billets', {slug: evenement.slug, id: evenement.id}) }}" class="btn btn-primary btn-large">
                        🎫 Gérer les billets
                    </a>
                </div>
            </div>
        </section>

        <section class="card">
            <h2 class="card-title">Historique des réservations</h2>
            <p class="card-meta">Dernières réservations et validations</p>

            <table id="reservations-table" class="table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Client</th>
                        <th>Type</th>
                        <th>Quantité</th>
                        <th>Total</th>
                        <th>Date</th>
                        <th>Statut</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>R-1001</td>
                    <td>marie.dupont@email.com</td>
                        <td><span class="pill pill-success">Simple</span></td>
                        <td>2</td>
                        <td>10 000 XAF</td>
                        <td>2024-02-10 14:30</td>
                        <td><span class="pill pill-success">Confirmé</span></td>
                        <td>
                            <a href="#" class="btn btn-sm btn-primary">Voir</a>
                            <a href="#" class="btn btn-sm btn-danger">Annuler</a>
                        </td>
                    </tr>
                    <tr>
                        <td>R-1002</td>
                        <td>jean.martin@email.com</td>
                        <td><span class="pill pill-warning">VIP</span></td>
                        <td>1</td>
                        <td>15 000 XAF</td>
                        <td>2024-02-10 16:45</td>
                        <td><span class="pill pill-success">Confirmé</span></td>
                        <td>
                            <a href="#" class="btn btn-sm btn-primary">Voir</a>
                            <a href="#" class="btn btn-sm btn-danger">Annuler</a>
                        </td>
                    </tr>
                    <tr>
                        <td>R-1003</td>
                        <td>alice.bob@email.com</td>
                        <td><span class="pill pill-success">Simple</span></td>
                        <td>3</td>
                        <td>15 000 XAF</td>
                        <td>2024-02-09 11:20</td>
                        <td><span class="pill pill-warning">En attente</span></td>
                        <td>
                            <a href="#" class="btn btn-sm btn-primary">Valider</a>
                            <a href="#" class="btn btn-sm btn-danger">Annuler</a>
                        </td>
                    </tr>
                    <tr>
                        <td>R-1004</td>
                        <td>bernard.roy@email.com</td>
                        <td><span class="pill pill-info">Premium</span></td>
                        <td>2</td>
                        <td>50 000 XAF</td>
                        <td>2024-02-08 20:30</td>
                        <td><span class="pill pill-success">Confirmé</span></td>
                        <td>
                            <a href="#" class="btn btn-sm btn-primary">Voir</a>
                            <a href="#" class="btn btn-sm btn-danger">Annuler</a>
                        </td>
                    </tr>
                </tbody>
            </table>
        </section>
    </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Initialiser DataTables pour les billets
    if (typeof DataTableOS !== 'undefined') {
        DataTableOS.init('#tickets-table', {
            order: [[1, 'asc']], // Tri par prix (croissant)
            columns: [
                { width: '80px', orderable: false },
                null,
                { width: '100px' },
                { width: '120px', orderable: false },
                { width: '150px', orderable: false }
            ]
        });

        // Initialiser DataTables pour les réservations
        DataTableOS.init('#reservations-table', {
            order: [[6, 'desc']], // Tri par date (décroissant)
            columns: [
                { width: '80px' },
                null,
                { width: '80px', orderable: false },
                { width: '80px' },
                { width: '100px' },
                { width: '150px' },
                { width: '80px', orderable: false },
                { width: '150px', orderable: false }
            ]
        });
    }
});
</script>
{% endblock %}
