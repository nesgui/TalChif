{% extends 'base.html.twig' %}

{% block title %}Événements - TalChif{% endblock %}

{% block meta_description %}Parcourez notre catalogue d'événements au Tchad. Trouvez votre prochain concert, festival ou soirée et réservez vos billets en ligne.{% endblock %}

{% block body %}
<style id="evenements-apple-style">
.catalog-page {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1rem;
}
.catalog-header {
    padding: 1.5rem 0 2rem;
    text-align: center;
}
.catalog-header h1 {
    font-size: 2.5rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    margin-bottom: 0.5rem;
    color: var(--couleur-texte);
}
.catalog-header p {
    margin: 0;
    color: var(--couleur-texte-secondaire);
    font-size: 1.1rem;
}
.catalog-toolbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 1rem 0 2rem;
    border-bottom: 1px solid var(--couleur-bordure-subtile, var(--couleur-bordure));
    margin-bottom: 2rem;
    flex-wrap: wrap;
}
.toolbar-left {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
}
.toolbar-title {
    font-size: 0.95rem;
    color: var(--couleur-texte-secondaire);
}
.toolbar-count {
    font-size: 0.95rem;
    font-weight: 600;
}
.toolbar-right {
    display: flex;
    align-items: center;
    gap: 0.5rem;
}
.toolbar-right select {
    min-width: 190px;
}
.catalog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1rem;
}
.catalog-card {
    background: var(--couleur-surface);
    border-radius: 8px;
    border: 1px solid var(--couleur-bordure-subtile, var(--couleur-bordure));
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    cursor: pointer;
    position: relative;
}
.catalog-card:hover {
    transform: scale(1.05);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.2);
    z-index: 10;
}
.catalog-card img {
    width: 100%;
    height: 280px;
    object-fit: cover;
    display: block;
}
.catalog-card-content {
    display: none;
}
.catalog-card-title {
    font-size: 0.95rem;
    font-weight: 600;
    margin-bottom: 0.25rem;
    line-height: 1.2;
    color: white;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
}
.catalog-card-meta {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.8);
    display: flex;
    align-items: center;
    gap: 0.5rem;
}
.catalog-card-meta::before {
    content: "📍";
    font-size: 0.7rem;
}
.catalog-card-price {
    font-size: 0.85rem;
    margin-top: 0.25rem;
    color: rgba(255, 255, 255, 0.9);
    font-weight: 500;
}
.catalog-card-actions {
    display: none;
}

/* Mode sombre - correction des couleurs des textes */
html[data-theme="dark"] .catalog-card-price,
html[data-theme="dark"] section .catalog-card-price,
html[data-theme="dark"] .catalog-card .catalog-card-price {
    color: #ffffff !important;
}

html[data-theme="dark"] .catalog-card-title,
html[data-theme="dark"] section .catalog-card-title,
html[data-theme="dark"] .catalog-card .catalog-card-title {
    color: #ffffff !important;
}

html[data-theme="dark"] .catalog-card-meta,
html[data-theme="dark"] section .catalog-card-meta,
html[data-theme="dark"] .catalog-card .catalog-card-meta {
    color: rgba(255, 255, 255, 0.9) !important;
}

/* Mode sombre - forcer tous les textes blancs dans les cartes */
html[data-theme="dark"] .catalog-card * {
    color: #ffffff !important;
}

html[data-theme="dark"] .catalog-card .catalog-card-meta {
    color: rgba(255, 255, 255, 0.9) !important;
}

/* Mode sombre - forcer les fonds des cartes en sombre */
html[data-theme="dark"] .catalog-card {
    background: #1D3557 !important;
    border-color: #457B9D !important;
}

/* Mode sombre - forcer les textes blancs avec spécificité maximale */
html[data-theme="dark"] section .category-section .catalog-card .catalog-card-content .catalog-card-price,
html[data-theme="dark"] .catalog-card .catalog-card-content .catalog-card-price,
html[data-theme="dark"] .catalog-card-price {
    color: #ffffff !important;
    text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.8) !important;
}

html[data-theme="dark"] section .category-section .catalog-card .catalog-card-content .catalog-card-title,
html[data-theme="dark"] .catalog-card .catalog-card-content .catalog-card-title,
html[data-theme="dark"] .catalog-card-title {
    color: #ffffff !important;
    text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.8) !important;
}

html[data-theme="dark"] section .category-section .catalog-card .catalog-card-content .catalog-card-meta,
html[data-theme="dark"] .catalog-card .catalog-card-content .catalog-card-meta,
html[data-theme="dark"] .catalog-card-meta {
    color: rgba(255, 255, 255, 0.9) !important;
    text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.8) !important;
}

.hero-banner {
    position: relative;
    height: 400px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    overflow: hidden;
    margin-bottom: 2rem;
}
.hero-banner::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: url('/images/evenements/evenement-1.jpg') center/cover;
    opacity: 0.3;
    z-index: 1;
}
.hero-content {
    position: relative;
    z-index: 2;
    height: 100%;
    display: flex;
    align-items: center;
    padding: 0 4rem;
}
.hero-text h1 {
    font-size: 3.5rem;
    font-weight: 700;
    color: white;
    margin-bottom: 1rem;
    text-shadow: 2px 2px 4px rgba(0,0,0,0.5);
}
.hero-text p {
    font-size: 1.3rem;
    color: rgba(255,255,255,0.9);
    margin-bottom: 2rem;
    text-shadow: 1px 1px 2px rgba(0,0,0,0.5);
}
.hero-buttons {
    display: flex;
    gap: 1rem;
}
.hero-buttons .btn {
    padding: 0.8rem 2rem;
    font-size: 1rem;
    border-radius: 50px;
    font-weight: 600;
    transition: all 0.3s ease;
}
.hero-buttons .btn-primary {
    background: white;
    color: #667eea;
    border: none;
}
.hero-buttons .btn-primary:hover {
    background: #f0f0f0;
    transform: translateY(-2px);
}
.hero-buttons .btn-secondary {
    background: rgba(255,255,255,0.2);
    color: white;
    border: 2px solid white;
}
.hero-buttons .btn-secondary:hover {
    background: rgba(255,255,255,0.3);
    transform: translateY(-2px);
}

@media (max-width: 768px) {
    .hero-banner {
        height: 300px;
    }
    .hero-content {
        padding: 0 2rem;
    }
    .hero-text h1 {
        font-size: 2.5rem;
    }
    .hero-text p {
        font-size: 1.1rem;
    }
    .hero-buttons {
        flex-direction: column;
    }
    .hero-buttons .btn {
        width: 100%;
        text-align: center;
    }
}
.category-section {
    margin-bottom: 2rem;
}
.category-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
}
.category-title {
    font-size: 1.3rem;
    font-weight: 600;
    color: var(--couleur-texte);
    margin: 0;
}
.category-link {
    color: var(--couleur-primaire);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    transition: color 0.2s ease;
}
.category-link:hover {
    color: color-mix(in srgb, var(--couleur-primaire) 85%, black 15%);
}
.category-row {
    display: flex;
    gap: 0.5rem;
    overflow-x: auto;
    padding: 0.5rem 0;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
}
.category-row::-webkit-scrollbar {
    height: 6px;
}
.category-row::-webkit-scrollbar-track {
    background: var(--couleur-surface-elevee, var(--couleur-surface));
    border-radius: 3px;
}
.category-row::-webkit-scrollbar-thumb {
    background: var(--couleur-bordure);
    border-radius: 3px;
}
.category-row::-webkit-scrollbar-thumb:hover {
    background: var(--couleur-bordure-subtile, var(--couleur-bordure));
}
.category-row .catalog-card {
    flex: 0 0 auto;
    width: 200px;
    min-width: 200px;
}
.product-link {
    text-decoration: none;
    color: inherit;
    display: block;
}
.product-rating {
    margin: 0.5rem 0;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}
.stars {
    display: inline-flex;
    font-size: 0.9rem;
    color: #ddd;
}
.stars-fill {
    position: absolute;
    color: #ffc107;
    overflow: hidden;
    white-space: nowrap;
}
.product-rating-meta {
    font-size: 0.85rem;
    color: var(--couleur-texte-secondaire);
}
@media (max-width: 768px) {
    .catalog-grid {
        grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
        gap: 0.75rem;
    }
    .catalog-header h1 {
        font-size: 2rem;
    }
    .catalog-toolbar {
        align-items: flex-start;
    }
    .toolbar-right {
        width: 100%;
        justify-content: flex-end;
    }
}
@media (max-width: 480px) {
    .catalog-grid {
        grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
        gap: 0.5rem;
    }
    .catalog-page {
        padding: 1rem 0.5rem;
    }
    .catalog-card img {
        height: 200px;
    }
}
</style>

<section class="catalog-page">
    <!-- Tous les événements -->
    <section class="category-section">
        <div class="category-header">
            <h2 class="category-title">Tous les événements</h2>
            <p class="toolbar-count">{{ evenements|length }} événement(s) trouvé(s)</p>
        </div>
        
        {% if evenements|length > 0 %}
            <div class="category-row">
                {% for evenement in evenements %}
                    {% set image_path = evenement.image starts with '/' ? evenement.image : '/' ~ evenement.image %}
                    <article class="catalog-card">
                        <a href="{{ path('evenement.show', {slug: evenement.slug, id: evenement.id}) }}" data-turbo="false">
                            <img src="{{ image_path }}" alt="Affiche de l'événement : {{ evenement.titre }}" 
                                 onerror="this.src='/images/evenements/default-event.jpg'; console.log('Image manquante: {{ image_path }}');">
                            <div class="catalog-card-content">
                                <div class="catalog-card-title">{{ evenement.titre }}</div>
                                <div class="catalog-card-meta">
                                    {{ evenement.ville }} • {{ evenement.date|date('d/m/Y H:i') }}
                                </div>
                                <div class="catalog-card-price">
                                    À partir de {{ evenement.prix_min|number_format(0, '.', ' ') }} XAF
                                </div>
                            </div>
                        </a>
                    </article>
                {% endfor %}
            </div>
        {% else %}
            <div class="empty-state">
                <div class="empty-state-icon">📅</div>
                <h3>Aucun événement trouvé</h3>
                <p>Il n'y a actuellement aucun événement disponible. Revenez nous voir plus tard !</p>
                <a href="{{ path('accueil_index') }}" class="btn btn-primary">Retour à l'accueil</a>
            </div>
        {% endif %}
    </section>
</section>

<style>
.empty-state {
    text-align: center;
    padding: 4rem 2rem;
    color: var(--couleur-texte-secondaire);
}

.empty-state-icon {
    font-size: 4rem;
    margin-bottom: 1rem;
    opacity: 0.5;
}

.empty-state h3 {
    color: var(--couleur-texte);
    margin-bottom: 0.5rem;
}

.empty-state p {
    margin-bottom: 2rem;
    max-width: 400px;
    margin-left: auto;
    margin-right: auto;
}

/* Mode sombre pour l'état vide */
html[data-theme="dark"] .empty-state {
    color: var(--couleur-texte-secondaire);
}

html[data-theme="dark"] .empty-state h3 {
    color: var(--couleur-texte);
}

/* Grille verticale sur mobile — remplace le scroll horizontal */
@media (max-width: 640px) {
    .category-row {
        display: grid !important;
        grid-template-columns: repeat(2, 1fr) !important;
        overflow-x: visible !important;
        overflow-y: visible !important;
        gap: .6rem !important;
        padding: 0 !important;
    }

    /* Les cartes reprennent leur pleine largeur dans la grille */
    .category-row .catalog-card {
        flex: none !important;
        width: 100% !important;
        min-width: 0 !important;
    }

    /* Image moins haute sur mobile */
    .catalog-card img {
        height: 180px !important;
        object-fit: cover;
    }

    /* Masquer les boutons de navigation prev/next sur mobile */
    .movie-nav {
        display: none !important;
    }

    /* Afficher le contenu texte sous l'image */
    .catalog-card-content {
        display: block !important;
        padding: .5rem;
        background: var(--couleur-surface);
    }

    .catalog-card-title {
        color: var(--couleur-texte) !important;
        font-size: .82rem;
        -webkit-line-clamp: 2;
    }

    .catalog-card-meta {
        color: var(--couleur-texte-secondaire) !important;
        font-size: .72rem;
        margin-top: .2rem;
    }

    .catalog-card-price {
        color: var(--couleur-primaire) !important;
        font-size: .78rem;
        margin-top: .15rem;
        font-weight: 600;
    }

    /* Toolbar compacte */
    .catalog-toolbar {
        flex-direction: column;
        gap: .5rem;
        padding: .5rem 0 1rem;
    }
    .toolbar-right {
        width: 100%;
    }
    .toolbar-right select {
        width: 100%;
        min-width: 0;
    }
}

/* 3 colonnes sur tablette */
@media (min-width: 641px) and (max-width: 900px) {
    .category-row {
        display: grid !important;
        grid-template-columns: repeat(3, 1fr) !important;
        overflow-x: visible !important;
        gap: .75rem !important;
    }
    .category-row .catalog-card {
        flex: none !important;
        width: 100% !important;
        min-width: 0 !important;
    }
    .movie-nav { display: none !important; }
    .catalog-card-content { display: block !important; padding: .5rem; }
    .catalog-card-title { color: var(--couleur-texte) !important; }
    .catalog-card-price { color: var(--couleur-primaire) !important; }
}
</style>
{% endblock %}
