{% extends 'base.html.twig' %}

{% block title %}{{ evenement.titre }} - TalChif{% endblock %}

{% block meta_description %}Découvrez {{ evenement.titre }} : {{ evenement.description|striptags|slice(0, 150) }}... Réservez vos billets dès maintenant.{% endblock %}

{% block og_title %}{{ evenement.titre }}{% endblock %}
{% block og_description %}{{ evenement.description|striptags|slice(0, 200) }}...{% endblock %}
{% block og_image %}
    <meta property="og:image" content="{{ app.request.schemeAndHttpHost ~ (evenement.image ?: '/images/placeholders/banniere-home.jpg') }}">
{% endblock %}
{% block og_type %}event{% endblock %}

{% block body %}
<section class="event-simple">
    <div class="event-card">
        <img class="event-img" src="{{ evenement.image ?: '/images/evenements/evenement-1.jpg' }}" alt="Affiche de l'événement {{ evenement.titre }}">
        <div class="event-content">
            <h1 class="page-title">{{ evenement.titre }}</h1>
            <p class="event-desc">{{ evenement.description|striptags|slice(0, 220) ~ (evenement.description|length > 220 ? '…' : '') }}</p>

            <div class="event-essential">
                <p><strong>Prix</strong> : à partir de {{ evenement.prix_min|number_format(0, '.', ' ') }} XAF</p>
                <p><strong>Date</strong> : {{ evenement.date|date('d/m/Y H:i') }}</p>
                <p><strong>Lieu</strong> : {{ evenement.lieu }}, {{ evenement.ville }}</p>
                <p><strong>Places restantes</strong> : {{ evenement.places_disponibles }}</p>
            </div>

            <div class="card-actions">
                <form method="post" action="{{ path('panier.ajouter', {id: evenement.id}) }}" class="btn-block">
                    <input type="hidden" name="quantite" value="1">
                    <input type="hidden" name="redirect" value="achat">
                    <button class="btn btn-primary btn-block" type="submit">Acheter maintenant</button>
                </form>
                <form method="post" action="{{ path('panier.ajouter', {id: evenement.id}) }}" class="btn-block">
                    <input type="hidden" name="quantite" value="1">
                    <input type="hidden" name="redirect" value="panier">
                    <button class="btn btn-secondary btn-block" type="submit">Ajouter au panier</button>
                </form>
            </div>
        </div>
    </div>
</section>

<style>
.event-simple { max-width: 920px; margin: 0 auto; }
.event-card { display: grid; grid-template-columns: 300px 1fr; gap: 1rem; align-items: stretch; background: var(--couleur-surface); border: 1px solid var(--couleur-bordure); border-radius: var(--rayon); padding: 1rem; }
.event-img { width: 100%; height: 100%; min-height: 260px; object-fit: cover; border-radius: var(--rayon); aspect-ratio: 3 / 4; }
.event-content { display: grid; gap: .75rem; }
.event-desc { margin: 0; color: var(--couleur-texte-secondaire); }
.event-essential p { margin: .3rem 0; }

/* Correction boutons - éviter chevauchement */
.card-actions {
    display: flex;
    flex-direction: column;
    gap: .75rem;
    margin-top: 1rem;
}

.card-actions form {
    margin: 0;
    flex: 1;
}

.card-actions .btn {
    width: 100%;
    padding: .75rem 1rem;
    font-size: 1rem;
    font-weight: 600;
    border-radius: var(--rayon);
    transition: all 0.2s ease;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

/* Mobile : boutons en colonne */
@media (max-width: 820px) {
    .event-card { 
        grid-template-columns: 1fr; 
        gap: 1.5rem;
    }
    .event-img { 
        min-height: 210px;
        max-height: none;
        width: 100%;
        aspect-ratio: 16 / 10;
    }
    .card-actions {
        flex-direction: column;
        gap: 1rem;
    }
    .card-actions .btn {
        padding: .8rem 1rem;
        font-size: 1.1rem;
    }
}

/* Très petits écrans */
@media (max-width: 480px) {
    .event-simple {
        padding: 0 .5rem;
    }
    .event-card {
        padding: .75rem;
        gap: 1rem;
    }
    .card-actions {
        gap: .75rem;
    }
    .card-actions .btn {
        padding: .7rem .9rem;
        font-size: 1rem;
    }
}
</style>
{% endblock %}
