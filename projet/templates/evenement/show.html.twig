{% extends 'base.html.twig' %}

{% block title %}{{ evenement.titre }}{% endblock %}

{% block body %}
{% set largeur_note = (evenement.note / 5) * 100 %}

<section class="product-page">
    <div class="product-hero">
        <div class="product-hero-media">
            <img class="product-hero-img" src="{{ evenement.image }}" alt="{{ evenement.titre }}" />
            {% if evenement.badge %}
                <span class="product-badge">{{ evenement.badge }}</span>
            {% endif %}
        </div>

        <div class="product-hero-body">
            <h1 class="page-title">{{ evenement.titre }}</h1>
            <p class="page-subtitle">
                <span class="pill">{{ evenement.date }}</span>
                <span class="pill">{{ evenement.lieu }}</span>
            </p>

            <div class="product-rating">
                <span class="stars" aria-label="Note {{ evenement.note }} sur 5">
                    <span class="stars-fill" style="width: {{ largeur_note }}%"></span>
                </span>
                <span class="product-rating-meta">{{ evenement.note }} ({{ evenement.avis }})</span>
            </div>

            <div class="product-price">À partir de <strong>{{ evenement.prix_min }} XAF</strong></div>

            <div class="card-actions">
                <a class="btn" href="{{ path('evenement.index') }}">Retour</a>
                <a class="btn btn-primary" href="{{ path('achat.evenement', {slug: evenement.slug, id: evenement.id}) }}">Acheter</a>
                <form method="post" action="{{ path('panier.ajouter', {id: evenement.id}) }}">
                    <input type="hidden" name="quantite" value="1" />
                    <input type="hidden" name="redirect" value="panier" />
                    <button class="btn" type="submit">Ajouter au panier</button>
                </form>
            </div>
        </div>
    </div>

    <div class="grid">
        <section class="card">
            <h2 class="card-title">Description</h2>
            <p class="card-meta">{{ evenement.description }}</p>
        </section>

        <section class="card">
            <h2 class="card-title">Billets</h2>
            <table class="table">
                <thead>
                    <tr>
                        <th>Type</th>
                        <th>Prix</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    {% for billet in evenement.types_billets %}
                        <tr>
                            <td>{{ billet.code }}</td>
                            <td>{{ billet.prix }} XAF</td>
                            <td>
                                <a class="btn btn-primary" href="{{ path('achat.evenement', {slug: evenement.slug, id: evenement.id}) }}">Acheter</a>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </section>
    </div>
</section>
{% endblock %}
