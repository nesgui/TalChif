{% extends 'base.html.twig' %}

{% block title %}Participants - {{ evenement.nom }}{% endblock %}

{% block body %}
<div class="participants-container">
    <div class="participants-header">
        <h1 class="page-title">
            <a href="{{ path('organisateur.dashboard') }}" class="back-link">← Retour</a>
            Liste des participants
        </h1>
        <div class="event-info">
            <h2>{{ evenement.nom }}</h2>
            <p class="event-meta">{{ evenement.dateEvenement|date('d/m/Y H:i') }} • {{ evenement.lieu }}</p>
        </div>
    </div>

    <!-- Filtres et recherche -->
    <div class="filters-section">
        <div class="filters-row">
            <div class="filter-group">
                <label for="search">Rechercher</label>
                <input type="text" id="search" class="search-input" placeholder="Nom ou email...">
            </div>
            <div class="filter-group">
                <label for="type-filter">Type de billet</label>
                <select id="type-filter" class="filter-select">
                    <option value="">Tous</option>
                    <option value="simple">Standard</option>
                    <option value="vip">VIP</option>
                </select>
            </div>
            <div class="filter-group">
                <label for="status-filter">Statut</label>
                <select id="status-filter" class="filter-select">
                    <option value="">Tous</option>
                    <option value="paid">Payé</option>
                    <option value="used">Utilisé</option>
                </select>
            </div>
        </div>
        <div class="export-section">
            <a href="{{ path('organisateur.evenement.export', {id: evenement.id}) }}" class="btn btn-primary">
                📥 Exporter en CSV
            </a>
        </div>
    </div>

    <!-- Tableau des participants -->
    <div class="table-container">
        <div class="table-wrapper">
            <table class="participants-table">
                <thead>
                    <tr>
                        <th>Nom complet</th>
                        <th>Email</th>
                        <th>Type billet</th>
                        <th>Prix</th>
                        <th>Date d'achat</th>
                        <th>Statut paiement</th>
                        <th>Statut utilisation</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for participant in participants %}
                    <tr class="participant-row" data-name="{{ participant.client.fullName|lower }}" data-email="{{ participant.client.email|lower }}" data-type="{{ participant.type }}">
                        <td class="name-cell">
                            <div class="participant-name">{{ participant.client.fullName }}</div>
                        </td>
                        <td class="email-cell">
                            <div class="participant-email">{{ participant.client.email }}</div>
                        </td>
                        <td class="type-cell">
                            <span class="ticket-type-badge {{ participant.type == 'vip' ? 'vip' : 'standard' }}">
                                {{ participant.type|upper }}
                            </span>
                        </td>
                        <td class="price-cell">
                            <span class="price-amount">{{ participant.prix|number_format(0, '.', ' ') }}</span>
                            <span class="price-currency">XAF</span>
                        </td>
                        <td class="date-cell">
                            <div class="date-info">
                                <span class="date-main">{{ participant.createdAt|date('d/m/Y') }}</span>
                                <span class="date-time">{{ participant.createdAt|date('H:i') }}</span>
                            </div>
                        </td>
                        <td class="status-cell">
                            <span class="status-badge {{ participant.statutPaiement == 'PAYE' ? 'paid' : 'pending' }}">
                                {% if participant.statutPaiement == 'PAYE' %}
                                    ✅ Payé
                                {% else %}
                                    ⏳ En attente
                                {% endif %}
                            </span>
                        </td>
                        <td class="status-cell">
                            <span class="status-badge {{ participant.utilise ? 'used' : 'available' }}">
                                {% if participant.utilise %}
                                    ❌ Utilisé
                                {% else %}
                                    ✅ Disponible
                                {% endif %}
                            </span>
                        </td>
                        <td class="actions-cell">
                            <div class="action-buttons">
                                <button class="btn-small btn-view" onclick="viewQRCode('{{ participant.qrCode }}')">
                                    📱 QR Code
                                </button>
                                {% if not participant.utilise %}
                                    <button class="btn-small btn-validate" onclick="validateTicket('{{ participant.id }}')">
                                        ✅ Valider
                                    </button>
                                {% endif %}
                            </div>
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="8" class="no-participants">
                            <div class="empty-state">
                                <div class="empty-icon">👥</div>
                                <h3>Aucun participant trouvé</h3>
                                <p>Aucun billet n'a été vendu pour cet événement.</p>
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <!-- Pagination -->
    {% if totalPages > 1 %}
    <div class="pagination">
        {% if currentPage > 1 %}
            <a href="{{ path('organisateur.evenement.participants', {id: evenement.id, page: currentPage - 1}) }}" class="page-link">←</a>
        {% endif %}
        
        {% set startPage = max(1, currentPage - 2) %}
        {% set endPage = min(totalPages, currentPage + 2) %}
        
        {% for page in startPage..endPage %}
            {% if page == currentPage %}
                <span class="page-current">{{ page }}</span>
            {% else %}
                <a href="{{ path('organisateur.evenement.participants', {id: evenement.id, page: page}) }}" class="page-link">{{ page }}</a>
            {% endif %}
        {% endfor %}
        
        {% if currentPage < totalPages %}
            <a href="{{ path('organisateur.evenement.participants', {id: evenement.id, page: currentPage + 1}) }}" class="page-link">→</a>
        {% endif %}
    </div>
    {% endif %}

    <!-- Modal QR Code -->
    <div id="qrModal" class="modal" style="display: none;">
        <div class="modal-content">
            <div class="modal-header">
                <h3>QR Code du billet</h3>
                <button class="modal-close" onclick="closeQRModal()">&times;</button>
            </div>
            <div class="modal-body">
                <div class="qr-display">
                    <div id="modalQRCode" class="qr-code-placeholder">
                        <!-- QR Code sera généré ici -->
                    </div>
                    <div class="qr-info">
                        <p class="qr-code-text" id="modalQRText"></p>
                        <button class="btn btn-primary" onclick="copyQRCode()">📋 Copier</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.participants-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 2rem;
}

.participants-header {
    margin-bottom: 2rem;
}

.page-title {
    font-size: 2rem;
    font-weight: 700;
    color: #1e293b;
    margin: 0 0 1rem 0;
    display: flex;
    align-items: center;
    gap: 1rem;
}

.back-link {
    color: #64748b;
    text-decoration: none;
    font-size: 1rem;
    font-weight: 500;
}

.back-link:hover {
    color: #3b82f6;
}

.event-info h2 {
    font-size: 1.5rem;
    font-weight: 600;
    color: #1e293b;
    margin: 0;
}

.event-meta {
    color: #64748b;
    font-size: 0.875rem;
    margin-top: 0.25rem;
}

.filters-section {
    background: white;
    padding: 1.5rem;
    border-radius: 8px;
    margin-bottom: 2rem;
    border: 1px solid #e2e8f0;
    box-shadow: 0 2px 8px rgba(0,0,0,0.05);
}

.filters-row {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 1rem;
    margin-bottom: 1rem;
}

.filter-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
}

.filter-group label {
    font-weight: 500;
    color: #374151;
    font-size: 0.875rem;
}

.search-input, .filter-select {
    padding: 0.75rem;
    border: 1px solid #d1d5db;
    border-radius: 6px;
    font-size: 0.875rem;
    transition: border-color 0.2s;
}

.search-input:focus, .filter-select:focus {
    outline: none;
    border-color: #3b82f6;
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
}

.export-section {
    display: flex;
    justify-content: flex-end;
}

.table-container {
    background: white;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid #e2e8f0;
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
}

.table-wrapper {
    overflow-x: auto;
}

.participants-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
}

.participants-table th {
    background: #f8fafc;
    padding: 1rem;
    text-align: left;
    font-weight: 600;
    color: #374151;
    border-bottom: 2px solid #e2e8f0;
    white-space: nowrap;
}

.participants-table td {
    padding: 1rem;
    border-bottom: 1px solid #f1f5f9;
    vertical-align: middle;
}

.participant-row:hover {
    background: #f8fafc;
}

.participant-name {
    font-weight: 500;
    color: #1e293b;
}

.participant-email {
    color: #64748b;
    font-size: 0.813rem;
}

.ticket-type-badge {
    padding: 0.25rem 0.75rem;
    border-radius: 12px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
}

.ticket-type-badge.standard {
    background: #dbeafe;
    color: #1e40af;
}

.ticket-type-badge.vip {
    background: #fef3c7;
    color: #d97706;
}

.price-amount {
    font-weight: 700;
    color: #1e293b;
}

.price-currency {
    color: #64748b;
    font-size: 0.75rem;
    margin-left: 0.25rem;
}

.date-info {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
}

.date-main {
    font-weight: 500;
    color: #1e293b;
}

.date-time {
    font-size: 0.75rem;
    color: #64748b;
}

.status-badge {
    padding: 0.25rem 0.75rem;
    border-radius: 12px;
    font-size: 0.75rem;
    font-weight: 600;
}

.status-badge.paid {
    background: #dcfce7;
    color: #16a34a;
}

.status-badge.pending {
    background: #fef3c7;
    color: #d97706;
}

.status-badge.used {
    background: #fee2e2;
    color: #dc2626;
}

.status-badge.available {
    background: #dcfce7;
    color: #16a34a;
}

.action-buttons {
    display: flex;
    gap: 0.5rem;
}

.btn-small {
    padding: 0.375rem 0.75rem;
    border: none;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
}

.btn-view {
    background: #3b82f6;
    color: white;
}

.btn-view:hover {
    background: #2563eb;
}

.btn-validate {
    background: #10b981;
    color: white;
}

.btn-validate:hover {
    background: #059669;
}

.no-participants {
    text-align: center;
    padding: 3rem;
}

.empty-state {
    color: #64748b;
}

.empty-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
}

.pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.5rem;
    margin-top: 2rem;
    padding: 1rem;
}

.page-link {
    padding: 0.5rem 0.75rem;
    border: 1px solid #d1d5db;
    border-radius: 4px;
    text-decoration: none;
    color: #374151;
    transition: all 0.2s;
}

.page-link:hover {
    background: #3b82f6;
    color: white;
    border-color: #3b82f6;
}

.page-current {
    padding: 0.5rem 0.75rem;
    background: #3b82f6;
    color: white;
    border-radius: 4px;
    font-weight: 600;
}

/* Modal styles */
.modal {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
}

.modal-content {
    background: white;
    border-radius: 12px;
    padding: 0;
    max-width: 500px;
    width: 90%;
    max-height: 90vh;
    overflow-y: auto;
}

.modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem;
    border-bottom: 1px solid #e2e8f0;
}

.modal-header h3 {
    margin: 0;
    font-size: 1.25rem;
    font-weight: 600;
    color: #1e293b;
}

.modal-close {
    background: none;
    border: none;
    font-size: 1.5rem;
    cursor: pointer;
    color: #64748b;
    padding: 0.25rem;
    border-radius: 4px;
}

.modal-close:hover {
    background: #f1f5f9;
}

.modal-body {
    padding: 1.5rem;
}

.qr-display {
    display: flex;
    gap: 1.5rem;
    align-items: center;
}

.qr-code-placeholder {
    width: 150px;
    height: 150px;
    background: #f8fafc;
    border: 2px solid #e2e8f0;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #64748b;
    font-size: 0.875rem;
}

.qr-info {
    flex: 1;
}

.qr-code-text {
    font-family: 'Courier New', monospace;
    background: #f8fafc;
    padding: 0.75rem;
    border-radius: 6px;
    border: 1px solid #e2e8f0;
    word-break: break-all;
    margin-bottom: 1rem;
    font-size: 0.875rem;
}

/* Responsive */
@media (max-width: 768px) {
    .participants-container {
        padding: 1rem;
    }
    
    .filters-row {
        grid-template-columns: 1fr;
        gap: 0.75rem;
    }
    
    .export-section {
        justify-content: flex-start;
        margin-top: 1rem;
    }
    
    .action-buttons {
        flex-direction: column;
    }
    
    .participants-table {
        font-size: 0.75rem;
    }
    
    .participants-table th,
    .participants-table td {
        padding: 0.75rem 0.5rem;
    }
    
    .qr-display {
        flex-direction: column;
        text-align: center;
    }
}
</style>

<script>
// Fonctions de recherche et filtrage
document.addEventListener('DOMContentLoaded', function() {
    const searchInput = document.getElementById('search');
    const typeFilter = document.getElementById('type-filter');
    const statusFilter = document.getElementById('status-filter');
    const rows = document.querySelectorAll('.participant-row');

    function filterTable() {
        const searchTerm = searchInput.value.toLowerCase();
        const typeValue = typeFilter.value;
        const statusValue = statusFilter.value;

        rows.forEach(row => {
            const name = row.dataset.name;
            const email = row.dataset.email;
            const type = row.dataset.type;
            
            let showRow = true;

            // Filtrage par recherche
            if (searchTerm && !name.includes(searchTerm) && !email.includes(searchTerm)) {
                showRow = false;
            }

            // Filtrage par type
            if (typeValue && type !== typeValue) {
                showRow = false;
            }

            // Filtrage par statut (à implémenter avec les données réelles)
            
            row.style.display = showRow ? '' : 'none';
        });
    }

    searchInput.addEventListener('input', filterTable);
    typeFilter.addEventListener('change', filterTable);
    statusFilter.addEventListener('change', filterTable);
});

function viewQRCode(qrCode) {
    document.getElementById('modalQRText').textContent = qrCode;
    document.getElementById('modalQRCode').innerHTML = '<div class="qr-loading">Génération en cours...</div>';
    document.getElementById('qrModal').style.display = 'flex';

    // Charger la bibliothèque QRCode et générer
    const script = document.createElement('script');
    script.src = 'https://cdn.jsdelivr.net/npm/qrcode@1.5.1/build/qrcode.min.js';
    script.onload = function() {
        QRCode.toCanvas(document.createElement('canvas'), qrCode, {
            width: 150,
            margin: 2,
            color: {
                dark: '#1e293b',
                light: '#ffffff'
            }
        }, function(error, canvas) {
            if (error) {
                document.getElementById('modalQRCode').innerHTML = '<div class="qr-error">Erreur</div>';
            } else {
                document.getElementById('modalQRCode').innerHTML = '';
                document.getElementById('modalQRCode').appendChild(canvas);
            }
        });
    };
    document.head.appendChild(script);
}

function closeQRModal() {
    document.getElementById('qrModal').style.display = 'none';
}

function copyQRCode() {
    const qrText = document.getElementById('modalQRText').textContent;
    navigator.clipboard.writeText(qrText).then(() => {
        alert('QR Code copié dans le presse-papiers !');
    });
}

function validateTicket(ticketId) {
    if (confirm('Valider ce billet comme utilisé ?')) {
        // Rediriger vers la page de validation avec le billet pré-sélectionné
        window.open(`/validation?ticket=${ticketId}`, '_blank');
    }
}

// Fermer le modal en cliquant à l'extérieur
document.getElementById('qrModal').addEventListener('click', function(e) {
    if (e.target === this) {
        closeQRModal();
    }
});
</script>
{% endblock %}
