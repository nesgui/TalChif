{% extends 'layout/dashboard.html.twig' %}

{% set section = 'organisateur' %}

{% block title %}Participants - {{ evenement.nom }}{% endblock %}

{% block dashboard_title %}Participants - {{ evenement.nom }}{% endblock %}

{% block dashboard_content %}
<div class="participants-container">
    <div class="participants-header">
        <h1 class="page-title">
            <a href="{{ path('organisateur.dashboard') }}" class="back-link">← Retour</a>
            Liste des participants
        </h1>
        <div class="event-info">
            <h2>{{ evenement.nom }}</h2>
            <p class="event-meta">{{ evenement.dateEvenement|date('d/m/Y H:i') }} • {{ evenement.lieu }}</p>
        </div>
    </div>

    <!-- Filtres et recherche -->
    <div class="filters-section">
        <div class="filters-row">
            <div class="filter-group">
                <label for="search">Rechercher</label>
                <input type="text" id="search" class="search-input" placeholder="Nom ou email...">
            </div>
            <div class="filter-group">
                <label for="type-filter">Type de billet</label>
                <select id="type-filter" class="filter-select">
                    <option value="">Tous</option>
                    <option value="simple">Standard</option>
                    <option value="vip">VIP</option>
                </select>
            </div>
            <div class="filter-group">
                <label for="status-filter">Statut</label>
                <select id="status-filter" class="filter-select">
                    <option value="">Tous</option>
                    <option value="paid">Payé</option>
                    <option value="used">Utilisé</option>
                </select>
            </div>
        </div>
        <div class="export-section">
            <a href="{{ path('organisateur.evenement.export', {id: evenement.id}) }}" class="btn btn-primary">
                📥 Exporter en CSV
            </a>
        </div>
    </div>

    <!-- Tableau des participants -->
    <div class="table-container">
        <div class="table-wrapper">
            <table class="participants-table dt-table" id="participants-table" data-order="[[4, 'desc']]">
                <thead>
                    <tr>
                        <th>Nom complet</th>
                        <th>Email</th>
                        <th>Type billet</th>
                        <th>Prix</th>
                        <th>Date d'achat</th>
                        <th>Statut paiement</th>
                        <th>Statut utilisation</th>
                        <th data-no-sort>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for participant in participants %}
                    <tr class="participant-row" data-name="{{ participant.client.fullName|lower }}" data-email="{{ participant.client.email|lower }}" data-type="{{ participant.type }}">
                        <td class="name-cell">
                            <div class="participant-name">{{ participant.client.fullName }}</div>
                        </td>
                        <td class="email-cell">
                            <div class="participant-email">{{ participant.client.email }}</div>
                        </td>
                        <td class="type-cell">
                            <span class="ticket-type-badge {{ participant.type == 'vip' ? 'vip' : 'standard' }}">
                                {{ participant.type|upper }}
                            </span>
                        </td>
                        <td class="price-cell">
                            <span class="price-amount">{{ participant.prix|number_format(0, '.', ' ') }}</span>
                            <span class="price-currency">XAF</span>
                        </td>
                        <td class="date-cell">
                            <div class="date-info">
                                <span class="date-main">{{ participant.createdAt|date('d/m/Y') }}</span>
                                <span class="date-time">{{ participant.createdAt|date('H:i') }}</span>
                            </div>
                        </td>
                        <td class="status-cell">
                            <span class="status-badge {{ participant.statutPaiement == 'PAYE' ? 'paid' : 'pending' }}">
                                {% if participant.statutPaiement == 'PAYE' %}
                                    Payé
                                {% else %}
                                    En attente
                                {% endif %}
                            </span>
                        </td>
                        <td class="status-cell">
                            <span class="status-badge {{ participant.utilise ? 'used' : 'available' }}">
                                {% if participant.utilise %}
                                    Utilisé
                                {% else %}
                                    Disponible
                                {% endif %}
                            </span>
                        </td>
                        <td class="actions-cell">
                            <div class="btn-group">
                                <button class="btn btn-sm btn-outline" onclick="viewQRCode('{{ participant.qrCode }}')" title="Voir QR Code">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                                        <rect x="7" y="7" width="3" height="3"/>
                                        <rect x="14" y="7" width="3" height="3"/>
                                        <rect x="14" y="14" width="3" height="3"/>
                                        <rect x="7" y="14" width="3" height="3"/>
                                    </svg>
                                    <span class="btn-label-desktop">QR Code</span>
                                </button>
                                {% if not participant.utilise %}
                                    <button class="btn btn-sm btn-success" onclick="validateTicket('{{ participant.id }}')" title="Valider ce billet">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <polyline points="20 6 9 17 4 12"/>
                                        </svg>
                                        <span class="btn-label-desktop">Valider</span>
                                    </button>
                                {% endif %}
                            </div>
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="8" class="no-participants">
                            <div class="empty-state">
                                <div class="empty-icon">👥</div>
                                <h3>Aucun participant trouvé</h3>
                                <p>Aucun billet n'a été vendu pour cet événement.</p>
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <!-- Modal QR Code -->
    <div id="qrModal" class="modal" style="display: none;">
        <div class="modal-content">
            <div class="modal-header">
                <h3>QR Code du billet</h3>
                <button class="modal-close" onclick="closeQRModal()">&times;</button>
            </div>
            <div class="modal-body">
                <div class="qr-display">
                    <div id="modalQRCode" class="qr-code-placeholder">
                        <!-- QR Code sera généré ici -->
                    </div>
                    <div class="qr-info">
                        <p class="qr-code-text" id="modalQRText"></p>
                        <button class="btn btn-primary" onclick="copyQRCode()">Copier</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.participants-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 2rem;
}

.participants-header {
    margin-bottom: 2rem;
}

.page-title {
    font-size: 2rem;
    font-weight: 700;
    color: var(--couleur-texte);
    margin: 0 0 1rem 0;
    display: flex;
    align-items: center;
    gap: 1rem;
}

.back-link {
    color: var(--couleur-texte-secondaire);
    text-decoration: none;
    font-size: 1rem;
    font-weight: 500;
}

.back-link:hover {
    color: var(--couleur-primaire);
}

.event-info h2 {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--couleur-texte);
    margin: 0;
}

.event-meta {
    color: var(--couleur-texte-secondaire);
    font-size: 0.875rem;
    margin-top: 0.25rem;
}

.filters-section {
    background: white;
    padding: 1.5rem;
    border-radius: 8px;
    margin-bottom: 2rem;
    border: 1px solid var(--couleur-bordure);
    box-shadow: 0 2px 8px rgba(0,0,0,0.05);
}

.filters-row {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 1rem;
    margin-bottom: 1rem;
}

.filter-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
}

.filter-group label {
    font-weight: 500;
    color: var(--couleur-texte);
    font-size: 0.875rem;
}

.search-input, .filter-select {
    padding: 0.75rem;
    border: 1px solid #d1d5db;
    border-radius: 6px;
    font-size: 0.875rem;
    transition: border-color 0.2s;
}

.search-input:focus, .filter-select:focus {
    outline: none;
    border-color: var(--couleur-primaire);
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
}

.export-section {
    display: flex;
    justify-content: flex-end;
}

.table-container {
    background: white;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--couleur-bordure);
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
}

.table-wrapper {
    overflow-x: auto;
}

.participants-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
}

.participants-table th {
    background: var(--couleur-surface);
    padding: 1rem;
    text-align: left;
    font-weight: 600;
    color: var(--couleur-texte);
    border-bottom: 2px solid var(--couleur-bordure);
    white-space: nowrap;
}

.participants-table td {
    padding: 1rem;
    border-bottom: 1px solid var(--couleur-surface);
    vertical-align: middle;
}

.participant-row:hover {
    background: var(--couleur-surface);
}

.participant-name {
    font-weight: 500;
    color: var(--couleur-texte);
}

.participant-email {
    color: var(--couleur-texte-secondaire);
    font-size: 0.813rem;
}

.ticket-type-badge {
    padding: 0.25rem 0.75rem;
    border-radius: 12px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
}

.ticket-type-badge.standard {
    background: color-mix(in srgb, var(--couleur-info, var(--couleur-primaire)) 15%, var(--couleur-surface));
    color: var(--couleur-texte);
}

.ticket-type-badge.vip {
    background: color-mix(in srgb, var(--couleur-warning) 18%, var(--couleur-surface));
    color: var(--couleur-texte);
}

.price-amount {
    font-weight: 700;
    color: var(--couleur-texte);
}

.price-currency {
    color: var(--couleur-texte-secondaire);
    font-size: 0.75rem;
    margin-left: 0.25rem;
}

.date-info {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
}

.date-main {
    font-weight: 500;
    color: var(--couleur-texte);
}

.date-time {
    font-size: 0.75rem;
    color: var(--couleur-texte-secondaire);
}

.status-badge {
    padding: 0.25rem 0.75rem;
    border-radius: 12px;
    font-size: 0.75rem;
    font-weight: 600;
}

.status-badge.paid {
    background: #dcfce7;
    color: #16a34a;
}

.status-badge.pending {
    background: #fef3c7;
    color: #d97706;
}

.status-badge.used {
    background: #fee2e2;
    color: #dc2626;
}

.status-badge.available {
    background: #dcfce7;
    color: #16a34a;
}

.action-buttons {
    display: flex;
    gap: 0.5rem;
}

.btn-small {
    padding: 0.375rem 0.75rem;
    border: none;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
}

.btn-view {
    background: var(--couleur-primaire);
    color: white;
}

.btn-view:hover {
    background: #2563eb;
}

.btn-validate {
    background: #10b981;
    color: white;
}

.btn-validate:hover {
    background: #059669;
}

.no-participants {
    text-align: center;
    padding: 3rem;
}

.empty-state {
    color: var(--couleur-texte-secondaire);
}

.empty-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
}

.pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.5rem;
    margin-top: 2rem;
    padding: 1rem;
}

.page-link {
    padding: 0.5rem 0.75rem;
    border: 1px solid #d1d5db;
    border-radius: 4px;
    text-decoration: none;
    color: var(--couleur-texte);
    transition: all 0.2s;
}

.page-link:hover {
    background: var(--couleur-primaire);
    color: white;
    border-color: var(--couleur-primaire);
}

.page-current {
    padding: 0.5rem 0.75rem;
    background: var(--couleur-primaire);
    color: white;
    border-radius: 4px;
    font-weight: 600;
}

/* Modal styles */
.modal {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
}

.modal-content {
    background: white;
    border-radius: 12px;
    padding: 0;
    max-width: 500px;
    width: 90%;
    max-height: 90vh;
    overflow-y: auto;
}

.modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem;
    border-bottom: 1px solid var(--couleur-bordure);
}

.modal-header h3 {
    margin: 0;
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--couleur-texte);
}

.modal-close {
    background: none;
    border: none;
    font-size: 1.5rem;
    cursor: pointer;
    color: var(--couleur-texte-secondaire);
    padding: 0.25rem;
    border-radius: 4px;
}

.modal-close:hover {
    background: var(--couleur-surface);
}

.modal-body {
    padding: 1.5rem;
}

.qr-display {
    display: flex;
    gap: 1.5rem;
    align-items: center;
}

.qr-code-placeholder {
    width: 150px;
    height: 150px;
    background: var(--couleur-surface);
    border: 2px solid var(--couleur-bordure);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--couleur-texte-secondaire);
    font-size: 0.875rem;
}

.qr-info {
    flex: 1;
}

.qr-code-text {
    font-family: 'Courier New', monospace;
    background: var(--couleur-surface);
    padding: 0.75rem;
    border-radius: 6px;
    border: 1px solid var(--couleur-bordure);
    word-break: break-all;
    margin-bottom: 1rem;
    font-size: 0.875rem;
}

/* Responsive */
@media (max-width: 768px) {
    .participants-container {
        padding: 1rem;
    }
    
    .filters-row {
        grid-template-columns: 1fr;
        gap: 0.75rem;
    }
    
    .export-section {
        justify-content: flex-start;
        margin-top: 1rem;
    }
    
    .action-buttons {
        flex-direction: column;
    }
    
    .participants-table {
        font-size: 0.75rem;
    }
    
    .participants-table th,
    .participants-table td {
        padding: 0.75rem 0.5rem;
    }
    
    .qr-display {
        flex-direction: column;
        text-align: center;
    }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    if (typeof DataTableOS === 'undefined') {
        return;
    }

    const tableEl = document.querySelector('#participants-table');
    if (!tableEl) {
        return;
    }

    const dt = DataTableOS.init('#participants-table', {
        order: [[4, 'desc']],
        columnDefs: [
            { targets: [7], orderable: false }
        ]
    });

    if (!dt) {
        return;
    }

    const searchInput = document.getElementById('search');
    const typeFilter = document.getElementById('type-filter');
    const statusFilter = document.getElementById('status-filter');

    if (searchInput) {
        searchInput.addEventListener('input', function() {
            dt.search(this.value).draw();
        });
    }

    if (typeFilter) {
        typeFilter.addEventListener('change', function() {
            const val = (this.value || '').toUpperCase();
            dt.column(2).search(val).draw();
        });
    }

    if (statusFilter) {
        statusFilter.addEventListener('change', function() {
            const val = this.value;
            dt.column(5).search(val === 'paid' ? 'Payé' : '').draw();
            dt.column(6).search(val === 'used' ? 'Utilisé' : '').draw();
        });
    }
});

function viewQRCode(qrCode) {
    document.getElementById('modalQRText').textContent = qrCode;
    document.getElementById('modalQRCode').innerHTML = '<div class="qr-loading">Génération en cours...</div>';
    document.getElementById('qrModal').style.display = 'flex';

    // Charger la bibliothèque QRCode et générer
    const script = document.createElement('script');
    script.src = 'https://cdn.jsdelivr.net/npm/qrcode@1.5.1/build/qrcode.min.js';
    script.onload = function() {
        QRCode.toCanvas(document.createElement('canvas'), qrCode, {
            width: 150,
            margin: 2,
            color: {
                dark: 'var(--couleur-texte)',
                light: '#ffffff'
            }
        }, function(error, canvas) {
            if (error) {
                document.getElementById('modalQRCode').innerHTML = '<div class="qr-error">Erreur</div>';
            } else {
                document.getElementById('modalQRCode').innerHTML = '';
                document.getElementById('modalQRCode').appendChild(canvas);
            }
        });
    };
    document.head.appendChild(script);
}

function closeQRModal() {
    document.getElementById('qrModal').style.display = 'none';
}

function copyQRCode() {
    const qrText = document.getElementById('modalQRText').textContent;
    navigator.clipboard.writeText(qrText).then(() => {
        alert('QR Code copié dans le presse-papiers !');
    });
}

function validateTicket(ticketId) {
    if (confirm('Valider ce billet comme utilisé ?')) {
        // Rediriger vers la page de validation avec le billet pré-sélectionné
        window.open(`/validation?ticket=${ticketId}`, '_blank');
    }
}

// Fermer le modal en cliquant à l'extérieur
document.getElementById('qrModal').addEventListener('click', function(e) {
    if (e.target === this) {
        closeQRModal();
    }
});
</script>
{% endblock dashboard_content %}
