{% extends 'layout/dashboard.html.twig' %}

{% set section = 'admin' %}

{% block title %}Dashboard admin{% endblock %}

{% block dashboard_title %}Back-office admin{% endblock %}

{% block dashboard_content %}
<p class="page-subtitle">Fonctionnalités disponibles en back-office.</p>

<div class="grid">
    <section class="card">
        <h2 class="card-title">Accès rapides</h2>
        <p class="card-meta">Seules les fonctionnalités connectées aux données réelles sont proposées ici. Les autres modules (événements, organisateurs, finance, sécurité) seront activés au fur et à mesure de leur mise en service.</p>
        <div class="card-actions">
            <a class="btn btn-primary" href="{{ path('admin.user.index') }}">Gérer les utilisateurs</a>
            <a class="btn btn-secondary" href="{{ path('accueil') }}">Retour au site</a>
        </div>
    </section>
</div>
{% endblock %}
