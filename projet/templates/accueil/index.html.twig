    /* Style pour le placeholder d'événements indisponibles */
    .no-events-placeholder {
        display: flex;
        align-items: center;
        justify-content: center;
        height: 100%;
        min-height: 200px;
        background: var(--couleur-surface);
        color: var(--couleur-texte-tertiaire);
        font-size: 0.9rem;
        text-align: center;
        padding: 20px;
        border-radius: 8px;
    }
    
    .no-events-placeholder p {
        margin: 0;
        line-height: 1.4;
    }
    
    /* Styles pour les liens des cartes d'événements */
    .movie-card-link {
        text-decoration: none;
        color: inherit;
        display: block;
        transition: transform 0.3s ease;
    }
    
    .movie-card-link:hover {
        text-decoration: none;
        color: inherit;
    }
    
    .movie-card-link:hover .movie-card {
        transform: scale(1.05);
    }
}
</style>

<!-- Carrousel Movie Box Style -->
<section class="movie-carousel">
    <!-- Conteneur du carrousel -->
    <div class="carousel-container">
        <!-- Flèches de navigation -->
        <button class="carousel-nav carousel-prev" aria-label="Précédent">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
