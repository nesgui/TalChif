                            console.log('ID:', '{{ evenement.id }}');
                            console.log('Titre:', '{{ evenement.titre }}');
                            console.log('Image BDD:', '{{ evenement.image }}');
                            console.log('Image path:', '{{ image_path }}');
                            console.log('Fallback:', '{{ fallback_image }}');
                            console.log('CSS final: url(\'{{ image_path }}\'), url(\'{{ fallback_image }}\')');
                            
                            // Test direct de l'image
                            var img = new Image();
                            img.onload = function() { console.log('âœ… Image PREMIER Ã©vÃ©nement chargÃ©e avec succÃ¨s!'); };
                            img.onerror = function() { console.log('âŒ Image PREMIER Ã©vÃ©nement MANQUANTE!'); };
                            img.src = '{{ image_path }}';
                            
                            // Debug CSS du slide
