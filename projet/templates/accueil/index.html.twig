<script>
// Carrousel JavaScript
document.addEventListener('DOMContentLoaded', function() {
    const carousel = {
        slides: document.querySelectorAll('.carousel-slide'),
        indicators: document.querySelectorAll('.indicator'),
        prevBtn: document.querySelector('.carousel-prev'),
        nextBtn: document.querySelector('.carousel-next'),
        currentSlide: 0,
        totalSlides: 0,
        autoPlayInterval: null,
        
        init() {
            this.totalSlides = this.slides.length;
            if (this.totalSlides === 0) return;
            
            this.bindEvents();
            this.startAutoPlay();
        },
        
        bindEvents() {
            this.prevBtn.addEventListener('click', () => this.prevSlide());
            this.nextBtn.addEventListener('click', () => this.nextSlide());
            
            this.indicators.forEach((indicator, index) => {
                indicator.addEventListener('click', () => this.goToSlide(index));
            });
            
            // Pause auto-play on hover
            const carouselContainer = document.querySelector('.carousel-container');
            carouselContainer.addEventListener('mouseenter', () => this.stopAutoPlay());
            carouselContainer.addEventListener('mouseleave', () => this.startAutoPlay());
        },
        
        updateSlide() {
            const track = document.querySelector('.carousel-track');
            if (track) {
                track.style.transform = `translateX(-${this.currentSlide * 100}%)`;
            }
            
            this.indicators.forEach((indicator, index) => {
                indicator.classList.toggle('active', index === this.currentSlide);
            });
        },
        
        nextSlide() {
            this.currentSlide = (this.currentSlide + 1) % this.totalSlides;
            this.updateSlide();
        },
        
        prevSlide() {
            this.currentSlide = (this.currentSlide - 1 + this.totalSlides) % this.totalSlides;
            this.updateSlide();
        },
        
        goToSlide(index) {
            this.currentSlide = index;
            this.updateSlide();
        },
        
        startAutoPlay() {
            this.stopAutoPlay();
            this.autoPlayInterval = setInterval(() => this.nextSlide(), 5000);
        },
        
        stopAutoPlay() {
            if (this.autoPlayInterval) {
                clearInterval(this.autoPlayInterval);
                this.autoPlayInterval = null;
            }
        }
    };
    
    carousel.init();

    // Movie Box Navigation JavaScript
    const movieBoxNav = {
        categories: {
            concerts: { currentIndex: 0, cards: [] },
            sport: { currentIndex: 0, cards: [] },
            culture: { currentIndex: 0, cards: [] },
            recommendations: { currentIndex: 0, cards: [] }
        },
        
        init() {
            // Initialize each category
            Object.keys(this.categories).forEach(category => {
                const row = document.getElementById(`${category}-row`);
                if (row) {
                    this.categories[category].cards = Array.from(row.children);
                    this.updateNavButtons(category);
                }
            });
            
            // Bind navigation events
            document.querySelectorAll('.movie-nav').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    const category = e.target.dataset.category;
                    const direction = e.target.classList.contains('prev') ? 'prev' : 'next';
                    this.navigate(category, direction);
                });
            });
        },
        
        navigate(category, direction) {
            const categoryData = this.categories[category];
            const row = document.getElementById(`${category}-row`);
            
            if (!row || categoryData.cards.length === 0) return;
            
            const cardWidth = 220; // 200px + 20px gap
            const visibleCards = Math.floor(row.parentElement.offsetWidth / cardWidth);
            const maxIndex = Math.max(0, categoryData.cards.length - visibleCards);
            
            if (direction === 'prev') {
                categoryData.currentIndex = Math.max(0, categoryData.currentIndex - 1);
            } else {
                categoryData.currentIndex = Math.min(maxIndex, categoryData.currentIndex + 1);
            }
            
            const offset = categoryData.currentIndex * cardWidth;
            row.style.transform = `translateX(-${offset}px)`;
            
            this.updateNavButtons(category);
        },
        
        updateNavButtons(category) {
            const categoryData = this.categories[category];
            const row = document.getElementById(`${category}-row`);
            
            if (!row || categoryData.cards.length === 0) return;
            
            const cardWidth = 220;
            const visibleCards = Math.floor(row.parentElement.offsetWidth / cardWidth);
            const maxIndex = Math.max(0, categoryData.cards.length - visibleCards);
            
            const prevBtn = document.querySelector(`.movie-nav.prev[data-category="${category}"]`);
            const nextBtn = document.querySelector(`.movie-nav.next[data-category="${category}"]`);
            
            if (prevBtn) {
                prevBtn.classList.toggle('disabled', categoryData.currentIndex === 0);
            }
            
            if (nextBtn) {
                nextBtn.classList.toggle('disabled', categoryData.currentIndex >= maxIndex);
            }
        }
    };
    
    movieBoxNav.init();
    
    // Update navigation on window resize
    window.addEventListener('resize', () => {
        Object.keys(movieBoxNav.categories).forEach(category => {
            movieBoxNav.updateNavButtons(category);
        });
    });
});

(function() {
    function computeDominantColor(img) {
        var canvas = document.createElement('canvas');
        var ctx = canvas.getContext('2d', { willReadFrequently: true });
        if (!ctx) return null;

        var w = 32;
        var h = 32;
        canvas.width = w;
        canvas.height = h;

        ctx.drawImage(img, 0, 0, w, h);
        var data = ctx.getImageData(0, 0, w, h).data;

        var r = 0, g = 0, b = 0, count = 0;
        for (var i = 0; i < data.length; i += 4) {
            var a = data[i + 3];
            if (a < 40) continue;

            var rr = data[i];
            var gg = data[i + 1];
            var bb = data[i + 2];

            if (rr > 245 && gg > 245 && bb > 245) continue;
            if (rr < 10 && gg < 10 && bb < 10) continue;

            r += rr;
            g += gg;
            b += bb;
            count++;
        }

        if (!count) return null;
        r = Math.round(r / count);
        g = Math.round(g / count);
        b = Math.round(b / count);
        return 'rgb(' + r + ' ' + g + ' ' + b + ')';
    }

    function apply(img) {
        try {
            var color = computeDominantColor(img);
            if (!color) return;
            var media = img.closest('.apple-card-media');
            if (!media) return;
            media.style.setProperty('--event-dominant', color);
        } catch (e) {
            return;
        }
    }

    function init() {
        document.querySelectorAll('img[data-dominant-color]').forEach(function(img) {
            if (img.complete && img.naturalWidth) {
                apply(img);
            } else {
                img.addEventListener('load', function() { apply(img); }, { once: true });
            }
        });
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
    } else {
        init();
    }
})();
</script>

