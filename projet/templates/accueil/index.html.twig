{% extends 'base.html.twig' %}

{% block title %}Accueil - TalChif{% endblock %}

{% block meta_description %}Découvrez les prochains événements près de chez vous au Tchad. Concerts, festivals, soirées - Réservez vos billets en ligne.{% endblock %}

{% block body %}
<style id="accueil-apple-style">
.hero-apple {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(0, 1fr);
    gap: 3rem;
    align-items: center;
    padding: 3rem 2rem;
    border-radius: 24px;
    background: radial-gradient(circle at top left, var(--couleur-primaire) 0%, var(--couleur-fond) 55%);
    color: var(--couleur-texte-inverse);
    margin-bottom: 3rem;
}
.hero-apple-text h1 {
    font-size: 2.4rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    margin-bottom: 0.75rem;
}
.hero-apple-text p {
    font-size: 1.05rem;
    max-width: 28rem;
    opacity: 0.9;
    margin-bottom: 1.5rem;
}
.hero-apple-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
}
.hero-apple-actions .btn {
    border-radius: 999px;
}
.hero-apple-media {
    display: flex;
    justify-content: center;
}
.hero-apple-card {
    background: var(--couleur-surface);
    border-radius: 24px;
    padding: 1.75rem 1.5rem;
    box-shadow: 0 18px 45px rgba(0,0,0,0.25);
    max-width: 360px;
    width: 100%;
}
.hero-apple-card img {
    width: 100%;
    border-radius: 18px;
    margin-bottom: 1.25rem;
    object-fit: cover;
}
.hero-apple-card h2 {
    font-size: 1.15rem;
    margin-bottom: 0.35rem;
    color: var(--couleur-texte);
}
.hero-apple-card p {
    margin: 0;
    font-size: 0.95rem;
    color: var(--couleur-texte-secondaire);
}

.lineup {
    margin-bottom: 3rem;
}
.lineup-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.5rem;
}
.lineup-card {
    border-radius: 18px;
    padding: 1.5rem;
    background: var(--couleur-surface);
    border: 1px solid var(--couleur-bordure-subtile, var(--couleur-bordure));
}
.lineup-card h3 {
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
}
.lineup-card p {
    font-size: 0.95rem;
    color: var(--couleur-texte-secondaire);
    margin-bottom: 1rem;
}

.apple-catalog {
    display: grid;
    grid-template-columns: repeat(auto-fill, 280px);
    gap: 1.25rem;
    justify-content: start;
}
.apple-card {
    background: var(--couleur-surface);
    border-radius: 18px;
    padding: 1rem;
    border: 1px solid var(--couleur-bordure-subtile, var(--couleur-bordure));
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: transform var(--transition-rapide), box-shadow var(--transition-rapide), border-color var(--transition-rapide);
}
.apple-card:hover {
    border-color: color-mix(in srgb, var(--couleur-primaire) 45%, var(--couleur-bordure));
    box-shadow: var(--ombre-md);
    transform: translateY(-1px);
}
.apple-card:active {
    transform: translateY(0);
}

.apple-card-media {
    position: relative;
    border-radius: 14px;
    overflow: hidden;
    background: radial-gradient(120% 120% at 30% 20%, color-mix(in srgb, var(--event-dominant, rgba(0,0,0,0.18)) 45%, transparent) 0%, var(--couleur-surface) 62%);
    box-shadow: 0 18px 42px color-mix(in srgb, var(--event-dominant, rgba(0,0,0,0.25)) 42%, transparent);
    aspect-ratio: 4 / 3;
    display: grid;
    place-items: center;
}

.apple-card-media::after {
    content: '';
    position: absolute;
    inset: -18%;
    background: radial-gradient(closest-side at 50% 40%, color-mix(in srgb, var(--event-dominant, rgba(0,0,0,0.22)) 55%, transparent) 0%, transparent 70%);
    filter: blur(22px);
    opacity: 0.95;
    pointer-events: none;
}

.apple-card-media img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    position: relative;
    z-index: 1;
    transform: scale(0.98);
}

.event-badge {
    position: absolute;
    top: 10px;
    left: 10px;
    padding: 0.3rem 0.6rem;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    background: color-mix(in srgb, var(--couleur-primaire) 92%, black);
    color: var(--couleur-texte-inverse);
    border: 1px solid color-mix(in srgb, var(--couleur-primaire) 55%, white);
    box-shadow: 0 6px 18px rgba(0,0,0,0.18);
}

.event-badge.is-full {
    background: color-mix(in srgb, var(--couleur-error) 88%, black);
    border-color: color-mix(in srgb, var(--couleur-error) 50%, white);
}

.apple-card-body {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
}

.apple-card-title {
    font-weight: 700;
    font-size: clamp(0.98rem, 0.92rem + 0.4vw, 1.12rem);
    letter-spacing: -0.01em;
    color: var(--couleur-texte);
    line-height: 1.25;
}
.apple-card-meta {
    font-size: 0.92rem;
    color: var(--couleur-texte-secondaire);
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
}
.apple-card-price {
    margin-top: 0.1rem;
    font-size: 0.95rem;
    color: var(--couleur-texte);
}

.apple-card-actions {
    margin-top: 0.25rem;
}

.apple-card-actions .btn {
    width: 100%;
    justify-content: center;
    border-radius: 999px;
}

.why-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.5rem;
}
.why-card {
    padding: 1.5rem;
    border-radius: 18px;
    background: var(--couleur-surface);
    border: 1px solid var(--couleur-bordure-subtile, var(--couleur-bordure));
}
.why-card h3 {
    font-size: 1rem;
    margin-bottom: 0.4rem;
}
.why-card p {
    font-size: 0.9rem;
    color: var(--couleur-texte-secondaire);
}

.organisateur-block {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(0, 1fr);
    gap: 2.5rem;
    align-items: center;
    padding: 2.5rem 2rem;
    border-radius: 22px;
    background: var(--couleur-surface-elevated, var(--couleur-surface));
    border: 1px solid var(--couleur-bordure-subtile, var(--couleur-bordure));
}
.organisateur-block ul {
    padding-left: 1.1rem;
    margin: 0.75rem 0 0;
    font-size: 0.95rem;
}
.organisateur-block li {
    margin-bottom: 0.25rem;
}

@media (max-width: 920px) {
    .hero-apple {
        grid-template-columns: minmax(0, 1fr);
        padding: 2.5rem 1.5rem;
    }
    .hero-apple-media {
        justify-content: flex-start;
    }
    .organisateur-block {
        grid-template-columns: minmax(0, 1fr);
        padding: 2rem 1.5rem;
    }
}

@media (max-width: 520px) {
    .hero-apple {
        padding: 2rem 1.25rem;
        margin-bottom: 2rem;
    }
    .apple-catalog {
        grid-template-columns: 1fr;
        gap: 1rem;
    }
    .apple-card {
        padding: 0.9rem;
        border-radius: 16px;
    }
    .event-badge {
        top: 8px;
        left: 8px;
        font-size: 0.72rem;
    }
}
</style>

<section class="hero-apple">
    <div class="hero-apple-text">
        <h1>La façon moderne d’acheter vos billets au Tchad.</h1>
        <p>TalChif simplifie l’achat et la validation des billets pour les concerts, soirées, matchs et événements près de chez vous.</p>
        <div class="hero-apple-actions">
            <a href="{{ path('evenement.index') }}" class="btn btn-primary">Voir les événements</a>
            <a href="{{ path('achat.commandes') }}" class="btn">Mes commandes</a>
        </div>
    </div>
    <div class="hero-apple-media">
        <div class="hero-apple-card">
            <img src="/images/placeholders/banniere-home.jpg" alt="Aperçu d'événements TalChif">
            <h2>Billets numériques sécurisés</h2>
            <p>QR code, contrôle antifraude et validation en moins d’une seconde à l’entrée.</p>
        </div>
    </div>
</section>

<section class="section lineup">
    <h2 class="section-title">Découvrez les événements</h2>
    <div class="lineup-grid">
        <article class="lineup-card">
            <h3>Événements à la une</h3>
            <p>Une sélection d’événements populaires, choisis pour leur ambiance et leur qualité.</p>
            <a href="{{ path('evenement.index') }}" class="btn btn-xs btn-primary">Voir la sélection</a>
        </article>
        <article class="lineup-card">
            <h3>Concerts & soirées</h3>
            <p>Clubbing, live, DJs, soirées privées : réservez vos places en quelques clics.</p>
        </article>
        <article class="lineup-card">
            <h3>Sport & culture</h3>
            <p>Matchs, compétitions, conférences, spectacles… tout ce qui fait vibrer votre ville.</p>
        </article>
    </div>
</section>

<section class="section">
    <h2 class="section-title">Recommandations pour vous</h2>
    <div class="apple-catalog">
        {% for evenement in evenements %}
            <article class="apple-card">
                <a href="{{ path('evenement.show', {slug: evenement.slug, id: evenement.id}) }}" class="product-link" style="text-decoration:none; color:inherit;">
                    <div class="apple-card-media">
                        <img src="{{ evenement.image }}" alt="Affiche de l'événement : {{ evenement.titre }}" loading="lazy" data-dominant-color>
                        {% if evenement.badge %}
                            <span class="event-badge {{ evenement.badge == 'Complet' ? 'is-full' : '' }}">{{ evenement.badge }}</span>
                        {% endif %}
                    </div>
                    <div class="apple-card-body">
                        <div class="apple-card-title">{{ evenement.titre }}</div>
                        <div class="apple-card-meta">
                            <span class="pill">{{ evenement.ville }}</span>
                            <span class="pill">{{ evenement.date|date('d/m/Y H:i') }}</span>
                        </div>
                        <div class="apple-card-price">
                            À partir de <strong>{{ evenement.prix_min|number_format(0, '.', ' ') }} XAF</strong>
                        </div>
                    </div>
                </a>
                <div class="apple-card-actions">
                    <a href="{{ path('evenement.show', {slug: evenement.slug, id: evenement.id}) }}" class="btn btn-sm btn-primary">Voir les détails</a>
                </div>
            </article>
        {% else %}
            <p class="text-center text-muted">Aucun événement disponible pour le moment.</p>
        {% endfor %}
    </div>
    <div class="section-actions">
        <a class="btn btn-primary" href="{{ path('evenement.index') }}">Voir tous les événements</a>
    </div>
</section>

<script>
(function() {
    function computeDominantColor(img) {
        var canvas = document.createElement('canvas');
        var ctx = canvas.getContext('2d', { willReadFrequently: true });
        if (!ctx) return null;

        var w = 32;
        var h = 32;
        canvas.width = w;
        canvas.height = h;

        ctx.drawImage(img, 0, 0, w, h);
        var data = ctx.getImageData(0, 0, w, h).data;

        var r = 0, g = 0, b = 0, count = 0;
        for (var i = 0; i < data.length; i += 4) {
            var a = data[i + 3];
            if (a < 40) continue;

            var rr = data[i];
            var gg = data[i + 1];
            var bb = data[i + 2];

            if (rr > 245 && gg > 245 && bb > 245) continue;
            if (rr < 10 && gg < 10 && bb < 10) continue;

            r += rr;
            g += gg;
            b += bb;
            count++;
        }

        if (!count) return null;
        r = Math.round(r / count);
        g = Math.round(g / count);
        b = Math.round(b / count);
        return 'rgb(' + r + ' ' + g + ' ' + b + ')';
    }

    function apply(img) {
        try {
            var color = computeDominantColor(img);
            if (!color) return;
            var media = img.closest('.apple-card-media');
            if (!media) return;
            media.style.setProperty('--event-dominant', color);
        } catch (e) {
            return;
        }
    }

    function init() {
        document.querySelectorAll('img[data-dominant-color]').forEach(function(img) {
            if (img.complete && img.naturalWidth) {
                apply(img);
            } else {
                img.addEventListener('load', function() { apply(img); }, { once: true });
            }
        });
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
    } else {
        init();
    }
})();
</script>

<!-- Effet 3D désactivé : carte statique -->
{% endblock %}
