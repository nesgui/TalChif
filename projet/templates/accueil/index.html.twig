                                console.log('Background dimensions:', bg ? bg.offsetWidth + 'x' + bg.offsetHeight : 'N/A');
                                console.log('Slide visible:', slide ? (slide.offsetWidth > 0 && slide.offsetHeight > 0) : 'NON');
                            }, 100);
