                                console.log('=== DEBUG CSS PREMIER SLIDE ===');
                                console.log('Slide trouvÃ©:', slide ? 'OUI' : 'NON');
                                console.log('Background trouvÃ©:', bg ? 'OUI' : 'NON');
                                console.log('Style background-image:', bg ? bg.style.backgroundImage : 'N/A');
                                console.log('Style background-color:', bg ? bg.style.backgroundColor : 'N/A');
