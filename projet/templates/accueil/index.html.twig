{% extends 'base.html.twig' %}

{% block title %}Accueil{% endblock %}

{% block body %}
<section class="hero">
    <img class="hero-media" src="/images/placeholders/banniere-home.jpg" alt="Bannière" />
    <div class="hero-content">
        <h1 class="hero-title">Trouve ton prochain événement près de chez toi !</h1>
        <p class="hero-subtitle">Des soirées aux festivals, tout est à portée de clic.</p>
        <div class="hero-actions">
            <a class="btn btn-primary btn-xs" href="{{ path('evenement.index') }}">Explorer</a>
            <a class="btn btn-secondary btn-xs" href="{{ path('auth.login') }}">Se connecter</a>
        </div>
    </div>
</section>

<style>
/* Boutons ultra-compacts */
.btn-xs {
    padding: 0.25rem 0.75rem;
    font-size: 0.8125rem;
    line-height: 1;
}

/* Réduction espaces bannière */
.hero-content {
    padding: 8px !important;
    gap: 6px !important;
}

.hero-title {
    margin-bottom: 2px !important;
}

.hero-subtitle {
    margin-bottom: 4px !important;
}

/* Réduction taille image bannière */
.hero-media {
    max-height: 200px !important;
    width: 100%;
    object-fit: cover;
}

/* Réduction hauteur bannière complète */
.hero {
    max-height: 280px !important;
}

/* Responsive bannière */
@media (max-width: 768px) {
    .hero-media {
        max-height: 150px !important;
    }
    
    .hero {
        max-height: 220px !important;
    }
    
    .hero-content {
        padding: 6px !important;
        gap: 4px !important;
    }
    
    .hero-title {
        font-size: 18px !important;
    }
    
    .hero-subtitle {
        font-size: 14px !important;
    }
}

@media (max-width: 480px) {
    .hero-media {
        max-height: 120px !important;
    }
    
    .hero {
        max-height: 180px !important;
    }
    
    .hero-content {
        padding: 4px !important;
        gap: 3px !important;
    }
    
    .hero-title {
        font-size: 16px !important;
    }
    
    .hero-subtitle {
        font-size: 12px !important;
    }
    
    .btn-xs {
        font-size: 0.75rem !important;
        padding: 0.1875rem 0.625rem !important;
    }
}
</style>

<section class="section">
    <h2 class="section-title">Accès rapide</h2>
    <div class="quick-grid">
        <a class="quick-card" href="{{ path('evenement.index') }}">
            <div class="quick-title">Événements</div>
            <div class="quick-meta">Voir le catalogue</div>
        </a>
        <a class="quick-card" href="{{ path('portefeuille.index') }}">
            <div class="quick-title">Portefeuille</div>
            <div class="quick-meta">Mes billets</div>
        </a>
        <a class="quick-card" href="{{ path('auth.login') }}">
            <div class="quick-title">Compte</div>
            <div class="quick-meta">Connexion / inscription</div>
        </a>
    </div>
</section>

<section class="section">
    <h2 class="section-title">Recommandations</h2>
    <div class="catalog">
        {% for evenement in evenements %}
        <article class="product-card">
            <a class="product-link" href="{{ path('evenement.show', {slug: evenement.slug, id: evenement.id}) }}">
                <div class="product-media">
                    <img class="product-img" src="{{ evenement.image }}" alt="{{ evenement.titre }}" />
                    <span class="product-badge">{{ evenement.badge }}</span>
                </div>
                <div class="product-body">
                    <h3 class="product-title">{{ evenement.titre }}</h3>
                    <div class="product-rating">
                        <span class="stars" aria-label="Note {{ evenement.note }} sur 5">
                            <span class="stars-fill" style="width: {{ (evenement.note / 5 * 100)|round }}%"></span>
                        </span>
                        <span class="product-rating-meta">{{ evenement.note }} ({{ evenement.avis }})</span>
                    </div>
                    <div class="product-price">À partir de <strong>{{ evenement.prix_min|number_format(0, '.', ' ') }} XAF</strong></div>
                </div>
            </a>
        </article>
        {% else %}
        <p class="text-center text-gray-500">Aucun événement disponible pour le moment.</p>
        {% endfor %}
    </div>
    <div class="section-actions">
        <a class="btn btn-primary" href="{{ path('evenement.index') }}">Voir tout</a>
    </div>
</section>
{% endblock %}
