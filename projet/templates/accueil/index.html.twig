{% extends 'base.html.twig' %}

{% block title %}Accueil - TalChif{% endblock %}

{% block meta_description %}Découvrez les prochains événements près de chez vous au Tchad. Concerts, festivals, soirées - Réservez vos billets en ligne.{% endblock %}

{% block body %}
<style id="accueil-apple-style">
.hero-apple {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(0, 1fr);
    gap: 3rem;
    align-items: center;
    padding: 3rem 2rem;
    border-radius: 24px;
    background: radial-gradient(circle at top left, var(--couleur-primaire) 0%, var(--couleur-fond) 55%);
    color: var(--couleur-texte-inverse);
    margin-bottom: 3rem;
}
.hero-apple-text h1 {
    font-size: 2.4rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    margin-bottom: 0.75rem;
}
.hero-apple-text p {
    font-size: 1.05rem;
    max-width: 28rem;
    opacity: 0.9;
    margin-bottom: 1.5rem;
}
.hero-apple-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
}
.hero-apple-actions .btn {
    border-radius: 999px;
}
.hero-apple-media {
    display: flex;
    justify-content: center;
}
.hero-apple-card {
    background: var(--couleur-surface);
    border-radius: 24px;
    padding: 1.75rem 1.5rem;
    box-shadow: 0 18px 45px rgba(0,0,0,0.25);
    max-width: 360px;
    width: 100%;
}
.hero-apple-card img {
    width: 100%;
    border-radius: 18px;
    margin-bottom: 1.25rem;
    object-fit: cover;
}
.hero-apple-card h2 {
    font-size: 1.15rem;
    margin-bottom: 0.35rem;
    color: var(--couleur-texte);
}
.hero-apple-card p {
    margin: 0;
    font-size: 0.95rem;
    color: var(--couleur-texte-secondaire);
}

.lineup {
    margin-bottom: 3rem;
}
.lineup-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.5rem;
}
.lineup-card {
    border-radius: 18px;
    padding: 1.5rem;
    background: var(--couleur-surface);
    border: 1px solid var(--couleur-bordure-subtile, var(--couleur-bordure));
}
.lineup-card h3 {
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
}
.lineup-card p {
    font-size: 0.95rem;
    color: var(--couleur-texte-secondaire);
    margin-bottom: 1rem;
}

.apple-catalog {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    gap: 1.75rem;
}
.apple-card {
    background: var(--couleur-surface);
    border-radius: 20px;
    padding: 1.25rem 1.25rem 1.5rem;
    border: 1px solid var(--couleur-bordure-subtile, var(--couleur-bordure));
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
}
.apple-card img {
    border-radius: 16px;
    width: 100%;
    height: 150px;
    object-fit: cover;
}
.apple-card-title {
    font-weight: 600;
    font-size: 0.98rem;
}
.apple-card-meta {
    font-size: 0.9rem;
    color: var(--couleur-texte-secondaire);
}
.apple-card-price {
    margin-top: 0.35rem;
    font-size: 0.95rem;
}

.why-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.5rem;
}
.why-card {
    padding: 1.5rem;
    border-radius: 18px;
    background: var(--couleur-surface);
    border: 1px solid var(--couleur-bordure-subtile, var(--couleur-bordure));
}
.why-card h3 {
    font-size: 1rem;
    margin-bottom: 0.4rem;
}
.why-card p {
    font-size: 0.9rem;
    color: var(--couleur-texte-secondaire);
}

.organisateur-block {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(0, 1fr);
    gap: 2.5rem;
    align-items: center;
    padding: 2.5rem 2rem;
    border-radius: 22px;
    background: var(--couleur-surface-elevated, var(--couleur-surface));
    border: 1px solid var(--couleur-bordure-subtile, var(--couleur-bordure));
}
.organisateur-block ul {
    padding-left: 1.1rem;
    margin: 0.75rem 0 0;
    font-size: 0.95rem;
}
.organisateur-block li {
    margin-bottom: 0.25rem;
}

@media (max-width: 920px) {
    .hero-apple {
        grid-template-columns: minmax(0, 1fr);
        padding: 2.5rem 1.5rem;
    }
    .hero-apple-media {
        justify-content: flex-start;
    }
    .organisateur-block {
        grid-template-columns: minmax(0, 1fr);
        padding: 2rem 1.5rem;
    }
}
</style>

<section class="hero-apple">
    <div class="hero-apple-text">
        <h1>La façon moderne d’acheter vos billets au Tchad.</h1>
        <p>TalChif simplifie l’achat et la validation des billets pour les concerts, soirées, matchs et événements près de chez vous.</p>
        <div class="hero-apple-actions">
            <a href="{{ path('evenement.index') }}" class="btn btn-primary">Voir les événements</a>
            <a href="{{ path('achat.commandes') }}" class="btn">Mes commandes</a>
        </div>
    </div>
    <div class="hero-apple-media">
        <div class="hero-apple-card">
            <img src="/images/placeholders/banniere-home.jpg" alt="Aperçu d'événements TalChif">
            <h2>Billets numériques sécurisés</h2>
            <p>QR code, contrôle antifraude et validation en moins d’une seconde à l’entrée.</p>
        </div>
    </div>
</section>

<section class="section lineup">
    <h2 class="section-title">Découvrez les événements</h2>
    <div class="lineup-grid">
        <article class="lineup-card">
            <h3>Événements à la une</h3>
            <p>Une sélection d’événements populaires, choisis pour leur ambiance et leur qualité.</p>
            <a href="{{ path('evenement.index') }}" class="btn btn-xs btn-primary">Voir la sélection</a>
        </article>
        <article class="lineup-card">
            <h3>Concerts & soirées</h3>
            <p>Clubbing, live, DJs, soirées privées : réservez vos places en quelques clics.</p>
        </article>
        <article class="lineup-card">
            <h3>Sport & culture</h3>
            <p>Matchs, compétitions, conférences, spectacles… tout ce qui fait vibrer votre ville.</p>
        </article>
    </div>
</section>

<section class="section">
    <h2 class="section-title">Recommandations pour vous</h2>
    <div class="apple-catalog">
        {% for evenement in evenements %}
            <article class="apple-card">
                <a href="{{ path('evenement.show', {slug: evenement.slug, id: evenement.id}) }}" class="product-link">
                    <img src="{{ evenement.image }}" alt="Affiche de l'événement : {{ evenement.titre }}" loading="lazy">
                    <div class="apple-card-title">{{ evenement.titre }}</div>
                    <div class="apple-card-meta">
                        {{ evenement.ville }} • {{ evenement.date|date('d/m/Y H:i') }}
                    </div>
                    <div class="apple-card-price">
                        À partir de <strong>{{ evenement.prix_min|number_format(0, '.', ' ') }} XAF</strong>
                    </div>
                </a>
            </article>
        {% else %}
            <p class="text-center text-muted">Aucun événement disponible pour le moment.</p>
        {% endfor %}
    </div>
    <div class="section-actions">
        <a class="btn btn-primary" href="{{ path('evenement.index') }}">Voir tous les événements</a>
    </div>
</section>

<section class="section">
    <h2 class="section-title">Pourquoi acheter avec TalChif&nbsp;?</h2>
    <div class="why-grid">
        <article class="why-card">
            <h3>Paiement Mobile Money encadré</h3>
            <p>Référence unique obligatoire, vérification manuelle des paiements et anti‑fraude intégré.</p>
        </article>
        <article class="why-card">
            <h3>Billets QR sécurisés</h3>
            <p>Chaque billet possède un QR code unique, utilisable une seule fois à l’entrée.</p>
        </article>
        <article class="why-card">
            <h3>Support humain</h3>
            <p>Support WhatsApp visible, et suivi des commandes dans votre espace personnel.</p>
        </article>
        <article class="why-card">
            <h3>Dashboard organisateur</h3>
            <p>Statistiques de ventes, commission transparente, statut de règlement par événement.</p>
        </article>
    </div>
</section>

<section class="section">
    <div class="organisateur-block">
        <div>
            <h2>Pour les organisateurs</h2>
            <p>TalChif vous aide à vendre plus et à garder le contrôle : vue globale des ventes, billets sécurisés, validation rapide à l’entrée.</p>
            <ul>
                <li>Suivi des ventes en temps réel</li>
                <li>Commission fixe et claire</li>
                <li>Statut de règlement par événement</li>
            </ul>
        </div>
        <div>
            <a href="{{ path('auth.register') }}" class="btn btn-primary">Devenir organisateur</a>
        </div>
    </div>
</section>

<!-- Effet 3D désactivé : carte statique -->
{% endblock %}
