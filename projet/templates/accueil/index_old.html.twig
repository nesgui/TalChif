{% extends 'base.html.twig' %}

{% block title %}Accueil - TalChif{% endblock %}

{% block meta_description %}Découvrez les prochains événements près de chez vous au Tchad. Concerts, festivals, soirées - Réservez vos billets en ligne.{% endblock %}

{% block body %}
<style id="movie-carousel-style">
/* Carrousel Movie Box Style */
.movie-carousel {
    position: relative;
    width: 100%;
    height: 70vh;
    min-height: 500px;
    overflow: hidden;
    background: #000;
}

.carousel-search {
    position: absolute;
    top: 20px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 100;
    display: flex;
    align-items: center;
    gap: 15px;
    background: rgba(0, 0, 0, 0.7);
    padding: 10px 20px;
    border-radius: 50px;
    backdrop-filter: blur(10px);
}

.search-form {
    display: flex;
    align-items: center;
}

.search-input {
    width: 300px;
    padding: 10px 15px;
    border: none;
    border-radius: 25px;
    background: rgba(255, 255, 255, 0.1);
    color: white;
    font-size: 14px;
}

.search-input::placeholder {
    color: rgba(255, 255, 255, 0.7);
}

.search-btn {
    background: none;
    border: none;
    color: white;
    font-size: 16px;
    cursor: pointer;
    margin-left: 10px;
}

.download-app-btn {
    background: #e50914;
    color: white;
    border: none;
    padding: 10px 20px;
    border-radius: 25px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.3s;
}

.download-app-btn:hover {
    background: #f40612;
}

.carousel-container {
    position: relative;
    width: 100%;
    height: 100%;
}

.carousel-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(0, 0, 0, 0.5);
    color: white;
    border: none;
    width: 50px;
    height: 50px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 50;
    transition: background 0.3s;
}

.carousel-nav:hover {
    background: rgba(0, 0, 0, 0.8);
}

.carousel-prev {
    left: 20px;
}

.carousel-next {
    right: 20px;
}

.carousel-track {
    display: flex;
    width: 100%;
    height: 100%;
    transition: transform 0.5s ease-in-out;
}

.carousel-slide {
    min-width: 100%;
    height: 100%;
    position: relative;
    opacity: 0;
    transition: opacity 0.5s ease-in-out;
}

.carousel-slide.active {
    opacity: 1;
}

.slide-background {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    filter: brightness(0.4);
}

.slide-content {
    position: relative;
    z-index: 10;
    display: grid;
    grid-template-columns: 1fr 1fr;
    height: 100%;
    padding: 60px;
    align-items: center;
}

.slide-text h1 {
    font-size: 3.5rem;
    font-weight: 700;
    color: white;
    margin-bottom: 20px;
    line-height: 1.1;
}

.slide-text p {
    font-size: 1.2rem;
    color: rgba(255, 255, 255, 0.9);
    margin-bottom: 30px;
    max-width: 500px;
}

.slide-actions {
    display: flex;
    gap: 15px;
}

.btn-large {
    padding: 15px 30px;
    font-size: 16px;
    border-radius: 30px;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s;
}

.btn-primary.btn-large {
    background: #e50914;
    color: white;
    border: none;
}

.btn-primary.btn-large:hover {
    background: #f40612;
    transform: scale(1.05);
}

.btn-outline.btn-large {
    background: transparent;
    color: white;
    border: 2px solid white;
}

.btn-outline.btn-large:hover {
    background: white;
    color: black;
}

.slide-card {
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
    border-radius: 20px;
    padding: 30px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    max-width: 400px;
}

.card-badge {
    background: #e50914;
    color: white;
    padding: 8px 16px;
    border-radius: 20px;
    font-weight: 600;
    font-size: 14px;
    margin-bottom: 15px;
    display: inline-block;
}

.slide-card p {
    color: rgba(255, 255, 255, 0.9);
    font-size: 16px;
    line-height: 1.5;
    margin: 0;
}

.carousel-indicators {
    position: absolute;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 10px;
    z-index: 50;
}

.indicator {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: none;
    background: rgba(255, 255, 255, 0.4);
    cursor: pointer;
    transition: background 0.3s;
}

.indicator.active {
    background: white;
}

@media (max-width: 920px) {
    .movie-carousel {
        height: 80vh;
        min-height: 600px;
    }
    
    .slide-content {
        grid-template-columns: 1fr;
        padding: 40px 30px;
        text-align: center;
    }
    
    .slide-text h1 {
        font-size: 2.5rem;
    }
    
    .slide-card {
        max-width: 100%;
        margin-top: 30px;
    }
    
    .carousel-search {
        flex-direction: column;
        gap: 10px;
        padding: 15px;
    }
    
    .search-input {
        width: 250px;
    }
}

@media (max-width: 520px) {
    .movie-carousel {
        height: 90vh;
        min-height: 500px;
    }
    
    .slide-text h1 {
        font-size: 2rem;
    }
    
    .slide-text p {
        font-size: 1rem;
    }
    
    .slide-actions {
        flex-direction: column;
        align-items: center;
    }
    
    .carousel-nav {
        width: 40px;
        height: 40px;
    }
    
    .carousel-prev {
        left: 10px;
    }
    
    .carousel-next {
        right: 10px;
    }
}

.lineup {
    margin-bottom: 3rem;
}
.lineup-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.5rem;
}
.lineup-card {
    border-radius: 18px;
    padding: 1.5rem;
    background: var(--couleur-surface);
    border: 1px solid var(--couleur-bordure-subtile, var(--couleur-bordure));
}
.lineup-card h3 {
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
}
.lineup-card p {
    font-size: 0.95rem;
    color: var(--couleur-texte-secondaire);
    margin-bottom: 1rem;
}

.apple-catalog {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1rem;
    justify-content: start;
}
.apple-card {
    background: var(--couleur-surface);
    border-radius: 8px;
    border: 1px solid var(--couleur-bordure-subtile, var(--couleur-bordure));
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    cursor: pointer;
    position: relative;
}
.apple-card:hover {
    transform: scale(1.05);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.2);
    z-index: 10;
}
.apple-card:active {
    transform: scale(1.02);
}

.apple-card-media {
    position: relative;
    overflow: hidden;
    height: 280px;
}

.apple-card-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
}
.apple-card-body {
    display: none;
}
.apple-card-title {
    font-size: 0.9rem;
    font-weight: 600;
    margin-bottom: 0.25rem;
    line-height: 1.2;
    color: white;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
}
.apple-card-meta {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.8);
    display: flex;
    align-items: center;
    gap: 0.5rem;
}
.apple-card-meta::before {
    content: "📍";
    font-size: 0.7rem;
}
.apple-card-price {
    font-size: 0.8rem;
    margin-top: 0.25rem;
    color: rgba(255, 255, 255, 0.9);
    font-weight: 500;
}

.apple-card-actions {
    display: none;
}

.event-badge {
    position: absolute;
    top: 10px;
    left: 10px;
    padding: 0.3rem 0.6rem;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    background: color-mix(in srgb, var(--couleur-primaire) 92%, black);
    color: var(--couleur-texte-inverse);
    border: 1px solid color-mix(in srgb, var(--couleur-primaire) 55%, white);
    box-shadow: 0 6px 18px rgba(0,0,0,0.18);
}

.event-badge.is-full {
    background: color-mix(in srgb, var(--couleur-error) 88%, black);
    border-color: color-mix(in srgb, var(--couleur-error) 50%, white);
}

.apple-card-body {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
}

.apple-card-title {
    font-weight: 700;
    font-size: clamp(0.98rem, 0.92rem + 0.4vw, 1.12rem);
    letter-spacing: -0.01em;
    color: var(--couleur-texte);
    line-height: 1.25;
}
.apple-card-meta {
    font-size: 0.92rem;
    color: var(--couleur-texte-secondaire);
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
}
.apple-card-price {
    margin-top: 0.1rem;
    font-size: 0.95rem;
    color: var(--couleur-texte);
}

.apple-card-actions {
    margin-top: 0.25rem;
}

.apple-card-actions .btn {
    width: 100%;
    justify-content: center;
    border-radius: 999px;
}

.why-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.5rem;
}
.why-card {
    padding: 1.5rem;
    border-radius: 18px;
    background: var(--couleur-surface);
    border: 1px solid var(--couleur-bordure-subtile, var(--couleur-bordure));
}
.why-card h3 {
    font-size: 1rem;
    margin-bottom: 0.4rem;
}
.why-card p {
    font-size: 0.9rem;
    color: var(--couleur-texte-secondaire);
}

.organisateur-block {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(0, 1fr);
    gap: 2.5rem;
    align-items: center;
    padding: 2.5rem 2rem;
    border-radius: 22px;
    background: var(--couleur-surface-elevated, var(--couleur-surface));
    border: 1px solid var(--couleur-bordure-subtile, var(--couleur-bordure));
}
.organisateur-block ul {
    padding-left: 1.1rem;
    margin: 0.75rem 0 0;
    font-size: 0.95rem;
}
.organisateur-block li {
    margin-bottom: 0.25rem;
}

@media (max-width: 920px) {
    .hero-apple {
        grid-template-columns: minmax(0, 1fr);
        padding: 2.5rem 1.5rem;
    }
    .hero-apple-media {
        justify-content: flex-start;
    }
    .organisateur-block {
        grid-template-columns: minmax(0, 1fr);
        padding: 2rem 1.5rem;
    }
}

@media (max-width: 520px) {
    .hero-apple {
        padding: 2rem 1.25rem;
        margin-bottom: 2rem;
    }
    .apple-catalog {
        grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
        gap: 0.75rem;
    }
    .apple-card-media {
        height: 220px;
    }
    .event-badge {
        top: 8px;
        left: 8px;
        font-size: 0.72rem;
    }
}
</style>

<section class="movie-carousel">
    <div class="hero-apple-text">
        <h1>La façon moderne d’acheter vos billets au Tchad.</h1>
        <p>TalChif simplifie l’achat et la validation des billets pour les concerts, soirées, matchs et événements près de chez vous.</p>
        <div class="hero-apple-actions">
            <a href="{{ path('evenement.index') }}" class="btn btn-primary">Voir les événements</a>
            <a href="{{ path('achat.commandes') }}" class="btn">Mes commandes</a>
        </div>
    </div>
    <div class="hero-apple-media">
        <div class="hero-apple-card">
            <img src="/images/placeholders/banniere-home.jpg" alt="Aperçu d'événements TalChif">
            <h2>Billets numériques sécurisés</h2>
            <p>QR code, contrôle antifraude et validation en moins d’une seconde à l’entrée.</p>
        </div>
    </div>
</section>

<section class="section lineup">
    <h2 class="section-title">Découvrez les événements</h2>
    <div class="lineup-grid">
        <article class="lineup-card">
            <h3>Événements à la une</h3>
            <p>Une sélection d’événements populaires, choisis pour leur ambiance et leur qualité.</p>
            <a href="{{ path('evenement.index') }}" class="btn btn-xs btn-primary">Voir la sélection</a>
        </article>
        <article class="lineup-card">
            <h3>Concerts & soirées</h3>
            <p>Clubbing, live, DJs, soirées privées : réservez vos places en quelques clics.</p>
        </article>
        <article class="lineup-card">
            <h3>Sport & culture</h3>
            <p>Matchs, compétitions, conférences, spectacles… tout ce qui fait vibrer votre ville.</p>
        </article>
    </div>
</section>

<section class="section">
    <h2 class="section-title">Recommandations pour vous</h2>
    <div class="apple-catalog">
        {% for evenement in evenements %}
            <article class="apple-card">
                <a href="{{ path('evenement.show', {slug: evenement.slug, id: evenement.id}) }}" style="text-decoration:none; color:inherit;">
                    <div class="apple-card-media">
                        <img src="{{ evenement.image|slice(1) }}" alt="Affiche de l'événement : {{ evenement.titre }}">
                        {% if evenement.badge %}
                            <span class="event-badge {{ evenement.badge == 'Complet' ? 'is-full' : '' }}">{{ evenement.badge }}</span>
                        {% endif %}
                        <div class="apple-card-body">
                            <div class="apple-card-title">{{ evenement.titre }}</div>
                            <div class="apple-card-meta">
                                {{ evenement.ville }} • {{ evenement.date|date('d/m/Y H:i') }}
                            </div>
                            <div class="apple-card-price">
                                À partir de {{ evenement.prix_min|number_format(0, '.', ' ') }} XAF
                            </div>
                        </div>
                    </div>
                </a>
            </article>
        {% else %}
            <p class="text-center text-muted">Aucun événement disponible pour le moment.</p>
        {% endfor %}
    </div>
    <div class="section-actions">
        <a class="btn btn-primary" href="{{ path('evenement.index') }}">Voir tous les événements</a>
    </div>
</section>

<script>
(function() {
    function computeDominantColor(img) {
        var canvas = document.createElement('canvas');
        var ctx = canvas.getContext('2d', { willReadFrequently: true });
        if (!ctx) return null;

        var w = 32;
        var h = 32;
        canvas.width = w;
        canvas.height = h;

        ctx.drawImage(img, 0, 0, w, h);
        var data = ctx.getImageData(0, 0, w, h).data;

        var r = 0, g = 0, b = 0, count = 0;
        for (var i = 0; i < data.length; i += 4) {
            var a = data[i + 3];
            if (a < 40) continue;

            var rr = data[i];
            var gg = data[i + 1];
            var bb = data[i + 2];

            if (rr > 245 && gg > 245 && bb > 245) continue;
            if (rr < 10 && gg < 10 && bb < 10) continue;

            r += rr;
            g += gg;
            b += bb;
            count++;
        }

        if (!count) return null;
        r = Math.round(r / count);
        g = Math.round(g / count);
        b = Math.round(b / count);
        return 'rgb(' + r + ' ' + g + ' ' + b + ')';
    }

    function apply(img) {
        try {
            var color = computeDominantColor(img);
            if (!color) return;
            var media = img.closest('.apple-card-media');
            if (!media) return;
            media.style.setProperty('--event-dominant', color);
        } catch (e) {
            return;
        }
    }

    function init() {
        document.querySelectorAll('img[data-dominant-color]').forEach(function(img) {
            if (img.complete && img.naturalWidth) {
                apply(img);
            } else {
                img.addEventListener('load', function() { apply(img); }, { once: true });
            }
        });
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
    } else {
        init();
    }
})();
</script>

<!-- Effet 3D désactivé : carte statique -->
{% endblock %}
