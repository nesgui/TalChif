<!DOCTYPE html>
<html lang="fr" class="no-js">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}TalChif{% endblock %}</title>

        {# Indicateur JS pour gérer l'affichage des messages flash (fallback vs toasts) #}
        <script>
            document.documentElement.classList.remove('no-js');
            document.documentElement.classList.add('js');
        </script>

        {# Style minimal pour le lien d'accès rapide : caché sauf au focus clavier #}
        <style>
            .skip-link {
                position: absolute;
                top: -100px;
                left: 1rem;
                z-index: 10000;
                padding: 0.5rem 1rem;
                background: #000;
                color: #fff;
                text-decoration: none;
                border-radius: 4px;
                font-weight: 600;
            }

            .skip-link:focus {
                top: 1rem;
            }
        </style>
        
        {# Meta tags SEO modernes (2026) #}
        <meta name="description" content="{% block meta_description %}Plateforme de billetterie en ligne pour événements au Tchad. Découvrez et réservez vos billets pour concerts, festivals et soirées.{% endblock %}">
        <meta name="keywords" content="{% block meta_keywords %}événements, billetterie, Tchad, concerts, festivals, réservation{% endblock %}">
        <meta name="author" content="TalChif">
        <meta name="robots" content="{% block meta_robots %}index, follow{% endblock %}">
        
        {# Open Graph / Facebook #}
        <meta property="og:type" content="{% block og_type %}website{% endblock %}">
        <meta property="og:title" content="{% block og_title %}{{ block('title') }}{% endblock %}">
        <meta property="og:description" content="{% block og_description %}{{ block('meta_description') }}{% endblock %}">
        <meta property="og:url" content="{{ app.request.uri }}">
        {% block og_image %}<meta property="og:image" content="{{ app.request.schemeAndHttpHost }}/images/placeholders/banniere-home.jpg">{% endblock %}
        <meta property="og:locale" content="fr_FR">
        <meta property="og:site_name" content="TalChif">
        
        {# Twitter Card #}
        <meta name="twitter:card" content="summary_large_image">
        <meta name="twitter:title" content="{% block twitter_title %}{{ block('title') }}{% endblock %}">
        <meta name="twitter:description" content="{% block twitter_description %}{{ block('meta_description') }}{% endblock %}">
        {% block twitter_image %}<meta name="twitter:image" content="{{ app.request.schemeAndHttpHost }}/images/placeholders/banniere-home.jpg">{% endblock %}
        
        {# Favicon #}
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        
        {# Preconnect pour performance (CDN externes) #}
        <link rel="preconnect" href="https://code.jquery.com">
        <link rel="preconnect" href="https://cdn.datatables.net">
        <link rel="preconnect" href="https://cdnjs.cloudflare.com">
        <link rel="dns-prefetch" href="https://code.jquery.com">
        <link rel="dns-prefetch" href="https://cdn.datatables.net">
        {% block stylesheets %}
            <link rel="stylesheet" href="{{ asset('styles/app.css') }}">

            {% if section is defined and section == 'admin' %}
                <link rel="stylesheet" href="{{ asset('styles/admin.css') }}">
            {% elseif section is defined and section == 'organisateur' %}
                <link rel="stylesheet" href="{{ asset('styles/organisateur.css') }}">
            {% endif %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
            
            <!-- Load services via importmap (système custom moderne) -->
            <script type="module" src="{{ asset('services/notification_service.js') }}"></script>
            <script type="module" src="{{ asset('services/theme_service.js') }}"></script>
            
            <!-- Scripts spécifiques admin (DataTables) -->
            {% if section is defined and section == 'admin' %}
                <!-- jQuery (DataTables uniquement) -->
                <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
                <!-- DataTables core -->
                <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
                <!-- Bibliothèques pour les exports DataTables -->
                <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
                <!-- JSZip local pour éviter les problèmes de tracking -->
                <script src="https://unpkg.com/jszip@3.10.1/dist/jszip.min.js"></script>
                <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
                <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.print.min.js"></script>
                <script type="module" src="{{ asset('services/datatables-service.js') }}"></script>
            {% endif %}
            
            <!-- Scripts globaux -->
            <script src="{{ asset('scripts/lazy-images.js') }}" defer></script>
            <script src="{{ asset('scripts/responsive-tables.js') }}" defer></script>
        {% endblock %}
    </head>
    <body>
        {# Skip link pour accessibilité (navigation clavier) #}
        <a href="#main-content" class="skip-link">Aller au contenu principal</a>
        
        {% block site_header %}
            <input class="public-toggle" type="checkbox" id="public-menu" />

            <header class="public-header">
                <div class="container public-topbar">
                    <a class="public-brand" href="{{ path('accueil') }}">TalChif</a>
                    <div class="public-topbar-actions">
                        <button class="auth-theme-toggle" id="theme-toggle" 
                                data-controller="theme" 
                                data-theme-target="toggle"
                                data-action="click->theme#toggle" 
                                title="Basculer le thème">
                            <svg class="theme-icon-light" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <circle cx="12" cy="12" r="5"/>
                                <line x1="12" y1="1" x2="12" y2="3"/>
                                <line x1="12" y1="21" x2="12" y2="23"/>
                                <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
                                <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
                                <line x1="1" y1="12" x2="3" y2="12"/>
                                <line x1="21" y1="12" x2="23" y2="12"/>
                                <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
                                <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
                            </svg>
                            <svg class="theme-icon-dark" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display: none;">
                                <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
                            </svg>
                        </button>
                        <label class="public-action" for="public-menu" aria-label="Ouvrir le menu">☰</label>
                    </div>
                </div>

                <div class="container public-search">
                    <form class="public-search-form" action="{{ path('evenement.index') }}" method="get">
                        <input class="public-search-input" type="search" name="q" placeholder="Rechercher un événement…" autocomplete="off" />
                    </form>
                </div>

                <div class="container public-drawer" aria-label="Menu">
                    {% if app.user %}
                        <div class="public-drawer-content">
                            <span class="public-drawer-welcome">
                                Bonjour {{ app.user.nom|default(app.user.email) }}
                            </span>
                            <div class="public-drawer-actions">
                                {% if is_granted('ROLE_ORGANISATEUR') %}
                                    <a class="public-drawer-link public-drawer-link-highlight" href="{{ path('organisateur.dashboard') }}" data-turbo="false">Espace organisateur</a>
                                {% endif %}
                                {% if is_granted('ROLE_ADMIN') %}
                                    <a class="public-drawer-link public-drawer-link-highlight" href="{{ path('admin.dashboard') }}" data-turbo="false">Administration</a>
                                {% endif %}
                                {% if is_granted('ROLE_ORGANISATEUR') %}
                                    <a class="public-drawer-link" href="{{ path('validation.index') }}">Validation</a>
                                {% endif %}
                                <a class="public-drawer-link public-drawer-link-danger" href="{{ path('auth.logout') }}">Déconnexion</a>
                            </div>
                        </div>
                    {% endif %}
                </div>
            </header>

            <nav class="public-bottom-nav" aria-label="Navigation principale">
                <a class="public-tab" href="{{ path('accueil') }}" {% if app.request.attributes.get('_route') == 'accueil' %}aria-current="page"{% endif %}>
                    <span class="public-tab-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M3 11.5L12 4l9 7.5" />
                            <path d="M5 10.5V20h14v-9.5" />
                            <path d="M10 20v-6h4v6" />
                        </svg>
                    </span>
                    <span class="public-tab-label">Accueil</span>
                </a>
                <a class="public-tab" href="{{ path('evenement.index') }}" {% if app.request.attributes.get('_route') starts with 'evenement.' %}aria-current="page"{% endif %}>
                    <span class="public-tab-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M3 7h18" />
                            <path d="M6 7V5a2 2 0 0 1 2-2h1" />
                            <path d="M18 7V5a2 2 0 0 0-2-2h-1" />
                            <rect x="3" y="7" width="18" height="14" rx="2" />
                            <path d="M7 11h4" />
                            <path d="M7 15h6" />
                        </svg>
                    </span>
                    <span class="public-tab-label">Événements</span>
                </a>
                <a class="public-tab" href="{{ path('panier.index') }}" {% if app.request.attributes.get('_route') starts with 'panier.' %}aria-current="page"{% endif %}>
                    <span class="public-tab-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M6 7h15l-2 10H8L6 7z" />
                            <path d="M6 7l-2 0" />
                            <circle cx="9" cy="20" r="1" />
                            <circle cx="18" cy="20" r="1" />
                        </svg>
                    </span>
                    <span class="public-tab-label">Panier</span>
                </a>
                {% if app.user %}
                {% if is_granted('ROLE_CLIENT') %}
                <a class="public-tab" href="{{ path('portefeuille.index') }}" {% if app.request.attributes.get('_route') starts with 'portefeuille.' %}aria-current="page"{% endif %}>
                    <span class="public-tab-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M4 7h15a1 1 0 0 1 1 1v10a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V7z" />
                            <path d="M20 10h-5a2 2 0 0 0 0 4h5" />
                            <path d="M7 7V6a2 2 0 0 1 2-2h10" />
                        </svg>
                    </span>
                    <span class="public-tab-label">Espace client</span>
                </a>
                {% endif %}
                {% if not is_granted('ROLE_CLIENT') %}
                <a class="public-tab" href="{{ path('profile.index') }}" {% if app.request.attributes.get('_route') starts with 'profile.' %}aria-current="page"{% endif %}>
                    <span class="public-tab-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M20 21a8 8 0 0 0-16 0" />
                            <circle cx="12" cy="8" r="4" />
                        </svg>
                    </span>
                    <span class="public-tab-label">Profil</span>
                </a>
                {% endif %}
                {% else %}
                <a class="public-tab public-me-trigger" href="#" role="button" aria-haspopup="menu" aria-expanded="false" data-turbo="false" {% if app.request.attributes.get('_route') starts with 'public.' %}aria-current="page"{% endif %}>
                    <span class="public-tab-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M20 21a8 8 0 0 0-16 0" />
                            <circle cx="12" cy="8" r="4" />
                        </svg>
                    </span>
                    <span class="public-tab-label">Moi</span>
                </a>
                {% endif %}
            </nav>

            {% if not app.user %}
                <div class="public-me-dropdown" id="public-me-dropdown" role="menu" aria-hidden="true">
                    <div class="public-me-dropdown-head">
                        <div class="public-me-dropdown-title">Veuillez vous connecter</div>
                        <a class="btn btn-xs btn-primary" href="{{ path('auth.login') }}">Se connecter</a>
                    </div>
                    <div class="public-me-dropdown-list">
                        <a class="public-me-dropdown-item" role="menuitem" href="{{ path('public.devenir_organisateur') }}">
                            <span class="public-me-dropdown-icon" aria-hidden="true">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M12 2v20" />
                                    <path d="M2 12h20" />
                                </svg>
                            </span>
                            <span>Devenir Organisateur</span>
                        </a>
                        <a class="public-me-dropdown-item" role="menuitem" href="{{ path('public.infos') }}">
                            <span class="public-me-dropdown-icon" aria-hidden="true">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                    <circle cx="12" cy="12" r="10" />
                                    <path d="M12 16v-4" />
                                    <path d="M12 8h.01" />
                                </svg>
                            </span>
                            <span>Plus d'informations</span>
                        </a>
                        <a class="public-me-dropdown-item" role="menuitem" href="{{ path('public.a_propos') }}">
                            <span class="public-me-dropdown-icon" aria-hidden="true">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M12 20h9" />
                                    <path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z" />
                                </svg>
                            </span>
                            <span>A propos de nous</span>
                        </a>
                    </div>
                </div>
            {% endif %}
        {% endblock %}

        {% block site_main %}
            <main id="main-content" class="site-main" role="main">
                <div class="container">
                    {% include 'partials/flashes.html.twig' %}
                    {% block body %}{% endblock %}
                </div>
            </main>

            <footer class="site-footer">
                <div class="container footer-inner">
                    <div class="footer-brand">
                        <span class="footer-logo">TalChif</span>
                        <span class="muted footer-tagline">La billetterie du Tchad</span>
                    </div>
                    <nav class="footer-links" aria-label="Liens du pied de page">
                        <a href="{{ path('evenement.index') }}" class="footer-link">Événements</a>
                        <a href="{{ path('public.devenir_organisateur') }}" class="footer-link">Devenir organisateur</a>
                        <a href="{{ path('public.a_propos') }}" class="footer-link">À propos</a>
                        <a href="{{ path('public.infos') }}" class="footer-link">Aide</a>
                    </nav>
                    <div class="footer-copy muted">© {{ "now"|date("Y") }} TalChif</div>
                </div>
            </footer>
        {% endblock %}
        <!-- Conteneur pour les notifications (toasts) -->
        <div id="notifications-container"
             class="notifications-container"
             role="region"
             aria-live="polite"
             aria-atomic="false"
             aria-label="Notifications">
        </div>
    </body>
</html>
