<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}OCEA.td{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        {% block stylesheets %}
            <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
            <link rel="stylesheet" href="{{ asset('styles/notifications.css') }}">
            <link rel="stylesheet" href="{{ asset('styles/tailwind-forms.css') }}">
            <link rel="stylesheet" href="{{ asset('styles/datatables.css') }}">
            <link rel="stylesheet" href="{{ asset('styles/buttons-uniform.css') }}">
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
            <script src="{{ asset('services/notification_service.js') }}" defer></script>
            <script src="{{ asset('services/datatables-service.js') }}" defer></script>
            <!-- Bibliothèques pour les exports DataTables -->
            <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
            <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
            <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
            <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.print.min.js"></script>
        {% endblock %}
    </head>
    <body>
        {% block site_header %}
            <input class="public-toggle" type="checkbox" id="public-menu" />

            <header class="public-header">
                <div class="container public-topbar">
                    <a class="public-brand" href="{{ path('accueil') }}">OCEA.td</a>
                    <div class="public-topbar-actions">
                        <button 
                            class="theme-toggle" 
                            data-controller="theme" 
                            data-action="click->theme#toggle"
                            data-theme-target="toggle"
                            type="button"
                            aria-label="Changer le thème"
                            title="Thème clair (cliquer pour thème sombre)"
                        >
                            <span class="icon-sun">☀️</span>
                            <span class="icon-moon">🌙</span>
                        </button>
                        <label class="public-action" for="public-menu" aria-label="Ouvrir le menu">☰</label>
                    </div>
                </div>

                <div class="container public-search">
                    <form class="public-search-form" action="{{ path('evenement.index') }}" method="get">
                        <input class="public-search-input" type="search" name="q" placeholder="Rechercher un événement…" autocomplete="off" />
                    </form>
                </div>

                <div class="container public-drawer" aria-label="Menu">
                    {% if app.user %}
                        <div class="public-drawer-content">
                            <span class="public-drawer-welcome">
                                Bonjour {{ app.user.prenom|default(app.user.email) }}
                            </span>
                            <div class="public-drawer-actions">
                                <a class="public-drawer-link" href="{{ path('portefeuille.index') }}">Mon compte</a>
                                {% if is_granted('ROLE_ORGANISATEUR') %}
                                    <a class="public-drawer-link" href="{{ path('validation.index') }}">🎫 Validation</a>
                                {% endif %}
                                <a class="public-drawer-link" href="{{ path('auth.logout') }}">Déconnexion</a>
                            </div>
                        </div>
                    {% endif %}
                </div>
            </header>

            <nav class="public-bottom-nav" aria-label="Navigation principale">
                <a class="public-tab" href="{{ path('accueil') }}">
                    <span class="public-tab-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M3 11.5L12 4l9 7.5" />
                            <path d="M5 10.5V20h14v-9.5" />
                            <path d="M10 20v-6h4v6" />
                        </svg>
                    </span>
                    <span class="public-tab-label">Accueil</span>
                </a>
                <a class="public-tab" href="{{ path('evenement.index') }}">
                    <span class="public-tab-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M3 7h18" />
                            <path d="M6 7V5a2 2 0 0 1 2-2h1" />
                            <path d="M18 7V5a2 2 0 0 0-2-2h-1" />
                            <rect x="3" y="7" width="18" height="14" rx="2" />
                            <path d="M7 11h4" />
                            <path d="M7 15h6" />
                        </svg>
                    </span>
                    <span class="public-tab-label">Événements</span>
                </a>
                <a class="public-tab" href="{{ path('panier.index') }}">
                    <span class="public-tab-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M6 7h15l-2 10H8L6 7z" />
                            <path d="M6 7l-2 0" />
                            <circle cx="9" cy="20" r="1" />
                            <circle cx="18" cy="20" r="1" />
                        </svg>
                    </span>
                    <span class="public-tab-label">Panier</span>
                </a>
                <a class="public-tab" href="{{ path('portefeuille.index') }}">
                    <span class="public-tab-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M4 7h15a1 1 0 0 1 1 1v10a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V7z" />
                            <path d="M20 10h-5a2 2 0 0 0 0 4h5" />
                            <path d="M7 7V6a2 2 0 0 1 2-2h10" />
                        </svg>
                    </span>
                    <span class="public-tab-label">Portefeuille</span>
                </a>
                {% if not app.user %}
                <a class="public-tab" href="{{ path('auth.login') }}">
                    <span class="public-tab-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M20 21a8 8 0 0 0-16 0" />
                            <circle cx="12" cy="8" r="4" />
                        </svg>
                    </span>
                    <span class="public-tab-label">Compte</span>
                </a>
            {% else %}
                <a class="public-tab" href="{{ path('portefeuille.index') }}">
                    <span class="public-tab-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M20 21a8 8 0 0 0-16 0" />
                            <circle cx="12" cy="8" r="4" />
                        </svg>
                    </span>
                    <span class="public-tab-label">Mon compte</span>
                </a>
            {% endif %}
            </nav>
        {% endblock %}

        {% block site_main %}
            <main class="site-main">
                <div class="container">
                    {% include 'partials/flashes.html.twig' %}
                    {% block body %}{% endblock %}
                </div>
            </main>

            <footer class="site-footer">
                <div class="container footer-inner">
                    <div class="muted">Prototype Frontend Twig</div>
                    <div class="muted">OCEA.td</div>
                </div>
            </footer>
        {% endblock %}
    </body>
    
    <!-- Conteneur pour les notifications -->
    <div id="notifications-container" 
         data-controller="notification" 
         data-notification-target="container">
    </div>
</html>
