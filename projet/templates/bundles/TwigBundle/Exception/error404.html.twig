{% extends 'base.html.twig' %}

{% block title %}Page non trouvée - TalChif{% endblock %}

{% block body %}
<div class="grid">
    <section class="card">
        <h1 class="page-title">Page non trouvée</h1>
        <div class="alert alert-error">
            <h2>Erreur 404</h2>
            <p>La page que vous recherchez n'existe pas ou a été déplacée.</p>
            
            <div class="error-details">
                <h3>Que faire ?</h3>
                <ul>
                    <li><strong>Vérifiez l'URL</strong> : Assurez-vous que l'adresse est correcte</li>
                    <li><strong>Retournez à l'accueil</strong> : Naviguez depuis la page principale</li>
                    <li><strong>Recherchez un événement</strong> : Utilisez la page des événements</li>
                </ul>
            </div>
        </div>
        
        <div class="card-actions">
            <a href="{{ path('accueil') }}" class="btn btn-primary">Retour à l'accueil</a>
            <a href="{{ path('evenement.index') }}" class="btn">Voir les événements</a>
        </div>
    </section>
</div>

<style>
.error-details {
    background: color-mix(in srgb, var(--couleur-surface) 90%, var(--couleur-fond) 10%);
    border: 1px solid var(--couleur-bordure);
    border-radius: 8px;
    padding: 20px;
    margin: 20px 0;
}

.error-details h3 {
    color: var(--couleur-texte);
    margin-bottom: 15px;
}

.error-details ul {
    margin: 0;
    padding-left: 20px;
}

.error-details li {
    margin-bottom: 10px;
    line-height: 1.5;
    color: var(--couleur-texte-secondaire);
}
</style>
{% endblock %}
