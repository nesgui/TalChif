{% extends 'base.html.twig' %}

{% block title %}Billets - {{ evenement.nom }}{% endblock %}

{% block body %}
<div class="event-billets-container">
    <!-- Header Section -->
    <header class="event-header">
        <div class="event-hero">
            <div class="event-visual">
                <img class="event-banner" src="{{ evenement.affichePrincipale ?: '/images/evenements/default.svg' }}" 
                     alt="{{ evenement.nom }}" />
                <div class="event-overlay">
                    <div class="event-info">
                        <h1 class="event-title">{{ evenement.nom }}</h1>
                        <div class="event-meta">
                            <span class="meta-item">
                                📅 {{ evenement.dateEvenement|date('d/m/Y H:i') }}
                            </span>
                            <span class="meta-item">
                                📍 {{ evenement.lieu }}, {{ evenement.ville }}
                            </span>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="stats-dashboard">
                <div class="stat-card primary">
                    <div class="stat-icon">🎫</div>
                    <div class="stat-content">
                        <span class="stat-number">{{ totalBilletsVendus }}</span>
                        <span class="stat-label">Billets vendus</span>
                    </div>
                </div>
                <div class="stat-card success">
                    <div class="stat-icon">💰</div>
                    <div class="stat-content">
                        <span class="stat-number">{{ totalRevenus|number_format(0, '.', ' ') }}</span>
                        <span class="stat-label">Revenus totaux</span>
                    </div>
                </div>
                <div class="stat-card info">
                    <div class="stat-icon">📊</div>
                    <div class="stat-content">
                        <span class="stat-number">{{ typesDisponibles|length }}</span>
                        <span class="stat-label">Types de billets</span>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- Main Content -->
    <main class="event-content">
        <!-- Tickets Section -->
        <section class="tickets-section">
            <div class="section-header">
                <h2 class="section-title">
                    <span class="title-icon">🎫</span>
                    Types de billets disponibles
                </h2>
                <p class="section-subtitle">Choisissez le type de billet qui vous convient</p>
            </div>
            
            <div class="tickets-grid">
                {% for type, info in typesDisponibles %}
                    <div class="ticket-card {{ info.statut == 'Épuisé' ? 'sold-out' : info.statut == 'Limité' ? 'limited' : 'available' }}">
                        <div class="ticket-header">
                            <div class="ticket-type-badge">
                                <span class="badge-icon">{{ type == 'Simple' ? '🎫' : '⭐' }}</span>
                                <h3 class="ticket-type">{{ type }}</h3>
                            </div>
                            <div class="ticket-price">
                                <span class="price-amount">{{ info.prix|number_format(0, '.', ' ') }}</span>
                                <span class="price-currency">XAF</span>
                            </div>
                        </div>
                        
                        <div class="ticket-body">
                            <div class="availability-section">
                                <div class="availability-header">
                                    <span class="availability-label">Places disponibles</span>
                                    <span class="status-badge status-{{ info.statut|lower }}">{{ info.statut }}</span>
                                </div>
                                
                                <div class="progress-container">
                                    <div class="progress-bar">
                                        <div class="progress-fill" style="width: {{ (info.vendues / info.places * 100)|round }}%"></div>
                                    </div>
                                    <div class="progress-text">
                                        <span class="available-count">{{ info.disponibles }}</span>
                                        <span class="separator">/</span>
                                        <span class="total-count">{{ info.places }}</span>
                                    </div>
                                </div>
                            </div>
                            
                            {% if info.statut != 'Épuisé' %}
                                <div class="ticket-actions">
                                    <form method="post" action="{{ path('event.billets.acheter', {slug: evenement.slug, id: evenement.id}) }}" class="action-form">
                                        <input type="hidden" name="type" value="{{ type }}">
                                        <div class="quantity-control">
                                            <label class="quantity-label">Quantité</label>
                                            <select name="quantite" class="quantity-select">
                                                {% for i in 1..min(5, info.disponibles) %}
                                                    <option value="{{ i }}">{{ i }}</option>
                                                {% endfor %}
                                            </select>
                                        </div>
                                        <button type="submit" class="btn btn-primary btn-block">
                                            Acheter
                                        </button>
                                    </form>
                                    
                                    <form method="post" action="{{ path('event.billets.reserver', {slug: evenement.slug, id: evenement.id}) }}" class="action-form">
                                        <input type="hidden" name="type" value="{{ type }}">
                                        <div class="quantity-control">
                                            <label class="quantity-label">Quantité</label>
                                            <select name="quantite" class="quantity-select">
                                                {% for i in 1..min(5, info.disponibles) %}
                                                    <option value="{{ i }}">{{ i }}</option>
                                                {% endfor %}
                                            </select>
                                        </div>
                                        <button type="submit" class="btn btn-secondary btn-block">
                                            Réserver
                                        </button>
                                    </form>
                                </div>
                            {% else %}
                                <div class="ticket-actions">
                                    <button class="btn btn-disabled btn-block" disabled>
                                        Épuisé
                                    </button>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                {% endfor %}
            </div>
        </section>

        <!-- History Section -->
        <section class="history-section">
            <div class="section-header">
                <h2 class="section-title">
                    <span class="title-icon">📊</span>
                    Historique des réservations
                </h2>
                <p class="section-subtitle">Dernières réservations et validations</p>
            </div>
            
            <div class="history-container">
                <div class="history-table-wrapper">
                    <table class="history-table" id="reservations-table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Client</th>
                                <th>Type</th>
                                <th>Quantité</th>
                                <th>Total</th>
                                <th>Date</th>
                                <th>Statut</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for reservation in historique %}
                                <tr class="history-row">
                                    <td><code class="reservation-id">{{ reservation.id }}</code></td>
                                    <td>
                                        <div class="client-info">
                                            <span class="client-email">{{ reservation.client }}</span>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="type-badge type-{{ reservation.type == 'Simple' ? 'simple' : 'vip' }}">{{ reservation.type }}</span>
                                    </td>
                                    <td class="quantity-cell">{{ reservation.quantite }}</td>
                                    <td class="price-cell">
                                        <strong>{{ reservation.total|number_format(0, '.', ' ') }} XAF</strong>
                                    </td>
                                    <td class="date-cell">{{ reservation.date|date('d/m/Y H:i') }}</td>
                                    <td>
                                        <span class="status-badge status-{{ reservation.statut|lower }}">
                                            {{ reservation.statut }}
                                        </span>
                                    </td>
                                    <td>
                                        <div class="action-buttons">
                                            <button class="btn btn-sm btn-outline">Voir</button>
                                            {% if reservation.statut == 'En attente' %}
                                                <button class="btn btn-sm btn-primary">Valider</button>
                                            {% endif %}
                                            <button class="btn btn-sm btn-danger">Annuler</button>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </section>
    </main>
</div>

<style>
/* Container */
.event-billets-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 2rem;
}

/* Header */
.event-header {
    margin-bottom: 3rem;
}

.event-hero {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
}

.event-visual {
    position: relative;
    border-radius: var(--rayon-lg);
    overflow: hidden;
    box-shadow: var(--ombre-xl);
}

.event-banner {
    width: 100%;
    height: 300px;
    object-fit: cover;
}

.event-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.8), transparent);
    padding: 2rem;
    color: var(--couleur-texte-inverse);
}

.event-title {
    font-size: 2.5rem;
    font-weight: 700;
    margin: 0 0 1rem 0;
    text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
}

.event-meta {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
}

.meta-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.1rem;
}

/* Stats Dashboard */
.stats-dashboard {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
}

.stat-card {
    background: var(--couleur-surface);
    border: 1px solid var(--couleur-bordure);
    border-radius: var(--rayon);
    padding: 1.5rem;
    box-shadow: var(--ombre-md);
    display: flex;
    align-items: center;
    gap: 1rem;
    transition: transform var(--transition-normale), box-shadow var(--transition-normale);
}

.stat-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--ombre-lg);
}

.stat-card.primary {
    background: linear-gradient(135deg, var(--couleur-primaire), var(--couleur-primaire-fonce));
    color: var(--couleur-texte-inverse);
    border-color: var(--couleur-primaire);
}

.stat-card.success {
    background: linear-gradient(135deg, var(--couleur-success), #059669);
    color: var(--couleur-texte-inverse);
    border-color: var(--couleur-success);
}

.stat-card.info {
    background: linear-gradient(135deg, var(--couleur-info), #0891b2);
    color: var(--couleur-texte-inverse);
    border-color: var(--couleur-info);
}

.stat-icon {
    font-size: 2rem;
    opacity: 0.8;
}

.stat-content {
    flex: 1;
}

.stat-number {
    display: block;
    font-size: 2rem;
    font-weight: 700;
    line-height: 1;
}

.stat-label {
    font-size: 0.875rem;
    opacity: 0.9;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

/* Main Content */
.event-content {
    display: grid;
    gap: 3rem;
}

/* Section Headers */
.section-header {
    text-align: center;
    margin-bottom: 2rem;
}

.section-title {
    font-size: 2rem;
    font-weight: 700;
    margin: 0 0 0.5rem 0;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    color: var(--couleur-texte);
}

.title-icon {
    font-size: 1.5rem;
}

.section-subtitle {
    color: var(--couleur-texte-secondaire);
    font-size: 1.1rem;
    margin: 0;
}

/* Tickets Grid */
.tickets-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
}

.ticket-card {
    background: var(--couleur-surface);
    border: 1px solid var(--couleur-bordure);
    border-radius: var(--rayon-lg);
    overflow: hidden;
    box-shadow: var(--ombre-md);
    transition: transform var(--transition-normale), box-shadow var(--transition-normale);
}

.ticket-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--ombre-lg);
}

.ticket-card.available {
    border-top: 4px solid var(--couleur-success);
}

.ticket-card.limited {
    border-top: 4px solid var(--couleur-warning);
}

.ticket-card.sold-out {
    border-top: 4px solid var(--couleur-error);
    opacity: 0.7;
}

.ticket-header {
    padding: 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid var(--couleur-bordure-subtile);
}

.ticket-type-badge {
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.badge-icon {
    font-size: 1.5rem;
}

.ticket-type {
    font-size: 1.25rem;
    font-weight: 600;
    margin: 0;
    color: var(--couleur-texte);
}

.ticket-price {
    text-align: right;
}

.price-amount {
    display: block;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--couleur-primaire);
}

.price-currency {
    font-size: 0.875rem;
    color: var(--couleur-texte-secondaire);
}

.ticket-body {
    padding: 1.5rem;
}

.availability-section {
    margin-bottom: 1.5rem;
}

.availability-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
}

.availability-label {
    font-size: 0.875rem;
    color: var(--couleur-texte-secondaire);
    font-weight: 500;
}

.status-badge {
    padding: 0.25rem 0.75rem;
    border-radius: var(--rayon);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
}

.status-available {
    background: var(--couleur-success);
    color: var(--couleur-texte-inverse);
}

.status-limited {
    background: var(--couleur-warning);
    color: var(--couleur-texte-inverse);
}

.status-epuise {
    background: var(--couleur-error);
    color: var(--couleur-texte-inverse);
}

.progress-container {
    margin-bottom: 0.5rem;
}

.progress-bar {
    width: 100%;
    height: 8px;
    background: var(--couleur-bordure-subtile);
    border-radius: var(--rayon-sm);
    overflow: hidden;
    margin-bottom: 0.5rem;
}

.progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--couleur-primaire), var(--couleur-primaire-fonce));
    border-radius: var(--rayon-sm);
    transition: width var(--transition-normale);
}

.progress-text {
    display: flex;
    justify-content: space-between;
    font-size: 0.875rem;
    color: var(--couleur-texte);
}

.available-count {
    font-weight: 600;
    color: var(--couleur-primaire);
}

.separator {
    color: var(--couleur-texte-secondaire);
}

.ticket-actions {
    display: flex;
    flex-direction: column;
    gap: 1rem;
}

.action-form {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
}

.quantity-control {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
}

.quantity-label {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--couleur-texte);
}

.quantity-select {
    padding: 0.5rem;
    border: 1px solid var(--couleur-bordure);
    border-radius: var(--rayon);
    font-size: 0.875rem;
    background: var(--couleur-fond);
    color: var(--couleur-texte);
}

/* History Section */
.history-container {
    background: var(--couleur-surface);
    border: 1px solid var(--couleur-bordure);
    border-radius: var(--rayon-lg);
    padding: 2rem;
    box-shadow: var(--ombre-md);
}

.history-table-wrapper {
    overflow-x: auto;
}

.history-table {
    width: 100%;
    border-collapse: collapse;
}

.history-table th {
    background: var(--couleur-surface-elevee);
    padding: 1rem;
    text-align: left;
    font-weight: 600;
    color: var(--couleur-texte);
    border-bottom: 1px solid var(--couleur-bordure);
}

.history-table td {
    padding: 1rem;
    border-bottom: 1px solid var(--couleur-bordure-subtile);
}

.history-row:hover {
    background: var(--couleur-surface-elevee);
}

.reservation-id {
    font-family: monospace;
    font-size: 0.875rem;
    background: var(--couleur-bordure-subtile);
    padding: 0.25rem 0.5rem;
    border-radius: var(--rayon-sm);
}

.client-info {
    display: flex;
    align-items: center;
}

.client-email {
    font-size: 0.875rem;
    color: var(--couleur-texte);
}

.type-badge {
    padding: 0.25rem 0.75rem;
    border-radius: var(--rayon);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
}

.type-simple {
    background: var(--couleur-primaire-clair);
    color: var(--couleur-primaire-fonce);
}

.type-vip {
    background: var(--couleur-warning);
    color: #92400e;
}

.quantity-cell {
    text-align: center;
    font-weight: 600;
}

.price-cell {
    text-align: right;
}

.date-cell {
    font-size: 0.875rem;
    color: var(--couleur-texte-secondaire);
}

.action-buttons {
    display: flex;
    gap: 0.5rem;
}

.btn-sm {
    padding: 8px 16px;
    font-size: 0.75rem;
    min-height: 36px;
}

/* Responsive */
@media (max-width: 768px) {
    .event-billets-container {
        padding: 1rem;
    }
    
    .event-title {
        font-size: 1.75rem;
    }
    
    .stats-dashboard {
        grid-template-columns: 1fr;
    }
    
    .tickets-grid {
        grid-template-columns: 1fr;
    }
    
    .history-table-wrapper {
        font-size: 0.875rem;
    }
    
    .action-buttons {
        flex-direction: column;
    }
    
    .btn-sm {
        width: 100%;
    }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Animate progress bars
    const progressFills = document.querySelectorAll('.progress-fill');
    progressFills.forEach(fill => {
        const width = fill.style.width;
        fill.style.width = '0%';
        setTimeout(() => {
            fill.style.width = width;
        }, 100);
    });
    
    // Animate stats
    const statNumbers = document.querySelectorAll('.stat-number');
    statNumbers.forEach(stat => {
        const finalValue = stat.textContent;
        const isNumber = /^\d/.test(finalValue);
        
        if (isNumber) {
            const target = parseInt(finalValue.replace(/\D/g, ''));
            let current = 0;
            const increment = target / 50;
            
            const timer = setInterval(() => {
                current += increment;
                if (current >= target) {
                    stat.textContent = finalValue;
                    clearInterval(timer);
                } else {
                    stat.textContent = Math.floor(current).toLocaleString();
                }
            }, 20);
        }
    });
    
    // Initialize DataTables for performance
    if (typeof DataTableOS !== 'undefined') {
        DataTableOS.init('#reservations-table', {
            order: [[6, 'desc']], // Sort by date column (index 6)
            pageLength: 10,
            lengthMenu: [[5, 10, 25, 50], [5, 10, 25, 50]],
            language: {
                search: "Rechercher...",
                lengthMenu: "Afficher _MENU_ entrées",
                info: "Affichage de _START_ à _END_ sur _TOTAL_ entrées",
                paginate: {
                    first: "Premier",
                    last: "Dernier",
                    next: "Suivant",
                    previous: "Précédent"
                }
            },
            columns: [
                { width: '120px', orderable: false },
                null,
                { width: '80px', orderable: false },
                { width: '80px', orderable: false },
                { width: '100px', orderable: false },
                { width: '150px' },
                { width: '100px', orderable: false },
                { width: '150px', orderable: false }
            ]
        });
    }
});
</script>
{% endblock %}
