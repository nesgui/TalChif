<script>
document.addEventListener('DOMContentLoaded', function() {
    console.log('Test page loaded');
    
    // Initialiser DataTables
    try {
        if (window.DataTableOS) {
            const table = window.DataTableOS.init('#test-table');
            if (table) {
                console.log('DataTables initialisé avec succès');
            } else {
                console.error('Échec de l\'initialisation de DataTables');
            }
        } else {
            console.error('DataTableOS n\'est pas disponible');
        }
    } catch (error) {
        console.error('Erreur lors de l\'initialisation de DataTables:', error);
    }
    
    // Diagnostic
    runDiagnostic();
});

function testNotification() {
    console.log('Test notification manuelle');
    if (window.NotificationService) {
        window.NotificationService.success('Test Manuel', 'Ceci est une notification de test générée manuellement');
    } else {
        alert('NotificationService non disponible');
    }
}

function testThemeToggle() {
    console.log('Test theme toggle');
    if (window.themeToggle && window.themeToggle.toggleTheme) {
        window.themeToggle.toggleTheme();
    } else {
        alert('ThemeToggle non disponible');
    }
}

function runDiagnostic() {
    const diagnostic = {
        'NotificationService': !!window.NotificationService,
        'ThemeToggle': !!(window.themeToggle || window.ThemeToggle),
        'DataTableOS': !!window.DataTableOS,
        'DataTables (CDN)': !!(window.DataTable || (window.$ && window.$.fn.dataTable)),
        'jQuery': !!(window.$),
        'Stimulus': !!(window.Stimulus),
        'Flash Messages': window.flashMessages ? window.flashMessages.length : 0
    };
    
    const diagnosticHtml = Object.entries(diagnostic)
        .map(([key, value]) => {
            const status = value === true ? '✅ OK' : value === false ? '❌ Manquant' : `ℹ️ ${value}`;
            const color = value === true ? 'var(--couleur-success)' : value === false ? 'var(--couleur-error)' : 'var(--couleur-info)';
            return `<div style="margin: 0.5rem 0; color: ${color};"><strong>${key}:</strong> ${status}</div>`;
        })
        .join('');
    
    document.getElementById('diagnostic-info').innerHTML = `
        <h3>État des Services JavaScript:</h3>
        ${diagnosticHtml}
        <div style="margin-top: 1rem;">
            <button onclick="runDiagnostic()" class="btn btn-sm btn-outline">🔄 Actualiser Diagnostic</button>
        </div>
    `;
    
    console.log('Diagnostic:', diagnostic);
}
</script>

