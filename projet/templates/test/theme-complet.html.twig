{% extends 'base.html.twig' %}

{% block title %}Test Complet Mode Sombre - TalChif{% endblock %}

{% block body %}
<div class="container" style="padding: 20px 0;">
    <h1>Test Complet du Mode Sombre</h1>
    <p>Cette page teste tous les composants avec le mode sombre.</p>
    
    <!-- Test navigation -->
    <section style="margin: 30px 0;">
        <h2>Navigation</h2>
        <div class="tickets-nav">
            <a href="#" class="nav-btn active">Actif</a>
            <a href="#" class="nav-btn">Normal</a>
            <a href="#" class="nav-btn">Normal</a>
        </div>
    </section>

    <!-- Test boutons -->
    <section style="margin: 30px 0;">
        <h2>Boutons</h2>
        <button class="btn btn-primary">Primaire</button>
        <button class="btn btn-secondary">Secondaire</button>
        <button class="btn btn-success">Succès</button>
        <button class="btn btn-danger">Danger</button>
        <button class="btn btn-outline">Outline</button>
        <button class="btn btn-ghost">Ghost</button>
    </section>

    <!-- Test pills -->
    <section style="margin: 30px 0;">
        <h2>Pills</h2>
        <span class="pill">Normal</span>
        <span class="pill pill-info">Info</span>
        <span class="pill pill-success">Succès</span>
        <span class="pill pill-warning">Warning</span>
        <span class="pill pill-danger">Danger</span>
    </section>

    <!-- Test cartes -->
    <section style="margin: 30px 0;">
        <h2>Cartes</h2>
        <div class="tickets-header">
            <div class="tickets-stats">
                <div class="stat-card">
                    <span class="stat-number">42</span>
                    <span class="stat-label">Total</span>
                </div>
                <div class="stat-card">
                    <span class="stat-number">12</span>
                    <span class="stat-label">Événements</span>
                </div>
                <div class="stat-card">
                    <span class="stat-number">5000</span>
                    <span class="stat-label">XAF</span>
                </div>
            </div>
        </div>
    </section>

    <!-- Test tableau -->
    <section style="margin: 30px 0;">
        <h2>Tableau</h2>
        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th>Colonne 1</th>
                        <th>Colonne 2</th>
                        <th>Colonne 3</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><span class="pill pill-info">VIP</span></td>
                        <td><code class="ticket-code-inline">ABC123</code></td>
                        <td>5000 XAF</td>
                        <td>
                            <span class="status-badge valid">Valide</span>
                            <a href="#" class="btn-link">Voir</a>
                        </td>
                    </tr>
                    <tr>
                        <td><span class="pill">SIMPLE</span></td>
                        <td><code class="ticket-code-inline">DEF456</code></td>
                        <td>2000 XAF</td>
                        <td>
                            <span class="status-badge used">Utilisé</span>
                            <a href="#" class="btn-link">Voir</a>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </section>

    <!-- Test formulaires -->
    <section style="margin: 30px 0;">
        <h2>Formulaires</h2>
        <div class="form-group">
            <label>Champ texte</label>
            <input type="text" class="form-control" placeholder="Entrez du texte...">
            <span class="form-help">Texte d'aide secondaire</span>
        </div>
        <div class="form-group">
            <label>
                <input type="checkbox" class="form-checkbox">
                Cochez cette case
            </label>
        </div>
    </section>

    <!-- Test titres -->
    <section style="margin: 30px 0;">
        <h2>Titres</h2>
        <h1>Titre H1</h1>
        <h2>Titre H2</h2>
        <h3>Titre H3</h3>
        <h4>Titre H4</h4>
        <h5>Titre H5</h5>
        <h6>Titre H6</h6>
        <p class="page-title">Page Title</p>
        <p class="section-title">Section Title</p>
    </section>

    <!-- Test texte -->
    <section style="margin: 30px 0;">
        <h2>Textes</h2>
        <p>Texte normal</p>
        <p class="text-muted">Texte muted/secondaire</p>
        <p class="muted">Texte muted (autre classe)</p>
    </section>

    <!-- Test liens -->
    <section style="margin: 30px 0;">
        <h2>Liens</h2>
        <a href="#">Lien normal</a> |
        <a href="#" class="pagination-link">Lien pagination</a> |
        <span class="pagination-info">Info pagination</span>
    </section>

    <!-- Test état vide -->
    <section style="margin: 30px 0;">
        <h2>État vide</h2>
        <div class="empty-tickets">
            <div class="empty-icon">📋</div>
            <h3>Aucun élément</h3>
            <p>Texte explicatif secondaire</p>
            <div class="card-actions">
                <button class="btn btn-primary">Action primaire</button>
                <button class="btn">Action secondaire</button>
            </div>
        </div>
    </section>

    <!-- Instructions -->
    <section style="margin: 30px 0;">
        <h2>Instructions de test</h2>
        <ol>
            <li>Cliquez sur le bouton du thème (☀️/🌙) en haut à droite</li>
            <li>Vérifiez que TOUS les éléments ci-dessus restent lisibles</li>
            <li>Testez les interactions : survol, clic, focus</li>
            <li>Vérifiez les contrastes WCAG</li>
            <li>Testez la navigation en bas de page</li>
        </ol>
        <p><strong>✅ Si tout est lisible, le mode sombre est parfaitement fonctionnel !</strong></p>
    </section>
</div>
{% endblock %}
