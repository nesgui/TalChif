{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block body %}
<div class="grid">
    <section class="card">
        <h1 class="page-title">Connexion</h1>
        
        {% if app.user %}
            <div class="alert alert-success">
                <h2>✅ Connecté !</h2>
                <p>Utilisateur : {{ app.user.email }}</p>
                <p>Rôle : {{ app.user.role }}</p>
                <p>ID : {{ app.user.id }}</p>
            </div>
            
            <div class="card-actions">
                <a href="{{ path('portefeuille.index') }}" class="btn btn-primary">Aller au portefeuille</a>
                <a href="{{ path('auth.logout') }}" class="btn btn-danger">Se déconnecter</a>
            </div>
        {% else %}
            <div class="alert alert-error">
                <h2>❌ Non connecté</h2>
                <p>Vous n'êtes pas connecté.</p>
            </div>
            
            <div class="card-actions">
                <a href="{{ path('auth.login') }}" class="btn btn-primary">Se connecter</a>
            </div>
        {% endif %}
    </section>
</div>
{% endblock %}
