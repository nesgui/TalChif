{% extends 'layout/dashboard.html.twig' %}

{% set section = 'organisateur' %}

{% block title %}Test Theme Persistence{% endblock %}

{% block dashboard_title %}Test Theme Persistence{% endblock %}

{% block dashboard_content %}
<div class="dashboard-container">
    <div class="dashboard-header">
        <h1 class="page-title">Test de Persistance du Thème</h1>
        <p class="page-subtitle">Vérification que le thème s'applique correctement dans le layout dashboard</p>
    </div>

    <div class="card">
        <h2 class="card-title">Instructions de Test</h2>
        <div class="card-content">
            <ol style="line-height: 1.8;">
                <li><strong>Étape 1:</strong> Allez sur la <a href="{{ path('accueil') }}" style="color: var(--couleur-primaire);">page d'accueil</a></li>
                <li><strong>Étape 2:</strong> Basculez le thème en utilisant le bouton en haut à droite</li>
                <li><strong>Étape 3:</strong> Revenez sur cette page pour vérifier que le thème est persisté</li>
                <li><strong>Étape 4:</strong> Le bouton thème dans cette barre supérieure devrait aussi fonctionner</li>
            </ol>
        </div>
    </div>

    <div class="stats-grid">
        <div class="stat-card primary">
            <div class="stat-header">
                <h3>🎨 Thème Actuel</h3>
            </div>
            <div class="stat-content">
                <div class="big-number">
                    <span class="number" id="current-theme">Détection...</span>
                    <span class="label">vérifié via JavaScript</span>
                </div>
            </div>
        </div>

        <div class="stat-card success">
            <div class="stat-header">
                <h3>💾 LocalStorage</h3>
            </div>
            <div class="stat-content">
                <div class="big-number">
                    <span class="number" id="storage-status">Vérification...</span>
                    <span class="label">état du stockage</span>
                </div>
            </div>
        </div>

        <div class="stat-card info">
            <div class="stat-header">
                <h3>🔄 Service Status</h3>
            </div>
            <div class="stat-content">
                <div class="big-number">
                    <span class="number" id="service-status">Vérification...</span>
                    <span class="label">ThemeService chargé</span>
                </div>
            </div>
        </div>
    </div>

    <div class="section-header">
        <h2 class="section-title">Actions de Test</h2>
    </div>

    <div class="actions-grid">
        <button onclick="testThemeToggle()" class="btn btn-primary">
            🔄 Forcer le Basculement du Thème
        </button>
        <button onclick="checkThemeStatus()" class="btn btn-outline">
            🔍 Vérifier l'État du Thème
        </button>
        <a href="{{ path('accueil') }}" class="btn btn-outline">
            🏠 Retour à l'Accueil
        </a>
        <a href="{{ path('organisateur.dashboard') }}" class="btn btn-outline">
            📊 Vrai Dashboard Organisateur
        </a>
    </div>
</div>

<script>
// Test script for theme persistence
document.addEventListener('DOMContentLoaded', function() {
    console.log('Dashboard theme test page loaded');
    checkThemeStatus();
    
    // Check theme every 2 seconds for debugging
    setInterval(checkThemeStatus, 2000);
});

function checkThemeStatus() {
    // Check current theme
    const currentTheme = document.documentElement.getAttribute('data-theme') || 'light';
    document.getElementById('current-theme').textContent = currentTheme === 'dark' ? 'SOMBRE' : 'CLAIR';
    
    // Check localStorage
    const storedTheme = localStorage.getItem('osea-theme') || localStorage.getItem('theme') || 'non défini';
    document.getElementById('storage-status').textContent = storedTheme.substring(0, 8).toUpperCase();
    
    // Check if theme service is loaded
    const serviceLoaded = !!(window.ThemeToggle || window.themeToggle || window.themeService);
    document.getElementById('service-status').textContent = serviceLoaded ? 'OK' : 'ERREUR';
    
    console.log('Theme status check:', {
        current: currentTheme,
        stored: storedTheme,
        service: serviceLoaded
    });
}

function testThemeToggle() {
    console.log('Manual theme toggle triggered');
    
    // Try multiple methods to toggle theme
    if (window.themeToggle && window.themeToggle.toggleTheme) {
        window.themeToggle.toggleTheme();
    } else if (window.ThemeToggle) {
        const toggle = new window.ThemeToggle();
        toggle.toggleTheme();
    } else {
        // Fallback: manual toggle
        const currentTheme = document.documentElement.getAttribute('data-theme') || 'light';
        const newTheme = currentTheme === 'light' ? 'dark' : 'light';
        
        if (newTheme === 'dark') {
            document.documentElement.setAttribute('data-theme', 'dark');
            document.documentElement.style.colorScheme = 'dark';
        } else {
            document.documentElement.removeAttribute('data-theme');
            document.documentElement.style.colorScheme = 'light';
        }
        
        localStorage.setItem('osea-theme', newTheme);
        localStorage.setItem('theme', newTheme);
        
        console.log('Manual toggle completed:', newTheme);
    }
    
    // Update status after toggle
    setTimeout(checkThemeStatus, 100);
}
</script>

<style>
.dashboard-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: var(--espace-lg);
}

.card {
    background: var(--couleur-surface);
    border-radius: var(--rayon);
    padding: var(--espace-lg);
    border: 1px solid var(--couleur-bordure);
    box-shadow: var(--ombre-md);
    margin-bottom: var(--espace-xl);
}

.card-title {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--couleur-texte);
    margin: 0 0 var(--espace-md) 0;
}

.card-content {
    color: var(--couleur-texte-secondaire);
    line-height: 1.6;
}

.actions-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: var(--espace-md);
}

.stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: var(--espace-lg);
    margin-bottom: var(--espace-xl);
}

.stat-card {
    background: var(--couleur-surface);
    border-radius: var(--rayon);
    padding: var(--espace-lg);
    border: 1px solid var(--couleur-bordure);
    box-shadow: var(--ombre-md);
}

.stat-card.primary {
    background: var(--couleur-primaire);
    color: var(--couleur-texte-inverse);
}

.stat-card.success {
    background: var(--couleur-success);
    color: var(--couleur-texte-inverse);
}

.stat-card.info {
    background: var(--couleur-info);
    color: var(--couleur-texte-inverse);
}

.stat-header h3 {
    font-size: 1.125rem;
    font-weight: 600;
    margin: 0 0 var(--espace-md) 0;
}

.stat-card.primary .stat-header h3,
.stat-card.success .stat-header h3,
.stat-card.info .stat-header h3 {
    color: var(--couleur-texte-inverse);
}

.big-number {
    text-align: center;
}

.big-number .number {
    display: block;
    font-size: 2rem;
    font-weight: 800;
    line-height: 1;
}

.big-number .label {
    display: block;
    font-size: 0.875rem;
    opacity: 0.9;
    margin-top: var(--espace-xs);
}

.btn {
    padding: var(--espace-sm) var(--espace-lg);
    border: none;
    border-radius: var(--rayon-sm);
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
    transition: all var(--transition-rapide);
    white-space: nowrap;
    user-select: none;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--espace-sm);
}

.btn-primary {
    background: var(--couleur-primaire);
    color: var(--couleur-texte-inverse);
}

.btn-primary:hover {
    background: var(--couleur-primaire-hover);
    transform: translateY(-1px);
    box-shadow: var(--ombre-md);
}

.btn-outline {
    background: transparent;
    color: var(--couleur-texte-secondaire);
    border: 1px solid var(--couleur-bordure);
}

.btn-outline:hover {
    background: var(--couleur-surface);
    border-color: var(--couleur-primaire);
    color: var(--couleur-primaire);
    transform: translateY(-1px);
    box-shadow: var(--ombre-sm);
}
</style>
{% endblock %}
