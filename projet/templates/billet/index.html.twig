{% extends 'base.html.twig' %}

{% block title %}Mes Billets{% endblock %}

{% block body %}
<section class="tickets-shell">
    <header class="tickets-header">
        <h1 class="page-title">Mes billets</h1>
        <p class="page-subtitle">Retrouvez tous vos billets au meme endroit.</p>
        <div class="tickets-stats-inline">
            <span class="tickets-stat"><strong>{{ totalBillets }}</strong> billet(s)</span>
            <span class="tickets-stat"><strong>{{ billetsByEvenement|length }}</strong> evenement(s)</span>
        </div>
    </header>

    <div class="tickets-nav">
        <a href="{{ path('billet.index') }}" class="ticket-filter-btn active">Tous</a>
        <a href="{{ path('billet.avenir') }}" class="ticket-filter-btn">À venir</a>
        <a href="{{ path('billet.passes') }}" class="ticket-filter-btn">Passés</a>
        <a href="{{ path('achat.commandes') }}" class="ticket-filter-btn">Mes commandes</a>
    </div>

    {% if billetsByEvenement|length > 0 %}
        <div class="tickets-list">
            {% for evenementId, data in billetsByEvenement %}
                <article class="ticket-event">
                    <div class="event-top">
                        <img class="event-image" src="{{ data.evenement.affichePrincipale ?: '/images/evenements/default.svg' }}" alt="Affiche {{ data.evenement.nom }}" loading="lazy">
                        <div class="event-main">
                            <h3 class="event-name">{{ data.evenement.nom }}</h3>
                            <p class="event-meta">{{ data.evenement.dateEvenement|date('d/m/Y H:i') }} • {{ data.evenement.ville }}</p>
                        </div>
                        <strong class="event-total">{{ data.total|number_format(0, '.', ' ') }} XAF</strong>
                    </div>
                    <div class="codes">
                        {% for billet in data.billets %}
                            <a class="code-pill" href="{{ path('achat.billet', {id: billet.id}) }}" target="_blank" rel="noopener">
                                {{ billet.type|upper }} • Voir billet
                            </a>
                        {% endfor %}
                    </div>
                </article>
            {% endfor %}
        </div>
    {% else %}
        <section class="card empty">
            <h2>Vous n'avez pas encore de billets</h2>
            <p>Achetez un billet et retrouvez-le ici.</p>
            <div class="card-actions">
                <a href="{{ path('evenement.index') }}" class="btn btn-primary">Explorer les événements</a>
                <a href="{{ path('panier.index') }}" class="btn">Mon panier</a>
            </div>
        </section>
    {% endif %}
</section>

<style>
.tickets-shell { max-width: 980px; margin: 0 auto; display: grid; gap: 1rem; }
.tickets-stats-inline { display: flex; gap: .5rem; flex-wrap: wrap; margin-top: .25rem; }
.tickets-stat { display: inline-flex; gap: .3rem; align-items: center; padding: .25rem .55rem; border-radius: 999px; border: 1px solid var(--couleur-bordure); background: var(--couleur-fond); font-size: .82rem; }
.tickets-stat strong { display: inline; font-size: .9rem; line-height: 1; }
.tickets-nav { display: flex; gap: .45rem; flex-wrap: wrap; align-items: center; }
a.ticket-filter-btn { display: inline-flex; align-items: center; justify-content: center; padding: .38rem .72rem; border: 1px solid var(--couleur-bordure); border-radius: 999px; text-decoration: none; color: var(--couleur-texte); background: var(--couleur-surface); font-size: .82rem; font-weight: 600; line-height: 1.2; min-height: auto; }
a.ticket-filter-btn:hover { border-color: var(--couleur-secondaire); background: color-mix(in srgb, var(--couleur-surface) 90%, var(--couleur-secondaire) 10%); }
a.ticket-filter-btn.active { background: var(--couleur-primaire); color: var(--couleur-texte-inverse); border-color: var(--couleur-primaire); }
html[data-theme="dark"] a.ticket-filter-btn { color: var(--couleur-texte); background: var(--couleur-surface-elevee); border-color: var(--couleur-bordure); }
html[data-theme="dark"] a.ticket-filter-btn:hover { color: var(--couleur-texte); background: color-mix(in srgb, var(--couleur-surface-elevee) 82%, var(--couleur-texte) 18%); border-color: var(--couleur-texte-secondaire); }
html[data-theme="dark"] a.ticket-filter-btn.active { background: var(--palette-light-blue); color: var(--palette-dark-blue); border-color: var(--palette-light-blue); }
html[data-theme="dark"] .tickets-nav .ticket-filter-btn,
html[data-theme="dark"] .tickets-nav .ticket-filter-btn:hover,
html[data-theme="dark"] .tickets-nav .ticket-filter-btn.active {
    color: #ffffff !important;
}
.tickets-list { display: grid; gap: .9rem; }
.ticket-event { border: 1px solid var(--couleur-bordure); border-radius: var(--rayon); background: var(--couleur-surface); padding: .9rem; }
.event-top { display: grid; grid-template-columns: 96px minmax(0, 1fr) auto; gap: .85rem; align-items: center; }
.event-image { width: 96px; height: 72px; object-fit: cover; border-radius: var(--rayon); }
.event-main { min-width: 0; }
.event-name { margin: 0; font-size: 1rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.event-meta { margin: .22rem 0 0; color: var(--couleur-texte-secondaire); font-size: .86rem; }
.event-total { white-space: nowrap; font-size: .95rem; }
.codes { margin-top: .72rem; display: flex; flex-wrap: wrap; gap: .45rem; }
.code-pill { text-decoration: none; border: 1px solid var(--couleur-bordure); border-radius: 999px; padding: .4rem .68rem; color: var(--couleur-texte); background: var(--couleur-fond); font-size: .84rem; transition: border-color var(--transition-rapide), color var(--transition-rapide); }
.code-pill:hover { border-color: var(--couleur-primaire); color: var(--couleur-primaire); }
/* En thème sombre, --couleur-primaire (#1D3557) est trop proche de --couleur-fond (#0d1321) :
   le texte devenait invisible au survol. On force une couleur lisible. */
html[data-theme="dark"] .code-pill { color: var(--couleur-texte); background: var(--couleur-surface); }
html[data-theme="dark"] .code-pill:hover { border-color: var(--couleur-secondaire); color: var(--couleur-texte); background: color-mix(in srgb, var(--couleur-surface) 80%, var(--couleur-secondaire) 20%); }
html[data-theme="dark"] .code-pill:focus-visible { outline: 2px solid var(--couleur-secondaire); color: var(--couleur-texte); }
.empty { text-align: center; }
@media (max-width: 760px) {
    .tickets-nav { gap: .35rem; }
    .ticket-filter-btn { padding: .34rem .62rem; font-size: .78rem; }
    .event-top { grid-template-columns: 72px 1fr; }
    .event-image { width: 72px; height: 56px; }
    .event-total { grid-column: 2; justify-self: start; margin-top: .2rem; }
}
</style>
{% endblock %}
