{% extends 'base.html.twig' %}

{% block title %}Mes Billets - Passés{% endblock %}

{% block body %}
<section class="tickets-shell">
    <header class="tickets-header">
        <h1 class="page-title">Billets passés</h1>
        <p class="page-subtitle">{{ billets|length }} billet(s)</p>
    </header>

    <div class="tickets-nav">
        <a href="{{ path('billet.index') }}" class="ticket-filter-btn">Tous</a>
        <a href="{{ path('billet.avenir') }}" class="ticket-filter-btn">À venir</a>
        <a href="{{ path('billet.passes') }}" class="ticket-filter-btn active">Passés</a>
        <a href="{{ path('achat.commandes') }}" class="ticket-filter-btn">Mes commandes</a>
    </div>

    {% if billets|length > 0 %}
        <div class="tickets-list">
            {% for billet in billets %}
                <article class="ticket-row">
                    <img class="event-image" src="{{ billet.evenement.affichePrincipale ?: '/images/evenements/default.svg' }}" alt="Affiche {{ billet.evenement.nom }}" loading="lazy">
                    <div>
                        <h3>{{ billet.evenement.nom }}</h3>
                        <p>{{ billet.evenement.dateEvenement|date('d/m/Y H:i') }} • {{ billet.evenement.ville }}</p>
                        <small>{{ billet.type }} • {{ billet.prix|number_format(0, '.', ' ') }} XAF • {{ billet.isUtilise() ? 'Utilisé' : 'Non utilisé' }}</small>
                    </div>
                    <a href="{{ path('achat.billet', {qrCode: billet.qrCode}) }}" class="btn">Voir billet</a>
                </article>
            {% endfor %}
        </div>
    {% else %}
        <section class="card empty">
            <h2>Aucun billet passé</h2>
            <p>Vous n'avez pas encore d'historique de billet.</p>
            <a href="{{ path('evenement.index') }}" class="btn btn-primary">Explorer les événements</a>
        </section>
    {% endif %}
</section>

<style>
.tickets-shell { max-width: 900px; margin: 0 auto; display: grid; gap: 1rem; }
.tickets-nav { display: flex; gap: .4rem; flex-wrap: wrap; align-items: center; }
a.ticket-filter-btn { display: inline-flex; align-items: center; justify-content: center; padding: .34rem .68rem; border: 1px solid var(--couleur-bordure); border-radius: 999px; text-decoration: none; color: var(--couleur-texte); background: var(--couleur-surface); font-size: .8rem; font-weight: 600; line-height: 1.2; min-height: auto; }
a.ticket-filter-btn:hover { border-color: var(--couleur-secondaire); background: color-mix(in srgb, var(--couleur-surface) 90%, var(--couleur-secondaire) 10%); }
a.ticket-filter-btn.active { background: var(--couleur-primaire); color: var(--couleur-texte-inverse); border-color: var(--couleur-primaire); }
html[data-theme="dark"] .tickets-nav .ticket-filter-btn,
html[data-theme="dark"] .tickets-nav .ticket-filter-btn:hover,
html[data-theme="dark"] .tickets-nav .ticket-filter-btn.active { color: #fff !important; }
.tickets-list { display: grid; gap: .7rem; }
.ticket-row { display: grid; grid-template-columns: 90px 1fr auto; gap: .75rem; align-items: center; padding: .75rem; border: 1px solid var(--couleur-bordure); border-radius: var(--rayon); background: var(--couleur-surface); opacity: .92; }
.event-image { width: 90px; height: 68px; object-fit: cover; border-radius: var(--rayon); }
.ticket-row h3 { margin: 0; }
.ticket-row p { margin: .2rem 0; color: var(--couleur-texte-secondaire); }
.ticket-row .btn { padding: .35rem .65rem; font-size: .78rem; border-radius: 999px; }
.empty { text-align: center; }
@media (max-width: 760px) {
    .ticket-row { grid-template-columns: 70px 1fr; }
    .event-image { width: 70px; height: 54px; }
    .ticket-row .btn { grid-column: 1 / -1; width: 100%; }
}
</style>
{% endblock %}
