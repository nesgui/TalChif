{% extends 'layout/dashboard.html.twig' %}

{% set section = 'organisateur' %}

{% block title %}Événement #{{ id }}{% endblock %}

{% block dashboard_title %}Événement #{{ id }}{% endblock %}

{% block dashboard_actions %}
    <a class="btn" href="{{ path('organisateur.evenement.index') }}">Retour</a>
{% endblock %}

{% block dashboard_content %}
<p class="page-subtitle">Détail/édition UI pour l'événement #{{ id }}.</p>

<div class="grid">
    <section class="card">
        <h2 class="card-title">Informations</h2>
        <table class="table">
            <tbody>
                <tr>
                    <th>Nom</th>
                    <td><span class="pill">champ</span></td>
                </tr>
                <tr>
                    <th>Date (jour/heure)</th>
                    <td><span class="pill">champ</span></td>
                </tr>
                <tr>
                    <th>Lieu</th>
                    <td><span class="pill">champ</span></td>
                </tr>
                <tr>
                    <th>Types de billets</th>
                    <td><span class="pill">SIMPLE / VIP</span></td>
                </tr>
            </tbody>
        </table>
        <div class="card-actions">
            <a class="btn btn-primary" href="{{ path('organisateur.dashboard') }}">Enregistrer (prototype)</a>
        </div>
    </section>
</div>
{% endblock %}
