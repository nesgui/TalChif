{% extends 'layout/dashboard.html.twig' %}

{% set section = 'organisateur' %}

{% block title %}Créer un événement{% endblock %}

{% block dashboard_title %}Créer un événement{% endblock %}

{% block dashboard_content %}

<div class="grid">
    <section class="card">
        <h2 class="card-title">Informations de l'événement</h2>
        <p class="card-meta">Remplissez les champs obligatoires pour créer votre événement</p>

        {{ form_start(form, {'attr': {'class': 'auth-form', 'enctype': 'multipart/form-data', 'novalidate': 'novalidate'}}) }}

        {% include 'partials/form_group_enhanced.html.twig' with {
            'form': form.nom,
            'label': 'Nom de l\'événement',
            'placeholder': 'Choisissez un nom clair et attractif pour votre événement'
        } %}

        {% include 'partials/form_group_enhanced.html.twig' with {
            'form': form.categorie,
            'label': 'Catégorie',
            'placeholder': 'Sélectionnez la catégorie de votre événement'
        } %}

        {% include 'partials/form_group_enhanced.html.twig' with {
            'form': form.description,
            'label': 'Description',
            'placeholder': 'Décrivez votre événement en détail (minimum 10 caractères)'
        } %}

        {% include 'partials/form_group_enhanced.html.twig' with {
            'form': form.dateEvenement,
            'label': 'Date de l\'événement',
            'placeholder': 'Choisissez une date future pour votre événement'
        } %}

        {% include 'partials/form_group_enhanced.html.twig' with {
            'form': form.lieu,
            'label': 'Lieu',
            'placeholder': 'Nom du lieu (salle, stade, etc.)'
        } %}

        {% include 'partials/form_group_enhanced.html.twig' with {
            'form': form.adresse,
            'label': 'Adresse',
            'placeholder': 'Adresse précise pour aider les participants à trouver le lieu'
        } %}

        {% include 'partials/form_group_enhanced.html.twig' with {
            'form': form.ville,
            'label': 'Ville',
            'placeholder': 'Ville où se déroule l\'événement'
        } %}

        {% include 'partials/form_group_enhanced.html.twig' with {
            'form': form.placesDisponibles,
            'label': 'Places disponibles',
            'placeholder': 'Nombre total de billets que vous pouvez vendre'
        } %}

        {% include 'partials/form_group_enhanced.html.twig' with {
            'form': form.prixSimple,
            'label': 'Prix simple (XAF)',
            'placeholder': 'Prix du billet standard en Francs CFA'
        } %}

        {% include 'partials/form_group_enhanced.html.twig' with {
            'form': form.prixVip,
            'label': 'Prix VIP (XAF)',
            'placeholder': 'Optionnel - Laissez vide si pas de billets VIP'
        } %}

        {% include 'partials/form_group_enhanced.html.twig' with {
            'form': form.affichePrincipale,
            'label': 'Affiche principale',
            'placeholder': 'Formats acceptés: JPEG, PNG, GIF, WebP (max 5MB)'
        } %}

        {% include 'partials/form_group_enhanced.html.twig' with {
            'form': form.autresAffiches,
            'label': 'Autres affiches',
            'placeholder': 'Formats acceptés: JPEG, PNG, GIF, WebP (max 5MB par image)'
        } %}

        <div class="auth-form-group" style="background: var(--couleur-surface-elevee); padding: var(--espace-md); border-radius: var(--rayon); border: 1px dashed var(--couleur-bordure);">
            <p class="auth-label" style="margin: 0;">Design du billet</p>
            <small class="form-help" style="margin: 0;">Le design personnalisé du billet (image PNG) se configure après la création de l'événement, depuis la page de gestion de l'événement.</small>
        </div>

        {% include 'partials/form_group_enhanced.html.twig' with {
            'form': form.isActive,
            'label': 'Événement actif',
            'help': 'Cochez si l\'événement est prêt à être publié et vendu'
        } %}

        {% include 'partials/form_group_enhanced.html.twig' with {
            'form': form.isValide,
            'label': 'Événement validé',
            'help': 'Cochez si l\'événement a été validé par l\'administration'
        } %}

        <div class="card-actions">
            <button type="submit" class="btn btn-primary">Créer l'événement</button>
            <a href="{{ path('organisateur.evenement.index') }}" class="btn">Annuler</a>
        </div>

        {{ form_end(form) }}
    </section>
</div>
{% endblock dashboard_content %}
