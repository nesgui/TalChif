{% extends 'layout/dashboard.html.twig' %}

{% set section = 'organisateur' %}

{% block title %}Mes événements{% endblock %}

{% block dashboard_title %}Mes événements{% endblock %}

{% block dashboard_actions %}
    <a class="btn btn-primary" href="{{ path('organisateur.evenement.create') }}">Créer un événement</a>
{% endblock %}

{% block dashboard_content %}
<p class="page-subtitle">Espace organisateur : création/gestion des événements.</p>

<div class="grid">
    <section class="card">
        <h2 class="card-title">Mes événements</h2>
        <p class="card-meta">
            {% if total > 0 %}
                Affichage de {{ (page - 1) * limit + 1 }} à {{ (page - 1) * limit + evenements|length }} sur {{ total }} événements.
                {% if totalPages > 1 %}Page {{ page }}/{{ totalPages }}.{% endif %}
            {% else %}
                Liste de vos événements (tri, recherche et export sur la page courante).
            {% endif %}
        </p>

        <form method="get" action="{{ path('organisateur.evenement.index') }}" class="search-zone">
            <input type="hidden" name="page" value="1">
            <label for="event-search" class="search-zone-label">Rechercher</label>
            <input type="search" id="event-search" name="q" value="{{ search|default('') }}" class="form-control search-zone-input" placeholder="Nom, lieu, ville ou description...">
            <button type="submit" class="btn btn-primary btn-sm">Rechercher</button>
            {% if search %}
                <a href="{{ path('organisateur.evenement.index') }}" class="pagination-link">Effacer</a>
            {% endif %}
        </form>
        
        <div class="organizer-events-table-wrap">
        <table id="events-table" class="table organizer-events-table">
            <thead>
                <tr>
                    <th class="col-id">ID</th>
                    <th class="col-name">Nom</th>
                    <th class="col-date">Date</th>
                    <th class="col-location">Lieu</th>
                    <th class="col-status">Statut</th>
                    <th class="col-places">Places</th>
                    <th class="col-actions">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for evenement in evenements %}
                    <tr>
                        <td class="cell-id">{{ evenement.id }}</td>
                        <td class="cell-name">{{ evenement.nom }}</td>
                        <td class="cell-date">{{ evenement.dateEvenement|date('d/m/Y H:i') }}</td>
                        <td class="cell-location">{{ evenement.lieu }}</td>
                        <td class="cell-status">
                            {% if evenement.isActive and evenement.isValide %}
                                <span class="pill pill-success event-status-pill">Publié</span>
                            {% else %}
                                <span class="pill pill-warning event-status-pill">Brouillon</span>
                            {% endif %}
                        </td>
                        <td class="cell-places"><span class="event-places-value">{{ evenement.placesVendues }}/{{ evenement.placesDisponibles }}</span></td>
                        <td class="cell-actions">
                            <div class="actions-cell">
                                <a href="{{ path('organisateur.evenement.show', {id: evenement.id}) }}" class="btn btn-sm btn-primary">Voir</a>

                                {% if evenement.isActive and evenement.isValide %}
                                    <form method="post" action="{{ path('organisateur.evenement.toggle_status', {id: evenement.id, action: 'deactivate'}) }}">
                                        <input type="hidden" name="_token" value="{{ csrf_token('status' ~ evenement.id) }}">
                                        <button type="submit" class="btn btn-sm btn-warning" onclick="return confirm('Désactiver cet événement ?')">Désactiver</button>
                                    </form>
                                {% else %}
                                    <form method="post" action="{{ path('organisateur.evenement.toggle_status', {id: evenement.id, action: 'activate'}) }}">
                                        <input type="hidden" name="_token" value="{{ csrf_token('status' ~ evenement.id) }}">
                                        <button type="submit" class="btn btn-sm btn-success" onclick="return confirm('Activer cet événement ?')">Activer</button>
                                    </form>
                                {% endif %}
                            </div>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
        </div>

        {% if total > 0 %}
            <nav class="table-pagination" aria-label="Pagination événements">
                <div class="pagination-inner">
                    {% if page > 1 %}
                        <a href="{{ path('organisateur.evenement.index', {page: page - 1, q: search}) }}" class="pagination-link">← Précédent</a>
                    {% else %}
                        <span class="pagination-link disabled">← Précédent</span>
                    {% endif %}
                    <span class="pagination-info">Page {{ page }} / {{ totalPages }}</span>
                    {% if page < totalPages %}
                        <a href="{{ path('organisateur.evenement.index', {page: page + 1, q: search}) }}" class="pagination-link">Suivant →</a>
                    {% else %}
                        <span class="pagination-link disabled">Suivant →</span>
                    {% endif %}
                </div>
            </nav>
        {% endif %}
    </section>
</div>

<style>
.organizer-events-table-wrap {
    width: 100%;
    overflow-x: auto;
}

.organizer-events-table {
    width: 100%;
    table-layout: fixed;
}

.organizer-events-table .col-id,
.organizer-events-table .cell-id {
    width: 64px;
    white-space: nowrap;
}

.organizer-events-table .col-date,
.organizer-events-table .cell-date {
    width: 148px;
}

.organizer-events-table .col-status,
.organizer-events-table .cell-status {
    width: 110px;
    text-align: center;
}

.organizer-events-table .col-places,
.organizer-events-table .cell-places {
    width: 96px;
    text-align: center;
}

.organizer-events-table .col-actions,
.organizer-events-table .cell-actions {
    width: 190px;
}

.organizer-events-table .cell-name {
    font-weight: 600;
}

.organizer-events-table .cell-location {
    line-height: 1.45;
}

.organizer-events-table .cell-date,
.organizer-events-table .cell-location {
    word-break: break-word;
}

.event-status-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 84px;
    white-space: nowrap;
    text-align: center;
}

.event-places-value {
    display: inline-block;
    white-space: nowrap;
    font-weight: 600;
}

.actions-cell {
    display: flex;
    align-items: center;
    gap: .5rem;
    flex-wrap: wrap;
}

.actions-cell form {
    margin: 0;
}

.actions-cell .btn {
    min-width: 96px;
    justify-content: center;
    white-space: nowrap;
}

@media (max-width: 980px) {
    .organizer-events-table {
        min-width: 860px;
    }
}

@media (max-width: 768px) {
    .organizer-events-table .col-id,
    .organizer-events-table .cell-id {
        width: 56px;
    }

    .organizer-events-table .col-date,
    .organizer-events-table .cell-date {
        width: 132px;
    }

    .organizer-events-table .col-status,
    .organizer-events-table .cell-status {
        width: 104px;
    }

    .organizer-events-table .col-places,
    .organizer-events-table .cell-places {
        width: 88px;
    }

    .organizer-events-table .col-actions,
    .organizer-events-table .cell-actions {
        width: 168px;
    }

    .actions-cell {
        gap: .4rem;
    }

    .actions-cell .btn {
        min-width: 84px;
        padding-inline: .7rem;
    }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Initialiser DataTables pour les événements
    if (typeof DataTableOS !== 'undefined') {
        // Nettoyage : détruire l'instance précédente et ses boutons (navigation Turbo Frame)
        if (jQuery.fn.DataTable.isDataTable('#events-table')) {
            jQuery('#events-table').DataTable().destroy();
        }
        jQuery('#events-table').parent().find('.dt-buttons').remove();

        DataTableOS.init('#events-table', {
            paging: false,
            searching: false,
            info: false,
            lengthChange: false,
            order: [[2, 'desc']], // Tri par date (décroissant)
            buttons: [
                {
                    extend: 'excel',
                    text: 'Excel',
                    className: 'btn btn-sm btn-success',
                    exportOptions: {
                        title: 'Exporter la liste des événements en Excel'
                    }
                },
                {
                    extend: 'csv',
                    text: 'CSV',
                    className: 'btn btn-sm btn-info',
                    exportOptions: {
                        title: 'Exporter la liste des événements en CSV'
                    }
                },
                {
                    extend: 'print',
                    text: 'Imprimer',
                    className: 'btn btn-sm btn-secondary',
                    exportOptions: {
                        title: 'Imprimer la liste des événements'
                    }
                }
            ],
            columns: [
                { width: '64px' },
                null,
                { width: '148px' },
                null,
                { width: '110px' },
                { width: '96px' },
                { width: '190px', orderable: false }
            ]
        });
    }
});
</script>

{% endblock %}
