{% extends 'layout/dashboard.html.twig' %}

{% set section = 'organisateur' %}

{% block title %}Modifier l'événement{% endblock %}

{% block dashboard_title %}Modifier l'événement{% endblock %}

{% block dashboard_content %}

<div class="grid">
    <section class="card">
        <h2 class="card-title">Informations de l'événement</h2>
        <p class="card-meta">Modifiez les champs nécessaires</p>

        {{ form_start(form, {'attr': {'class': 'auth-form', 'enctype': 'multipart/form-data'}}) }}

        <div class="auth-form-group">
            <label for="{{ form.nom.vars.id }}" class="auth-label">Nom de l'événement <span style="color: #e53e3e;">*</span></label>
            {{ form_widget(form.nom, {'attr': {'class': 'auth-input', 'placeholder': 'Entrez le nom de l\'événement'}}) }}
            {% if form_errors(form.nom) %}
                <div class="auth-error-message">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"/>
                        <line x1="12" y1="8" x2="12" y2="12"/>
                        <line x1="12" y1="16" x2="12.01" y2="16"/>
                    </svg>
                    {{ form_errors(form.nom) }}
                </div>
            {% endif %}
        </div>

        <div class="auth-form-group">
            <label for="{{ form.categorie.vars.id }}" class="auth-label">Catégorie <span style="color: #e53e3e;">*</span></label>
            {{ form_widget(form.categorie, {'attr': {'class': 'auth-input'}}) }}
            {% if form_errors(form.categorie) %}
                <div class="auth-error-message">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"/>
                        <line x1="12" y1="8" x2="12" y2="12"/>
                        <line x1="12" y1="16" x2="12.01" y2="16"/>
                    </svg>
                    {{ form_errors(form.categorie) }}
                </div>
            {% endif %}
        </div>

        <div class="auth-form-group">
            <label for="{{ form.description.vars.id }}" class="auth-label">Description <span style="color: #e53e3e;">*</span></label>
            {{ form_widget(form.description, {'attr': {'class': 'auth-input', 'placeholder': 'Décrivez votre événement en détail (minimum 10 caractères)', 'rows': '4'}}) }}
            {% if form_errors(form.description) %}
                <div class="auth-error-message">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"/>
                        <line x1="12" y1="8" x2="12" y2="12"/>
                        <line x1="12" y1="16" x2="12.01" y2="16"/>
                    </svg>
                    {{ form_errors(form.description) }}
                </div>
            {% endif %}
        </div>

        <div class="auth-form-group">
            <label for="{{ form.dateEvenement.vars.id }}" class="auth-label">Date de l'événement <span style="color: #e53e3e;">*</span></label>
            {{ form_widget(form.dateEvenement, {'attr': {'class': 'auth-input'}}) }}
            {% if form_errors(form.dateEvenement) %}
                <div class="auth-error-message">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"/>
                        <line x1="12" y1="8" x2="12" y2="12"/>
                        <line x1="12" y1="16" x2="12.01" y2="16"/>
                    </svg>
                    {{ form_errors(form.dateEvenement) }}
                </div>
            {% endif %}
        </div>

        <div class="auth-form-group">
            <label for="{{ form.lieu.vars.id }}" class="auth-label">Lieu <span style="color: #e53e3e;">*</span></label>
            {{ form_widget(form.lieu, {'attr': {'class': 'auth-input', 'placeholder': 'Entrez le lieu de l\'événement'}}) }}
            {% if form_errors(form.lieu) %}
                <div class="auth-error-message">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"/>
                        <line x1="12" y1="8" x2="12" y2="12"/>
                        <line x1="12" y1="16" x2="12.01" y2="16"/>
                    </svg>
                    {{ form_errors(form.lieu) }}
                </div>
            {% endif %}
        </div>

        <div class="auth-form-group">
            <label for="{{ form.adresse.vars.id }}" class="auth-label">Adresse <span style="color: #e53e3e;">*</span></label>
            {{ form_widget(form.adresse, {'attr': {'class': 'auth-input', 'placeholder': 'Entrez l\'adresse complète'}}) }}
            {% if form_errors(form.adresse) %}
                <div class="auth-error-message">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"/>
                        <line x1="12" y1="8" x2="12" y2="12"/>
                        <line x1="12" y1="16" x2="12.01" y2="16"/>
                    </svg>
                    {{ form_errors(form.adresse) }}
                </div>
            {% endif %}
        </div>

        <div class="auth-form-group">
            <label for="{{ form.ville.vars.id }}" class="auth-label">Ville <span style="color: #e53e3e;">*</span></label>
            {{ form_widget(form.ville, {'attr': {'class': 'auth-input', 'placeholder': 'Entrez la ville'}}) }}
            {% if form_errors(form.ville) %}
                <div class="auth-error-message">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"/>
                        <line x1="12" y1="8" x2="12" y2="12"/>
                        <line x1="12" y1="16" x2="12.01" y2="16"/>
                    </svg>
                    {{ form_errors(form.ville) }}
                </div>
            {% endif %}
        </div>

        <div class="auth-form-group">
            <label for="{{ form.placesDisponibles.vars.id }}" class="auth-label">Places disponibles <span style="color: #e53e3e;">*</span></label>
            {{ form_widget(form.placesDisponibles, {'attr': {'class': 'auth-input', 'placeholder': 'Nombre de places disponibles'}}) }}
            {% if form_errors(form.placesDisponibles) %}
                <div class="auth-error-message">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"/>
                        <line x1="12" y1="8" x2="12" y2="12"/>
                        <line x1="12" y1="16" x2="12.01" y2="16"/>
                    </svg>
                    {{ form_errors(form.placesDisponibles) }}
                </div>
            {% endif %}
        </div>

        <div class="auth-form-group">
            <label for="{{ form.prixSimple.vars.id }}" class="auth-label">Prix simple (XAF) <span style="color: #e53e3e;">*</span></label>
            {{ form_widget(form.prixSimple, {'attr': {'class': 'auth-input', 'placeholder': 'Prix du billet simple'}}) }}
            {% if form_errors(form.prixSimple) %}
                <div class="auth-error-message">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"/>
                        <line x1="12" y1="8" x2="12" y2="12"/>
                        <line x1="12" y1="16" x2="12.01" y2="16"/>
                    </svg>
                    {{ form_errors(form.prixSimple) }}
                </div>
            {% endif %}
        </div>

        <div class="auth-form-group">
            {{ form_label(form.prixVip, 'Prix VIP (XAF)', {'label_attr': {'class': 'auth-label'}}) }}
            {{ form_widget(form.prixVip, {'attr': {'class': 'auth-input', 'placeholder': 'Prix du billet VIP (optionnel)'}}) }}
            {% if form_errors(form.prixVip) %}
                <div class="auth-error-message">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"/>
                        <line x1="12" y1="8" x2="12" y2="12"/>
                        <line x1="12" y1="16" x2="12.01" y2="16"/>
                    </svg>
                    {{ form_errors(form.prixVip) }}
                </div>
            {% endif %}
            <small class="form-help">Optionnel - Laissez vide si pas de billets VIP</small>
        </div>

        <div class="auth-form-group">
            {{ form_label(form.affichePrincipale, 'Affiche principale', {'label_attr': {'class': 'auth-label'}}) }}
            {{ form_widget(form.affichePrincipale, {'attr': {'class': 'file-input'}}) }}
            {% if form_errors(form.affichePrincipale) %}
                <div class="auth-error-message">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"/>
                        <line x1="12" y1="8" x2="12" y2="12"/>
                        <line x1="12" y1="16" x2="12.01" y2="16"/>
                    </svg>
                    {{ form_errors(form.affichePrincipale) }}
                </div>
            {% endif %}
            <small class="form-help">Formats acceptés: JPEG, PNG, GIF, WebP (max 5MB)</small>
            {% if evenement.affichePrincipale %}
                <p class="mt-2">
                    <small>Image actuelle : </small>
                    <img src="{{ evenement.affichePrincipale }}" alt="Affiche actuelle" style="max-height: 100px;">
                </p>
            {% endif %}
        </div>

        <div class="auth-form-group">
            {{ form_label(form.autresAffiches, 'Bannière de l\'événement (1600 × 600 px recommandés, soit environ 423 × 159 mm)', {'label_attr': {'class': 'auth-label'}}) }}
            {{ form_widget(form.autresAffiches, {'attr': {'class': 'file-input', 'multiple': 'multiple'}}) }}
            {% if form_errors(form.autresAffiches) %}
                <div class="auth-error-message">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"/>
                        <line x1="12" y1="8" x2="12" y2="12"/>
                        <line x1="12" y1="16" x2="12.01" y2="16"/>
                    </svg>
                    {{ form_errors(form.autresAffiches) }}
                </div>
            {% endif %}
            <small class="form-help">Formats acceptés: JPEG, PNG, GIF, WebP (max 2MB) - format conseillé 1600 × 600 px pour la banderole</small>
        </div>

        <div class="auth-form-group">
            {{ form_label(form.isActive, 'Événement actif', {'label_attr': {'class': 'auth-label'}}) }}
            {{ form_widget(form.isActive, {'attr': {'class': 'form-checkbox'}}) }}
            {% if form_errors(form.isActive) %}
                <div class="auth-error-message">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"/>
                        <line x1="12" y1="8" x2="12" y2="12"/>
                        <line x1="12" y1="16" x2="12.01" y2="16"/>
                    </svg>
                    {{ form_errors(form.isActive) }}
                </div>
            {% endif %}
            <small class="form-help">{{ form_help(form.isActive) }}</small>
        </div>

        <div class="auth-form-group">
            {{ form_label(form.isValide, 'Événement validé', {'label_attr': {'class': 'auth-label'}}) }}
            {{ form_widget(form.isValide, {'attr': {'class': 'form-checkbox'}}) }}
            {% if form_errors(form.isValide) %}
                <div class="auth-error-message">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"/>
                        <line x1="12" y1="8" x2="12" y2="12"/>
                        <line x1="12" y1="16" x2="12.01" y2="16"/>
                    </svg>
                    {{ form_errors(form.isValide) }}
                </div>
            {% endif %}
            <small class="form-help">{{ form_help(form.isValide) }}</small>
        </div>

        <div class="card-actions">
            <button type="submit" class="btn btn-primary">Mettre à jour l'événement</button>
            <a href="{{ path('organisateur.evenement.index') }}" class="btn">Annuler</a>
        </div>

        {{ form_end(form) }}
    </section>
</div>
{% endblock dashboard_content %}
