{% extends 'base.html.twig' %}

{% block title %}Modifier l'événement{% endblock %}

{% block body %}
<h1 class="page-title">Modifier l'événement</h1>
<p class="page-subtitle">Mettre à jour les informations de l'événement</p>

<div class="grid">
    <section class="card">
        <h2 class="card-title">Informations de l'événement</h2>
        <p class="card-meta">Modifiez les champs nécessaires</p>

        {% for flash in app.flashes('success') %}
            <div class="alert alert-success">
                {{ flash }}
            </div>
        {% endfor %}

        {% for flash in app.flashes('error') %}
            <div class="alert alert-error">
                {{ flash }}
            </div>
        {% endfor %}

        {{ form_start(form, {'attr': {'class': 'form', 'enctype': 'multipart/form-data'}}) }}
        
        <div class="form-group">
            {{ form_label(form.nom) }}
            {{ form_widget(form.nom, {'attr': {'class': 'form-control w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors'}}) }}
            {{ form_errors(form.nom) }}
        </div>

        <div class="form-group">
            {{ form_label(form.description) }}
            {{ form_widget(form.description, {'attr': {'class': 'form-control w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors', 'rows': '4'}}) }}
            {{ form_errors(form.description) }}
        </div>

        <div class="form-group">
            {{ form_label(form.dateEvenement) }}
            {{ form_widget(form.dateEvenement, {'attr': {'class': 'form-control w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors'}}) }}
            {{ form_errors(form.dateEvenement) }}
        </div>

        <div class="form-group">
            {{ form_label(form.lieu) }}
            {{ form_widget(form.lieu, {'attr': {'class': 'form-control w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors'}}) }}
            {{ form_errors(form.lieu) }}
        </div>

        <div class="form-group">
            {{ form_label(form.adresse) }}
            {{ form_widget(form.adresse, {'attr': {'class': 'form-control w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors'}}) }}
            {{ form_errors(form.adresse) }}
        </div>

        <div class="form-group">
            {{ form_label(form.ville) }}
            {{ form_widget(form.ville, {'attr': {'class': 'form-control w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors'}}) }}
            {{ form_errors(form.ville) }}
        </div>

        <div class="form-group">
            {{ form_label(form.placesDisponibles) }}
            {{ form_widget(form.placesDisponibles, {'attr': {'class': 'form-control w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors'}}) }}
            {{ form_errors(form.placesDisponibles) }}
        </div>

        <div class="form-group">
            {{ form_label(form.prixSimple) }}
            {{ form_widget(form.prixSimple, {'attr': {'class': 'form-control w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors'}}) }}
            {{ form_errors(form.prixSimple) }}
        </div>

        <div class="form-group">
            {{ form_label(form.prixVip) }}
            {{ form_widget(form.prixVip, {'attr': {'class': 'form-control w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors'}}) }}
            {{ form_errors(form.prixVip) }}
            <small class="form-help text-gray-500 text-sm mt-1">Optionnel - Laissez vide si pas de billets VIP</small>
        </div>

        <div class="form-group">
            {{ form_label(form.affichePrincipale) }}
            {{ form_widget(form.affichePrincipale, {'attr': {'class': 'file-input w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors'}}) }}
            {{ form_errors(form.affichePrincipale) }}
            <small class="form-help text-gray-500 text-sm mt-1">Formats acceptés: JPEG, PNG, GIF, WebP (max 5MB)</small>
            {% if evenement.affichePrincipale %}
                <p class="mt-2">
                    <small>Image actuelle : </small>
                    <img src="{{ evenement.affichePrincipale }}" alt="Affiche actuelle" style="max-height: 100px;">
                </p>
            {% endif %}
        </div>

        <div class="form-group">
            {{ form_label(form.autresAffiches) }}
            {{ form_widget(form.autresAffiches, {'attr': {'class': 'file-input w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors'}}) }}
            {{ form_errors(form.autresAffiches) }}
            <small class="form-help text-gray-500 text-sm mt-1">Formats acceptés: JPEG, PNG, GIF, WebP (max 5MB par image) - Plusieurs images possibles</small>
        </div>

        <div class="form-group">
            {{ form_label(form.imageBillet) }}
            {{ form_widget(form.imageBillet, {'attr': {'class': 'file-input w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors'}}) }}
            {{ form_errors(form.imageBillet) }}
            <small class="form-help text-gray-500 text-sm mt-1">Formats acceptés: JPEG, PNG, GIF, WebP (max 2MB)</small>
            {% if evenement.imageBillet %}
                <p class="mt-2">
                    <small>Image actuelle : </small>
                    <img src="{{ evenement.imageBillet }}" alt="Image billet actuelle" style="max-height: 100px;">
                </p>
            {% endif %}
        </div>

        <div class="form-group">
            {{ form_label(form.isActive) }}
            {{ form_widget(form.isActive, {'attr': {'class': 'form-checkbox'}}) }}
            {{ form_errors(form.isActive) }}
            <small class="form-help text-gray-500 text-sm mt-1">{{ form_help(form.isActive) }}</small>
        </div>

        <div class="form-group">
            {{ form_label(form.isValide) }}
            {{ form_widget(form.isValide, {'attr': {'class': 'form-checkbox'}}) }}
            {{ form_errors(form.isValide) }}
            <small class="form-help text-gray-500 text-sm mt-1">{{ form_help(form.isValide) }}</small>
        </div>

        <div class="card-actions">
            <button type="submit" class="btn btn-primary">Mettre à jour l'événement</button>
            <a href="{{ path('organisateur.evenement.index') }}" class="btn">Annuler</a>
        </div>

        {{ form_end(form) }}
    </section>
</div>
{% endblock %}
