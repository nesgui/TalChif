{% extends 'base.html.twig' %}

{% block title %}Espace client{% endblock %}

{% block body %}
<section class="client-shell">
    <header>
        <h1 class="page-title">Espace client</h1>
        <p class="page-subtitle">Bienvenue {{ app.user.nom }}. Gérez vos achats.</p>
    </header>

    <div class="grid">
        <section class="card">
            <h2 class="card-title">Mon compte</h2>
            <p><strong>Email:</strong> {{ app.user.email }}</p>
            <p><strong>Téléphone:</strong> {{ app.user.telephone ?: 'Non renseigné' }}</p>
            <p>
                <strong>Compte vérifié:</strong>
                {% if app.user.isVerified %}
                    <span class="pill pill-success">Oui</span>
                {% else %}
                    <span class="pill pill-warning">Non</span>
                {% endif %}
            </p>
        </section>

        <section class="card">
            <h2 class="card-title">Actions rapides</h2>
            <div class="card-actions">
                <a href="{{ path('profile.index') }}" class="btn">Mon profil</a>
                <a href="{{ path('billet.index') }}" class="btn btn-primary">Mes billets</a>
                <a href="{{ path('achat.commandes') }}" class="btn">Mes commandes</a>
                <a href="{{ path('panier.index') }}" class="btn">Mon panier</a>
                <a href="{{ path('evenement.index') }}" class="btn">Voir les événements</a>
                <a href="{{ path('auth.logout') }}" class="btn btn-danger">Se déconnecter</a>
            </div>
        </section>
    </div>
</section>

{% endblock %}
