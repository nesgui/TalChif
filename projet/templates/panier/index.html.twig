{% extends 'base.html.twig' %}

{% block title %}Mon panier{% endblock %}

{% block body %}
<section class="panier-shell">
    <header class="panier-head">
        <h1 class="page-title">Mon panier</h1>
        <p class="page-subtitle">Vérifiez vos billets puis passez au paiement.</p>
    </header>

    {% if lignes|length > 0 %}
        <div class="panier-grid">
            <section class="card">
                <div class="card-actions top-row">
                    <h2 class="card-title">Articles ({{ lignes|length }})</h2>
                    <form method="post" action="{{ path('panier.vider') }}">
                        <button class="btn" type="submit" onclick="return confirm('Vider tout le panier ?')">Vider</button>
                    </form>
                </div>

                <div class="items-list">
                    {% for ligne in lignes %}
                        <article class="item-row">
                            <img class="item-img" src="{{ ligne.produit.image }}" alt="Affiche {{ ligne.produit.titre }}" loading="lazy">
                            <div class="item-main">
                                <p class="item-title">{{ ligne.produit.titre }}</p>
                                <small>{{ ligne.produit.date|date('d/m/Y H:i') }} • {{ ligne.produit.ville }}</small>
                                <div class="qty-row">
                                    <button class="btn btn-sm" type="button" onclick="updateQuantite({{ ligne.produit.id }}, {{ ligne.quantite }}, -1, {{ ligne.produit.places_restantes }})">−</button>
                                    <span class="qty">{{ ligne.quantite }}</span>
                                    <button class="btn btn-sm" type="button" onclick="updateQuantite({{ ligne.produit.id }}, {{ ligne.quantite }}, 1, {{ ligne.produit.places_restantes }})">+</button>
                                    <form method="post" action="{{ path('panier.supprimer', {id: ligne.id}) }}" class="remove-form">
                                        <input type="hidden" name="_token" value="{{ csrf_token('panier_supprimer_' ~ ligne.id) }}">
                                        <button class="btn btn-sm" type="submit">Supprimer</button>
                                    </form>
                                </div>
                            </div>
                            <strong class="item-total">{{ ligne.sous_total|number_format(0, '.', ' ') }} XAF</strong>
                        </article>
                    {% endfor %}
                </div>
            </section>

            <aside class="card recap">
                <h2 class="card-title">Total</h2>
                <p class="total">{{ total|number_format(0, '.', ' ') }} XAF</p>
                <div class="card-actions">
                    {% if app.user %}
                        <a class="btn btn-primary btn-block" href="{{ path('achat.index') }}">Passer au paiement</a>
                    {% else %}
                        <a class="btn btn-primary btn-block" href="{{ path('achat.index') }}">Se connecter pour payer</a>
                    {% endif %}
                    <a class="btn btn-block" href="{{ path('evenement.index') }}">Continuer mes achats</a>
                </div>
            </aside>
        </div>
    {% else %}
        <section class="card empty">
            <h2>Votre panier est vide</h2>
            <p>Ajoutez un événement pour commencer.</p>
            <a class="btn btn-primary" href="{{ path('evenement.index') }}">Explorer les événements</a>
        </section>
    {% endif %}
</section>

<style>
.panier-shell { max-width: 980px; margin: 0 auto; display: grid; gap: 1rem; }
.panier-grid { display: grid; grid-template-columns: 1fr 320px; gap: 1rem; }
.top-row { justify-content: space-between; align-items: center; }
.items-list { display: grid; gap: .7rem; }
.item-row { display: grid; grid-template-columns: 90px 1fr auto; gap: .8rem; align-items: center; padding: .75rem; border: 1px solid var(--couleur-bordure); border-radius: var(--rayon); }
.item-img { width: 90px; height: 70px; object-fit: cover; border-radius: var(--rayon); }
.item-title { margin: 0; font-weight: 700; }
.item-main small { color: var(--couleur-texte-secondaire); }
.qty-row { margin-top: .45rem; display: flex; align-items: center; gap: .35rem; flex-wrap: wrap; }
.qty { min-width: 20px; text-align: center; font-weight: 700; }
.remove-form { display: inline; }
.item-total { white-space: nowrap; }
.recap .total { font-size: 1.5rem; font-weight: 800; margin: .3rem 0 1rem; }
.empty { text-align: center; }
@media (max-width: 860px) {
    .panier-grid { grid-template-columns: 1fr; }
    .item-row { grid-template-columns: 70px 1fr; }
    .item-img { width: 70px; height: 56px; }
    .item-total { grid-column: 1 / -1; }
}
</style>

<script>
function updateQuantite(id, currentQuantite, change, maxQuantite) {
    const newQuantite = Math.max(0, Math.min(currentQuantite + change, maxQuantite));
    const form = document.createElement('form');
    form.method = 'POST';
    form.action = "{{ path('panier.quantite', {id: 0}) }}".replace(/\/0$/, '/' + id);

    const quantiteInput = document.createElement('input');
    quantiteInput.type = 'hidden';
    quantiteInput.name = 'quantite';
    quantiteInput.value = newQuantite;
    form.appendChild(quantiteInput);

    const tokenInput = document.createElement('input');
    tokenInput.type = 'hidden';
    tokenInput.name = '_token';
    tokenInput.value = "{{ csrf_token('panier_quantite') }}";
    form.appendChild(tokenInput);

    document.body.appendChild(form);
    form.submit();
}
</script>
{% endblock %}
