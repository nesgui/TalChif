{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block body %}
<h1 class="page-title">Connexion</h1>
<p class="page-subtitle">Accédez à votre espace personnel</p>

{% if error %}
    <div class="alert alert-error">
        {{ error.messageKey|trans(error.messageData, 'security') }}
    </div>
{% endif %}

<div class="grid">
    <section class="card">
        <h2 class="card-title">Se connecter</h2>
        <p class="card-meta">Entrez vos identifiants</p>

        <form method="post" action="{{ path('auth.login') }}" class="form">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
            
            <div class="form-group">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" class="form-control w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors" 
                       value="{{ last_username }}" required autofocus>
            </div>

            <div class="form-group">
                <label for="password">Mot de passe</label>
                <input type="password" id="password" name="password" class="form-control w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors" required>
            </div>

            <div class="card-actions">
                <button type="submit" class="btn btn-primary">Se connecter</button>
                <a href="{{ path('auth.register') }}" class="btn">Créer un compte</a>
            </div>
        </form>
    </section>
</div>
{% endblock %}
