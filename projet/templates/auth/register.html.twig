{% extends 'base.html.twig' %}

{% block title %}Inscription{% endblock %}

{% block stylesheets %}
    {{ parent() }}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('services/auth_service.js') }}" defer></script>
{% endblock %}

{% block body %}
<div class="auth-top-header">
    <div class="auth-header-content">
        <a href="{{ path('accueil') }}" class="auth-app-name" style="text-decoration: none;">TalChif</a>
    </div>
</div>
<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <h1 class="auth-title">Inscription</h1>
            <p class="auth-subtitle">Créez votre compte pour accéder à tous les événements</p>
        </div>
        
        <div class="auth-body">
            {% for flash in app.flashes('error') %}
                <div class="auth-alert auth-alert-error">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"/>
                        <line x1="12" y1="8" x2="12" y2="12"/>
                        <line x1="12" y1="16" x2="12.01" y2="16"/>
                    </svg>
                    {{ flash }}
                </div>
            {% endfor %}

            {{ form_start(form, {'attr': {'class': 'auth-form'}}) }}
            
                <div class="auth-form-group">
                    {{ form_label(form.email, 'Adresse email', {'label_attr': {'class': 'auth-label'}}) }}
                    {{ form_widget(form.email, {'attr': {
                        'class': 'auth-input',
                        'placeholder': 'Entrez votre adresse email'
                    }}) }}
                    {% if form_errors(form.email) %}
                        <div class="auth-error-message">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <circle cx="12" cy="12" r="10"/>
                                <line x1="12" y1="8" x2="12" y2="12"/>
                                <line x1="12" y1="16" x2="12.01" y2="16"/>
                            </svg>
                            {{ form_errors(form.email) }}
                        </div>
                    {% endif %}
                </div>

                <div class="auth-form-group">
                    {{ form_label(form.nom, 'Nom complet', {'label_attr': {'class': 'auth-label'}}) }}
                    {{ form_widget(form.nom, {'attr': {
                        'class': 'auth-input',
                        'placeholder': 'Entrez votre nom complet'
                    }}) }}
                    {% if form_errors(form.nom) %}
                        <div class="auth-error-message">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <circle cx="12" cy="12" r="10"/>
                                <line x1="12" y1="8" x2="12" y2="12"/>
                                <line x1="12" y1="16" x2="12.01" y2="16"/>
                            </svg>
                            {{ form_errors(form.nom) }}
                        </div>
                    {% endif %}
                </div>

                <div class="auth-form-group">
                    {{ form_label(form.telephone, 'Téléphone', {'label_attr': {'class': 'auth-label'}}) }}
                    {{ form_widget(form.telephone, {'attr': {
                        'class': 'auth-input',
                        'placeholder': 'Entrez votre numéro de téléphone'
                    }}) }}
                    {% if form_errors(form.telephone) %}
                        <div class="auth-error-message">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <circle cx="12" cy="12" r="10"/>
                                <line x1="12" y1="8" x2="12" y2="12"/>
                                <line x1="12" y1="16" x2="12.01" y2="16"/>
                            </svg>
                            {{ form_errors(form.telephone) }}
                        </div>
                    {% endif %}
                </div>

                <div class="auth-form-group">
                    {{ form_label(form.password, 'Mot de passe', {'label_attr': {'class': 'auth-label'}}) }}
                    {{ form_widget(form.password, {'attr': {
                        'class': 'auth-input',
                        'placeholder': 'Choisissez un mot de passe'
                    }}) }}
                    {% if form_errors(form.password) %}
                        <div class="auth-error-message">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <circle cx="12" cy="12" r="10"/>
                                <line x1="12" y1="8" x2="12" y2="12"/>
                                <line x1="12" y1="16" x2="12.01" y2="16"/>
                            </svg>
                            {{ form_errors(form.password) }}
                        </div>
                    {% endif %}
                </div>

                <div class="auth-form-group">
                    {{ form_label(form.password_confirm, 'Confirmer le mot de passe', {'label_attr': {'class': 'auth-label'}}) }}
                    {{ form_widget(form.password_confirm, {'attr': {
                        'class': 'auth-input',
                        'placeholder': 'Confirmez votre mot de passe'
                    }}) }}
                    {% if form_errors(form.password_confirm) %}
                        <div class="auth-error-message">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <circle cx="12" cy="12" r="10"/>
                                <line x1="12" y1="8" x2="12" y2="12"/>
                                <line x1="12" y1="16" x2="12.01" y2="16"/>
                            </svg>
                            {{ form_errors(form.password_confirm) }}
                        </div>
                    {% endif %}
                </div>

                <div class="auth-actions">
                    <button type="submit" class="auth-btn auth-btn-primary">
                        Créer le compte
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                            <circle cx="8.5" cy="7" r="4"/>
                            <line x1="20" y1="8" x2="20" y2="14"/>
                            <line x1="23" y1="11" x2="17" y2="11"/>
                        </svg>
                    </button>
                </div>

                <div class="auth-divider">ou</div>

                <div class="auth-actions">
                    <a href="{{ path('auth.login') }}" class="auth-btn auth-btn-secondary">
                        J'ai déjà un compte
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/>
                            <polyline points="10 17 15 12 10 7"/>
                            <line x1="15" y1="12" x2="3" y2="12"/>
                        </svg>
                    </a>
                </div>

            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}
