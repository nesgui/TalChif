{% extends 'layout/auth.html.twig' %}

{% block title %}Inscription{% endblock %}

{% block auth_content %}
    <div class="auth-header">
        <h1 class="auth-title">Inscription</h1>
        <p class="auth-subtitle">Créez votre compte pour accéder à tous les événements</p>
    </div>
    
    <div class="auth-body">
        {% for flash in app.flashes('error') %}
            <div class="auth-alert auth-alert-error">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"/>
                    <line x1="12" y1="8" x2="12" y2="12"/>
                    <line x1="12" y1="16" x2="12.01" y2="16"/>
                </svg>
                {{ flash }}
            </div>
        {% endfor %}

        {% for flash in app.flashes('success') %}
            <div class="auth-alert auth-alert-success">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 11.08V12.5a1 1 0 0 0-1-1v-1a6 6 0 0 0-6-6H6a6 6 0 0 0-6 6v1a9 9 0 0 0 9 9h.01a9 9 0 0 0 9-9H21"/>
                    <polyline points="22,11.08 22,4 16,4 16,11.08"/>
                </svg>
                {{ flash }}
            </div>
        {% endfor %}

        {{ form_start(form, {'attr': {'class': 'auth-form', 'novalidate': 'novalidate'}}) }}
        
        {% include 'partials/form_group_enhanced.html.twig' with {
            'form': form.email,
            'label': 'Adresse email',
            'placeholder': 'Entrez votre adresse email'
        } %}

        {% include 'partials/form_group_enhanced.html.twig' with {
            'form': form.nom,
            'label': 'Nom complet',
            'placeholder': 'Entrez votre nom complet'
        } %}

        {% include 'partials/form_group_enhanced.html.twig' with {
            'form': form.telephone,
            'label': 'Téléphone',
            'placeholder': '+235 XXXXXXXX'
        } %}

        {% include 'partials/form_group_enhanced.html.twig' with {
            'form': form.password,
            'label': 'Mot de passe',
            'placeholder': 'Minimum 6 caractères'
        } %}

        {% include 'partials/form_group_enhanced.html.twig' with {
            'form': form.password_confirm,
            'label': 'Confirmer le mot de passe',
            'placeholder': 'Doit être identique au mot de passe'
        } %}
        
        <div class="auth-form-actions">
            <button type="submit" class="auth-btn auth-btn-primary">
                S&#39;inscrire
            </button>
        </div>
        
        {{ form_end(form) }}
        
        <div class="auth-footer">
            <p class="auth-footer-text">
                Déjà un compte ? 
                <a href="{{ path('auth.login') }}" class="auth-link">Se connecter</a>
            </p>
        </div>
    </div>
{% endblock %}
