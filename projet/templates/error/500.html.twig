{% extends 'base.html.twig' %}

{% block title %}Erreur serveur - TalChif{% endblock %}

{% block body %}
<div class="error-page-wrapper">
    <div class="error-page-content-centered">
        <div class="error-page-icon error-icon-error">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <path d="M12 8v4"/>
                <path d="M12 16h.01"/>
            </svg>
        </div>
        
        <div class="error-page-code-watermark">500</div>
        <h1 class="error-page-title">Erreur serveur</h1>
        <p class="error-page-description">Une erreur interne s'est produite sur nos serveurs. Notre équipe technique a été automatiquement notifiée et travaille à résoudre le problème.</p>
        
        <div class="error-page-info-box">
            <div class="error-page-info-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/>
                    <line x1="12" y1="16" x2="12" y2="12"/>
                    <line x1="12" y1="8" x2="12.01" y2="8"/>
                </svg>
            </div>
            <div class="error-page-info-text">
                <strong>Que faire ?</strong>
                <p>Veuillez réessayer dans quelques instants. Si le problème persiste, contactez notre support.</p>
            </div>
        </div>
        
        <div class="error-page-actions">
            <a href="{{ path('accueil') }}" class="btn btn-primary">Retour à l'accueil</a>
            <button onclick="window.location.reload()" class="btn btn-secondary">Réessayer</button>
        </div>
    </div>
</div>

<style>
.error-page-wrapper {
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--espace-xl) 0;
}

.error-page-content-centered {
    max-width: 600px;
    margin: 0 auto;
    text-align: center;
}

.error-page-icon {
    width: clamp(64px, 10vw, 96px);
    height: clamp(64px, 10vw, 96px);
    margin: 0 auto var(--espace-md);
    opacity: 0.9;
}

.error-icon-error {
    color: var(--couleur-error);
}

.error-page-icon svg {
    width: 100%;
    height: 100%;
}

.error-page-code-watermark {
    font-size: clamp(3rem, 8vw, 5rem);
    font-weight: 800;
    color: var(--couleur-texte);
    opacity: 0.1;
    line-height: 1;
    margin-bottom: var(--espace-sm);
    letter-spacing: -0.02em;
    user-select: none;
}

.error-page-title {
    font-size: clamp(1.5rem, 3vw + 1rem, 2.25rem);
    font-weight: 700;
    color: var(--couleur-texte);
    margin: 0 0 var(--espace-md);
    line-height: 1.2;
}

.error-page-description {
    font-size: clamp(0.95rem, 0.5vw + 0.85rem, 1.125rem);
    color: var(--couleur-texte-secondaire);
    line-height: 1.6;
    margin: 0 0 var(--espace-xl);
}

.error-page-info-box {
    background: var(--couleur-surface);
    border: 1px solid var(--couleur-bordure);
    border-radius: var(--rayon);
    padding: var(--espace-lg);
    margin-bottom: var(--espace-xl);
    display: flex;
    gap: var(--espace-md);
    text-align: left;
}

.error-page-info-icon {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    color: var(--couleur-info);
}

.error-page-info-icon svg {
    width: 100%;
    height: 100%;
}

.error-page-info-text strong {
    display: block;
    font-weight: 600;
    color: var(--couleur-texte);
    margin-bottom: var(--espace-xs);
}

.error-page-info-text p {
    margin: 0;
    font-size: 0.9rem;
    color: var(--couleur-texte-secondaire);
    line-height: 1.5;
}

.error-page-actions {
    display: flex;
    gap: var(--espace-md);
    justify-content: center;
    flex-wrap: wrap;
}
</style>
{% endblock %}
