{% extends 'base.html.twig' %}

{% block title %}Service temporairement indisponible - TalChif{% endblock %}

{% block body %}
<div class="error-page-wrapper">
    <div class="error-page-content-centered">
        <div class="error-page-icon error-icon-warning">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                <line x1="12" y1="9" x2="12" y2="13"/>
                <line x1="12" y1="17" x2="12.01" y2="17"/>
            </svg>
        </div>
        
        <div class="error-page-code-watermark">503</div>
        <h1 class="error-page-title">Service temporairement indisponible</h1>
        <p class="error-page-description">Le service est actuellement en maintenance ou temporairement surchargé. Nous travaillons à rétablir l'accès dans les plus brefs délais.</p>
        
        <div class="error-page-info-box">
            <div class="error-page-info-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/>
                    <polyline points="12 6 12 12 16 14"/>
                </svg>
            </div>
            <div class="error-page-info-text">
                <strong>Maintenance en cours</strong>
                <p>Veuillez réessayer dans quelques minutes. Nous nous excusons pour la gêne occasionnée.</p>
            </div>
        </div>
        
        <div class="error-page-actions">
            <button onclick="window.location.reload()" class="btn btn-primary">Réessayer</button>
            <a href="{{ path('accueil') }}" class="btn btn-secondary">Retour à l'accueil</a>
        </div>
    </div>
</div>

<style>
.error-page-wrapper {
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--espace-xl) 0;
}

.error-page-content-centered {
    max-width: 600px;
    margin: 0 auto;
    text-align: center;
}

.error-page-icon {
    width: clamp(64px, 10vw, 96px);
    height: clamp(64px, 10vw, 96px);
    margin: 0 auto var(--espace-md);
    opacity: 0.9;
}

.error-icon-warning {
    color: var(--couleur-warning);
}

.error-page-icon svg {
    width: 100%;
    height: 100%;
}

.error-page-code-watermark {
    font-size: clamp(3rem, 8vw, 5rem);
    font-weight: 800;
    color: var(--couleur-texte);
    opacity: 0.1;
    line-height: 1;
    margin-bottom: var(--espace-sm);
    letter-spacing: -0.02em;
    user-select: none;
}

.error-page-title {
    font-size: clamp(1.5rem, 3vw + 1rem, 2.25rem);
    font-weight: 700;
    color: var(--couleur-texte);
    margin: 0 0 var(--espace-md);
    line-height: 1.2;
}

.error-page-description {
    font-size: clamp(0.95rem, 0.5vw + 0.85rem, 1.125rem);
    color: var(--couleur-texte-secondaire);
    line-height: 1.6;
    margin: 0 0 var(--espace-xl);
}

.error-page-info-box {
    background: var(--couleur-surface);
    border: 1px solid var(--couleur-bordure);
    border-radius: var(--rayon);
    padding: var(--espace-lg);
    margin-bottom: var(--espace-xl);
    display: flex;
    gap: var(--espace-md);
    text-align: left;
}

.error-page-info-icon {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    color: var(--couleur-warning);
}

.error-page-info-icon svg {
    width: 100%;
    height: 100%;
}

.error-page-info-text strong {
    display: block;
    font-weight: 600;
    color: var(--couleur-texte);
    margin-bottom: var(--espace-xs);
}

.error-page-info-text p {
    margin: 0;
    font-size: 0.9rem;
    color: var(--couleur-texte-secondaire);
    line-height: 1.5;
}

.error-page-actions {
    display: flex;
    gap: var(--espace-md);
    justify-content: center;
    flex-wrap: wrap;
}
</style>
{% endblock %}
