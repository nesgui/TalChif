{% extends 'base.html.twig' %}

{% block title %}Page non trouvée - TalChif{% endblock %}

{% block body %}
<div class="error-page-wrapper">
    <div class="error-page-content-centered">
        <div class="error-page-icon error-icon-warning">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                <line x1="12" y1="9" x2="12" y2="13"/>
                <line x1="12" y1="17" x2="12.01" y2="17"/>
            </svg>
        </div>
        
        <div class="error-page-code-watermark">404</div>
        <h1 class="error-page-title">Page non trouvée</h1>
        <p class="error-page-description">La page que vous recherchez n'existe pas ou a été déplacée. Vérifiez l'URL ou retournez à l'accueil.</p>
        
        <div class="error-page-suggestions-box">
            <h2 class="error-suggestions-title">Suggestions</h2>
            <ul class="error-suggestions-grid">
                <li>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 11.5L12 4l9 7.5"/>
                        <path d="M5 10.5V20h14v-9.5"/>
                    </svg>
                    <span>Retourner à la <a href="{{ path('accueil') }}">page d'accueil</a></span>
                </li>
                <li>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="7" width="18" height="14" rx="2"/>
                        <path d="M3 7h18"/>
                    </svg>
                    <span>Parcourir les <a href="{{ path('evenement.index') }}">événements</a></span>
                </li>
                <li>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="11" cy="11" r="8"/>
                        <path d="m21 21-4.35-4.35"/>
                    </svg>
                    <span>Utiliser la recherche depuis l'accueil</span>
                </li>
            </ul>
        </div>
        
        <div class="error-page-actions">
            <a href="{{ path('accueil') }}" class="btn btn-primary">Retour à l'accueil</a>
            <a href="{{ path('evenement.index') }}" class="btn btn-secondary">Voir les événements</a>
        </div>
    </div>
</div>

<style>
.error-page-wrapper {
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--espace-xl) 0;
}

.error-page-content-centered {
    max-width: 600px;
    margin: 0 auto;
    text-align: center;
}

.error-page-icon {
    width: clamp(64px, 10vw, 96px);
    height: clamp(64px, 10vw, 96px);
    margin: 0 auto var(--espace-md);
    opacity: 0.9;
}

.error-icon-warning {
    color: var(--couleur-warning);
}

.error-icon-error {
    color: var(--couleur-error);
}

.error-page-icon svg {
    width: 100%;
    height: 100%;
}

.error-page-code-watermark {
    font-size: clamp(3rem, 8vw, 5rem);
    font-weight: 800;
    color: var(--couleur-texte);
    opacity: 0.1;
    line-height: 1;
    margin-bottom: var(--espace-sm);
    letter-spacing: -0.02em;
    user-select: none;
}

.error-page-title {
    font-size: clamp(1.5rem, 3vw + 1rem, 2.25rem);
    font-weight: 700;
    color: var(--couleur-texte);
    margin: 0 0 var(--espace-md);
    line-height: 1.2;
}

.error-page-description {
    font-size: clamp(0.95rem, 0.5vw + 0.85rem, 1.125rem);
    color: var(--couleur-texte-secondaire);
    line-height: 1.6;
    margin: 0 0 var(--espace-xl);
}

.error-page-suggestions-box {
    background: var(--couleur-surface);
    border: 1px solid var(--couleur-bordure);
    border-radius: var(--rayon);
    padding: var(--espace-lg);
    margin-bottom: var(--espace-xl);
    text-align: left;
}

.error-suggestions-title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--couleur-texte);
    margin: 0 0 var(--espace-md);
}

.error-suggestions-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--espace-sm);
}

.error-suggestions-grid li {
    display: flex;
    align-items: center;
    gap: var(--espace-sm);
    color: var(--couleur-texte-secondaire);
    font-size: 0.95rem;
}

.error-suggestions-grid svg {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    color: var(--couleur-primaire);
}

.error-suggestions-grid a {
    color: var(--couleur-primaire);
    text-decoration: none;
    font-weight: 500;
}

.error-suggestions-grid a:hover {
    text-decoration: underline;
}

.error-page-actions {
    display: flex;
    gap: var(--espace-md);
    justify-content: center;
    flex-wrap: wrap;
}
</style>
{% endblock %}
