{% extends 'base.html.twig' %}

{% block title %}Erreur - TalChif{% endblock %}

{% block body %}
<div class="error-page-wrapper">
    <div class="error-page-content-centered">
        <div class="error-page-icon error-icon-error">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <line x1="12" y1="8" x2="12" y2="12"/>
                <line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
        </div>
        
        <h1 class="error-page-title">Une erreur est survenue</h1>
        <p class="error-page-description">Nous sommes désolés, une erreur inattendue s'est produite. Notre équipe a été notifiée et travaille à résoudre le problème.</p>
        
        <div class="error-page-actions">
            <a href="{{ path('accueil') }}" class="btn btn-primary">Retour à l'accueil</a>
            <a href="{{ path('evenement.index') }}" class="btn btn-secondary">Voir les événements</a>
        </div>
    </div>
</div>

<style>
.error-page-wrapper {
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--espace-xl) 0;
}

.error-page-content-centered {
    max-width: 600px;
    margin: 0 auto;
    text-align: center;
}

.error-page-icon {
    width: clamp(64px, 10vw, 96px);
    height: clamp(64px, 10vw, 96px);
    margin: 0 auto var(--espace-xl);
    opacity: 0.9;
}

.error-icon-error {
    color: var(--couleur-error);
}

.error-page-icon svg {
    width: 100%;
    height: 100%;
}

.error-page-title {
    font-size: clamp(1.5rem, 3vw + 1rem, 2.25rem);
    font-weight: 700;
    color: var(--couleur-texte);
    margin: 0 0 var(--espace-md);
    line-height: 1.2;
}

.error-page-description {
    font-size: clamp(0.95rem, 0.5vw + 0.85rem, 1.125rem);
    color: var(--couleur-texte-secondaire);
    line-height: 1.6;
    margin: 0 0 var(--espace-xl);
}

.error-page-actions {
    display: flex;
    gap: var(--espace-md);
    justify-content: center;
    flex-wrap: wrap;
}
</style>
{% endblock %}
