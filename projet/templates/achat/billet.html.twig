{% extends 'base.html.twig' %}

{% block title %}Billet - {{ billet.evenement.nom }}{% endblock %}

{% block body %}
<div class="ticket-container">
    <div class="ticket-main">
        <div class="ticket-header">
            <div class="ticket-event">
                <h1 class="ticket-title">{{ billet.evenement.nom }}</h1>
                <div class="ticket-meta">
                    <span class="pill pill-{{ billet.type|lower }}">{{ billet.type }}</span>
                    <span class="pill">{{ billet.prix|number_format(0, '.', ' ') }} XAF</span>
                </div>
            </div>
            <div class="ticket-status">
                {% if billet.isPaye() %}
                    <span class="status-badge status-success">✅ Payé</span>
                {% else %}
                    <span class="status-badge status-warning">⏳ En attente</span>
                {% endif %}
                {% if billet.isUtilise() %}
                    <span class="status-badge status-error">❌ Utilisé</span>
                {% endif %}
            </div>
        </div>

        <div class="ticket-info">
            <div class="info-row">
                <span class="info-icon">📅</span>
                <div class="info-content">
                    <strong>Date</strong><br>
                    {{ billet.evenement.dateEvenement|date('d/m/Y H:i') }}
                </div>
            </div>
            
            <div class="info-row">
                <span class="info-icon">📍</span>
                <div class="info-content">
                    <strong>Lieu</strong><br>
                    {{ billet.evenement.lieu }} - {{ billet.evenement.ville }}
                </div>
            </div>
            
            <div class="info-row">
                <span class="info-icon">👤</span>
                <div class="info-content">
                    <strong>Acheteur</strong><br>
                    {{ billet.client.fullName }}
                </div>
            </div>
            
            <div class="info-row">
                <span class="info-icon">🆔</span>
                <div class="info-content">
                    <strong>Transaction</strong><br>
                    {{ billet.transactionId }}
                </div>
            </div>
        </div>

        <div class="ticket-qr">
            <div class="qr-code">
                <div class="qr-placeholder">
                    🎫
                    <div style="font-size: 0.8rem; margin-top: 0.5rem;">QR Code</div>
                </div>
            </div>
            <div class="qr-text">
                <strong>Code QR</strong><br>
                <span style="font-family: monospace; font-size: 0.9rem;">{{ billet.qrCode }}</span>
            </div>
        </div>
    </div>

    <div class="ticket-footer">
        <div class="footer-info">
            <p><strong>Instructions importantes:</strong></p>
            <ul>
                <li>Présentez ce QR code à l'entrée de l'événement</li>
                <li>Ne partagez jamais ce code avec d'autres personnes</li>
                <li>Ce billet est non remboursable et non transférable</li>
                <li>En cas de problème, contactez le support: support@osea.td</li>
            </ul>
        </div>
        <div class="footer-actions">
            <button class="btn btn-primary" onclick="downloadTicket()">
                📥 Télécharger le billet
            </button>
            <button class="btn" onclick="shareTicket()">
                📤 Partager
            </button>
        </div>
    </div>
</div>

<style>
.ticket-container {
    max-width: 800px;
    margin: 0 auto;
    background: white;
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
    overflow: hidden;
}

.ticket-main {
    padding: 2rem;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    position: relative;
}

.ticket-main::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><defs><pattern id="grain" width="100" height="100" patternUnits="userSpaceOnUse"><circle cx="50" cy="50" r="1" fill="white" opacity="0.1"/></pattern></defs><rect width="100" height="100" fill="url(%23grain)"/></svg>');
    opacity: 0.3;
}

.ticket-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 2rem;
    position: relative;
    z-index: 1;
}

.ticket-title {
    font-size: 2rem;
    margin: 0 0 0.5rem 0;
    font-weight: 700;
}

.ticket-meta {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
}

.ticket-status {
    text-align: right;
}

.status-badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    font-size: 0.875rem;
    font-weight: 600;
    margin-bottom: 0.25rem;
}

.status-success {
    background: #10b981;
    color: white;
}

.status-warning {
    background: #f59e0b;
    color: white;
}

.status-error {
    background: #ef4444;
    color: white;
}

.ticket-info {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
    margin-bottom: 2rem;
    position: relative;
    z-index: 1;
}

.info-row {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
}

.info-icon {
    font-size: 1.25rem;
    flex-shrink: 0;
    margin-top: 0.25rem;
}

.info-content strong {
    display: block;
    margin-bottom: 0.25rem;
}

.ticket-qr {
    display: flex;
    align-items: center;
    gap: 2rem;
    padding: 1.5rem;
    background: rgba(255,255,255,0.1);
    border-radius: 12px;
    position: relative;
    z-index: 1;
}

.qr-code {
    width: 120px;
    height: 120px;
    background: white;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
}

.qr-placeholder {
    text-align: center;
    color: #666;
}

.qr-text {
    flex: 1;
    color: white;
}

.ticket-footer {
    padding: 2rem;
    background: #f8fafc;
    border-top: 1px solid #e2e8f0;
}

.footer-info {
    margin-bottom: 1.5rem;
}

.footer-info ul {
    margin: 0.5rem 0 0 0;
    padding-left: 1.5rem;
}

.footer-info li {
    margin-bottom: 0.25rem;
    color: #64748b;
}

.footer-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
}

.pill {
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    font-size: 0.875rem;
    font-weight: 600;
}

.pill-simple {
    background: rgba(59, 130, 246, 0.2);
    color: white;
}

.pill-vip {
    background: rgba(245, 158, 11, 0.2);
    color: white;
}

@media (max-width: 768px) {
    .ticket-container {
        margin: 1rem;
        border-radius: 8px;
    }
    
    .ticket-main {
        padding: 1.5rem;
    }
    
    .ticket-header {
        flex-direction: column;
        gap: 1rem;
        text-align: center;
    }
    
    .ticket-status {
        text-align: center;
    }
    
    .ticket-qr {
        flex-direction: column;
        text-align: center;
    }
    
    .footer-actions {
        flex-direction: column;
    }
}
</style>

<script>
function downloadTicket() {
    // En production, générer un vrai PDF du billet
    window.print();
}

function shareTicket() {
    if (navigator.share) {
        navigator.share({
            title: 'Billet - {{ billet.evenement.nom }}',
            text: 'Je viens d\'acheter un billet pour {{ billet.evenement.nom }} !',
            url: window.location.href
        });
    } else {
        // Fallback: copier le lien
        navigator.clipboard.writeText(window.location.href);
        alert('Lien copié dans le presse-papiers !');
    }
}

// Auto-refresh toutes les 30 secondes pour vérifier le statut
setInterval(() => {
    location.reload();
}, 30000);
</script>
{% endblock %}
