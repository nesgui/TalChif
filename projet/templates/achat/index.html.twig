{% extends 'base.html.twig' %}

{% block title %}Finaliser l'achat{% endblock %}

{% block body %}
<h1 class="page-title">Finaliser l'achat</h1>
<p class="page-subtitle">Vérifiez votre commande et procédez au paiement</p>

<div class="grid">
    <section class="card">
        <h2 class="card-title">Votre commande</h2>
        <p class="card-meta">Dernière vérification avant paiement</p>

        {% if lignes|length > 0 %}
            <div class="panier-lignes">
                {% for ligne in lignes %}
                    <article class="panier-ligne">
                        <img class="panier-img" src="{{ ligne.produit.image }}" alt="{{ ligne.produit.titre }}" />
                        <div class="panier-info">
                            <div class="panier-titre">{{ ligne.produit.titre }}</div>
                            <div class="panier-meta">
                                <span class="pill">Quantité: {{ ligne.quantite }}</span>
                                <span class="pill">Prix: {{ ligne.produit.prix_min|number_format(0, '.', ' ') }} XAF</span>
                                <span class="pill">Sous-total: {{ ligne.sous_total|number_format(0, '.', ' ') }} XAF</span>
                            </div>
                            <div class="panier-details">
                                <small>{{ ligne.produit.date|date('d/m/Y H:i') }} - {{ ligne.produit.ville }}</small>
                            </div>
                        </div>
                    </article>
                {% endfor %}
            </div>
        {% else %}
            <p class="card-meta">Votre panier est vide.</p>
            <div class="card-actions">
                <a class="btn btn-primary" href="{{ path('evenement.index') }}">Explorer les événements</a>
            </div>
        {% endif %}
    </section>

    <aside class="card">
        <h2 class="card-title">Paiement</h2>
        
        {% if app.user %}
            <form method="post" action="{{ path('achat.paiement') }}">
                <div class="form-group">
                    <label class="form-label">Méthode de paiement *</label>
                    <div class="payment-methods">
                        <label class="payment-method">
                            <input type="radio" name="methode_paiement" value="momo" checked required>
                            <span class="payment-icon">📱</span>
                            <span class="payment-name">MoMo</span>
                        </label>
                        <label class="payment-method">
                            <input type="radio" name="methode_paiement" value="airtel" required>
                            <span class="payment-icon">📱</span>
                            <span class="payment-name">Airtel Money</span>
                        </label>
                        <label class="payment-method">
                            <input type="radio" name="methode_paiement" value="orange" required>
                            <span class="payment-icon">📱</span>
                            <span class="payment-name">Orange Money</span>
                        </label>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label" for="telephone">Numéro de téléphone *</label>
                    <input type="tel" id="telephone" name="telephone" class="form-control" 
                           placeholder="235 00 00 00 00" pattern="[0-9\s]+" required>
                    <small class="form-help">Format : 235 XX XX XX XX</small>
                </div>

                <table class="table">
                    <tbody>
                        <tr>
                            <th>Total à payer</th>
                            <td><strong>{{ total|number_format(0, '.', ' ') }} XAF</strong></td>
                        </tr>
                    </tbody>
                </table>

                <div class="card-actions">
                    <button type="submit" class="btn btn-primary" onclick="return confirmPaiement()">
                        Confirmer le paiement
                    </button>
                    <a href="{{ path('panier.index') }}" class="btn">Retour au panier</a>
                </div>
            </form>
        {% else %}
            <div class="auth-required">
                <p class="card-meta">Vous devez être connecté pour effectuer un achat</p>
                <div class="card-actions">
                    <a class="btn btn-primary" href="{{ path('auth.login') }}">Se connecter</a>
                    <a class="btn" href="{{ path('auth.register') }}">Créer un compte</a>
                </div>
            </div>
        {% endif %}
    </aside>
</div>

<style>
.payment-methods {
    display: flex;
    gap: 12px;
    margin-top: 8px;
}

.payment-method {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 16px;
    border: 2px solid var(--couleur-bordure);
    border-radius: var(--rayon);
    cursor: pointer;
    transition: all 0.2s ease;
    flex: 1;
}

.payment-method:hover {
    border-color: var(--couleur-primaire);
    background: color-mix(in srgb, var(--couleur-surface) 95%, var(--couleur-primaire) 5%);
}

.payment-method input[type="radio"] {
    margin: 0;
}

.payment-method input[type="radio"]:checked + .payment-icon,
.payment-method input[type="radio"]:checked + .payment-icon + .payment-name {
    color: var(--couleur-primaire);
}

.payment-icon {
    font-size: 1.2em;
}

.payment-name {
    font-weight: 500;
}

.auth-required {
    text-align: center;
    padding: 20px;
}
</style>

<script>
function confirmPaiement() {
    const telephone = document.getElementById('telephone').value;
    const methode = document.querySelector('input[name="methode_paiement"]:checked').value;
    
    if (!telephone || !methode) {
        alert('Veuillez remplir tous les champs');
        return false;
    }
    
    // Validation simple du numéro de téléphone
    if (!/^235\s\d{2}\s\d{2}\s\d{2}\s\d{2}$/.test(telephone.replace(/\s/g, ''))) {
        alert('Format du numéro de téléphone invalide. Utilisez: 235 XX XX XX XX');
        return false;
    }
    
    return confirm(`Confirmer le paiement de {{ total|number_format(0, '.', ' ') }} XAF par ${methode.toUpperCase()} ?`);
}
</script>
{% endblock %}
