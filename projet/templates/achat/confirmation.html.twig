{% extends 'base.html.twig' %}

{% block title %}Confirmation d'achat{% endblock %}

{% block body %}
<div class="text-center">
    <div class="success-icon"></div>
    <h1 class="page-title">Paiement réussi !</h1>
    <p class="page-subtitle">Vos billets ont été générés avec succès</p>
</div>

<div class="card">
    <h2 class="card-title">Détails de la transaction</h2>
    <p class="card-meta">Transaction ID: {{ transactionId }}</p>
    
    <table class="table">
        <thead>
            <tr>
                <th>Événement</th>
                <th>Type</th>
                <th>Prix</th>
                <th>QR Code</th>
            </tr>
        </thead>
        <tbody>
            {% for billet in billets %}
                <tr>
                    <td>
                        <strong>{{ billet.evenement.nom }}</strong><br>
                        <small>{{ billet.evenement.dateEvenement|date('d/m/Y H:i') }} - {{ billet.evenement.ville }}</small>
                    </td>
                    <td><span class="pill pill-{{ billet.type|lower }}">{{ billet.type }}</span></td>
                    <td><strong>{{ billet.prix|number_format(0, '.', ' ') }} XAF</strong></td>
                    <td>
                        <button class="btn btn-sm" onclick="showQRCode('{{ billet.qrCode }}')">
                            Voir QR Code
                        </button>
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
    
    <div class="summary">
        <div class="summary-row">
            <span>Total payé:</span>
            <strong>{{ total|number_format(0, '.', ' ') }} XAF</strong>
        </div>
    </div>
</div>

<div class="card">
    <h2 class="card-title">Instructions importantes</h2>
    <div class="instructions">
        <div class="instruction-item">
            <span class="instruction-icon"></span>
            <div class="instruction-text">
                <strong>Conservez vos QR codes</strong><br>
                Présentez-les à l'entrée de l'événement
            </div>
        </div>
        <div class="instruction-item">
            <span class="instruction-icon"></span>
            <div class="instruction-text">
                <strong>Sécurité</strong><br>
                Ne partagez jamais vos QR codes avec d'autres personnes
            </div>
        </div>
        <div class="instruction-item">
            <span class="instruction-icon">📧</span>
            <div class="instruction-text">
                <strong>Email de confirmation</strong><br>
                Un email récapitulatif vous a été envoyé
            </div>
        </div>
    </div>
</div>

<div class="card-actions">
    <a href="{{ path('portefeuille.index') }}" class="btn btn-primary">Voir mes billets</a>
    <a href="{{ path('evenement.index') }}" class="btn">Explorer d'autres événements</a>
</div>

<!-- Modal QR Code -->
<div id="qrModal" class="modal" style="display: none;">
    <div class="modal-content">
        <div class="modal-header">
            <h3>QR Code du billet</h3>
            <button class="modal-close" onclick="closeQRModal()">&times;</button>
        </div>
        <div class="modal-body text-center">
        <div id="qrCodeDisplay"></div>
            <p class="qr-code-text"></p>
            <button class="btn btn-primary" onclick="downloadQR()">Télécharger</button>
        </div>
    </div>
</div>

<style>
.success-icon {
    font-size: 4rem;
    margin-bottom: 1rem;
}

.summary {
    margin-top: 1rem;
    padding: 1rem;
    background: var(--couleur-surface);
    border-radius: var(--rayon);
}

.summary-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 1.1rem;
}

.instructions {
    display: grid;
    gap: 1rem;
}

.instruction-item {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
}

.instruction-icon {
    font-size: 1.5rem;
    flex-shrink: 0;
}

.instruction-text strong {
    display: block;
    margin-bottom: 0.25rem;
}

.modal {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
}

.modal-content {
    background: var(--couleur-fond);
    border-radius: var(--rayon);
    max-width: 400px;
    width: 90%;
    max-height: 90vh;
    overflow-y: auto;
}

.modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem;
    border-bottom: 1px solid var(--couleur-bordure);
}

.modal-body {
    padding: 1rem;
}

.modal-close {
    background: none;
    border: none;
    font-size: 1.5rem;
    cursor: pointer;
    color: var(--couleur-texte);
}

#qrCodeDisplay {
    width: 200px;
    height: 200px;
    margin: 0 auto 1rem;
    border: 2px solid var(--couleur-bordure);
    border-radius: var(--rayon);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8rem;
    text-align: center;
    padding: 1rem;
    background: white;
}

.qr-code-text {
    font-family: monospace;
    font-size: 0.9rem;
    color: var(--couleur-texte-secondaire);
    word-break: break-all;
}

.pill-vip {
    background: var(--couleur-warning);
    color: white;
}

.pill-simple {
    background: var(--couleur-primaire);
    color: white;
}
</style>

<script>
let currentQRCode = '';

function showQRCode(qrCode) {
    currentQRCode = qrCode;
    const modal = document.getElementById('qrModal');
    const display = document.getElementById('qrCodeDisplay');
    const text = document.querySelector('.qr-code-text');
    
    // Aperçu du QR code
    display.innerHTML = `
        <div style="font-size: 0.8rem; margin-top: 0.5rem;">QR Code</div>
    `;
    text.textContent = qrCode;
    
    modal.style.display = 'flex';
}

function closeQRModal() {
    document.getElementById('qrModal').style.display = 'none';
}

function downloadQR() {
    // Téléchargement de l'aperçu
    const link = document.createElement('a');
    link.download = `billet-${currentQRCode}.png`;
    link.href = 'data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAADUlEQVR42mNkYPhfDwAChwGA60e6kgAAAABJRU5ErkJggg==';
    link.click();
}

// Fermer le modal en cliquant à l'extérieur
document.getElementById('qrModal').addEventListener('click', function(e) {
    if (e.target === this) {
        closeQRModal();
    }
});
</script>
{% endblock %}
