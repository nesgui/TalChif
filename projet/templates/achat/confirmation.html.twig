{% extends 'base.html.twig' %}

{% block title %}Confirmation d'achat{% endblock %}

{% block body %}
<section class="confirmation-wrap">
    <header class="confirmation-hero card">
        <p class="confirmation-kicker">Paiement confirme</p>
        <h1 class="page-title">Vos billets sont disponibles</h1>
        <p class="page-subtitle">Transaction <strong>{{ transactionId }}</strong></p>
        <div class="confirmation-metrics">
            <div class="metric">
                <span>Billets</span>
                <strong>{{ billets|length }}</strong>
            </div>
            <div class="metric">
                <span>Total paye</span>
                <strong>{{ total|number_format(0, '.', ' ') }} FCFA</strong>
            </div>
        </div>
    </header>

    <section class="card">
        <h2 class="card-title">Mes billets</h2>
        <div class="tickets-grid">
            {% for billet in billets %}
                <article class="ticket-card">
                    <div class="ticket-top">
                        <div>
                            <h3>{{ billet.evenement.nom }}</h3>
                            <p>{{ billet.evenement.dateEvenement|date('d/m/Y H:i') }} - {{ billet.evenement.ville }}</p>
                        </div>
                        <span class="pill pill-{{ billet.type|lower }}">{{ billet.type|upper }}</span>
                    </div>
                    <div class="ticket-bottom">
                        <strong>{{ billet.prix|number_format(0, '.', ' ') }} FCFA</strong>
                        <a href="{{ path('achat.billet', {id: billet.id}) }}" class="btn btn-sm btn-primary">Voir billet</a>
                    </div>
                </article>
            {% endfor %}
        </div>
    </section>

    <section class="card info-card">
        <h2 class="card-title">A retenir</h2>
        <p class="card-meta">Presentez votre billet a l'entree et ne partagez pas votre QR code.</p>
    </section>

    <div class="card-actions-confirm">
        <a href="{{ path('portefeuille.index') }}" class="btn btn-sm btn-primary">Espace client</a>
        <a href="{{ path('achat.commandes') }}" class="btn btn-sm btn-secondary">Mes commandes</a>
        <a href="{{ path('evenement.index') }}" class="btn btn-sm">Autres événements</a>
    </div>
</section>

<style>
.confirmation-wrap { max-width: 980px; margin: 0 auto; display: grid; gap: 1rem; }
.confirmation-hero { display: grid; gap: .55rem; }
.confirmation-kicker { margin: 0; text-transform: uppercase; font-size: .82rem; color: var(--couleur-texte-secondaire); letter-spacing: .08em; }
.confirmation-hero .page-title { margin: 0; }
.confirmation-hero .page-subtitle { margin: 0; color: var(--couleur-texte-secondaire); }
.confirmation-metrics { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: .7rem; margin-top: .4rem; }
.metric { border: 1px solid var(--couleur-bordure); border-radius: var(--rayon); padding: .75rem; background: color-mix(in srgb, var(--couleur-primaire) 8%, var(--couleur-surface)); display: grid; gap: .2rem; }
.metric span { font-size: .84rem; color: var(--couleur-texte-secondaire); }
.metric strong { font-size: 1.05rem; }
.tickets-grid { display: grid; gap: .75rem; }
.ticket-card { border: 1px solid var(--couleur-bordure); border-radius: var(--rayon); padding: .8rem; display: grid; gap: .6rem; }
.ticket-top { display: flex; justify-content: space-between; gap: .7rem; align-items: flex-start; }
.ticket-top h3 { margin: 0; font-size: 1rem; }
.ticket-top p { margin: .2rem 0 0; color: var(--couleur-texte-secondaire); font-size: .9rem; }
.ticket-bottom { display: flex; justify-content: space-between; align-items: center; gap: .7rem; }
.pill-vip { background: var(--couleur-warning); color: #fff; }
.pill-simple { background: var(--couleur-primaire); color: #fff; }
.info-card .card-meta { margin: 0; }
.card-actions-confirm {
    display: flex;
    flex-wrap: wrap;
    gap: .5rem;
    align-items: center;
}

.card-actions-confirm .btn {
    flex: 1 1 auto;
    min-width: 120px;
    text-align: center;
    justify-content: center;
}

@media (max-width: 700px) {
    .confirmation-wrap { gap: .75rem; }
    .confirmation-metrics { grid-template-columns: 1fr 1fr; }
    .ticket-top { flex-direction: row; flex-wrap: wrap; }
    .ticket-bottom { flex-direction: row; align-items: center; flex-wrap: wrap; }
}

@media (max-width: 480px) {
    .confirmation-metrics { grid-template-columns: 1fr 1fr; gap: .4rem; }
    .ticket-top { flex-direction: column; align-items: flex-start; }
    .ticket-bottom { flex-direction: column; align-items: flex-start; }
    .card-actions-confirm {
        flex-direction: column;
    }
    .card-actions-confirm .btn {
        width: 100%;
    }
}
</style>
{% endblock %}
