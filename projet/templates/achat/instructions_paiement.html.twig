{% extends 'base.html.twig' %}

{% block title %}Instructions de paiement - {{ commande.reference }}{% endblock %}

{% block body %}
<section class="instructions-shell">
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="flash flash-{{ label == 'error' ? 'error' : 'success' }}">{{ message }}</div>
        {% endfor %}
    {% endfor %}

    {% set referenceDejaEnvoyee = commande.referenceTransactionClient is not null and commande.referenceTransactionClient|trim != '' %}
    <div class="mm-card">
        {% if not referenceDejaEnvoyee %}
            <form method="post" action="{{ path('achat.notifier_paiement', {reference: commande.reference, token: token}) }}" class="mm-form" enctype="multipart/form-data">
                <input type="hidden" name="_token" value="{{ csrf_token('notifier_paiement_' ~ commande.reference) }}">

                <p class="mm-kicker">Paiement Mobile Money</p>

                <div class="mm-headline">
                    <div class="mm-hero">
                        <div class="mm-hero-lead">Il vous reste</div>
                        <div class="mm-hero-values">
                            <strong id="timeLeft" class="mm-countdown mm-hero-time">10:00</strong>
                            <span class="mm-hero-sep" aria-hidden="true">•</span>
                            <button type="button" class="mm-link mm-hero-number" onclick="copyMomo()">{{ depotNumero }}</button>
                        </div>
                        <div class="mm-hero-sub">pour faire le dépôt sur notre numéro</div>
                    </div>
                    <div class="mm-progress" aria-hidden="true">
                        <div class="mm-progress-bar" id="timeProgress"></div>
                    </div>
                </div>

                <p class="mm-help">Envoyez-nous la preuve de votre transaction pour que notre équipe puisse la vérifier.</p>

                <div class="mm-sep" aria-hidden="true"></div>

                <div class="mm-field">
                    <div class="mm-label">Capture d’écran de la transaction <span class="mm-required">*</span></div>

                    <input
                        type="file"
                        name="capture_transaction"
                        id="capture_transaction"
                        accept="image/jpeg,image/png,image/webp"
                        required
                        class="mm-file"
                    >

                    <div class="mm-dropzone" id="upload-zone" tabindex="0" role="button">
                        <div class="mm-dropzone-inner">
                            <div class="mm-upload-icon" aria-hidden="true">
                                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                                    <polyline points="17 8 12 3 7 8" />
                                    <line x1="12" y1="3" x2="12" y2="15" />
                                </svg>
                            </div>
                            <div id="upload-placeholder">
                                <div class="mm-dropzone-title">Glissez ou cliquez pour choisir un fichier</div>
                                <div class="mm-dropzone-sub">JPG, PNG, WEBP — max 5 Mo</div>
                            </div>
                            <img id="upload-preview" alt="Aperçu de la capture" class="mm-preview" style="display:none;" />
                        </div>
                    </div>
                </div>

                <div class="mm-callout mm-callout-info" id="statusPending">
                    <div class="mm-dot" aria-hidden="true"></div>
                    <div>
                        <div class="mm-callout-title">Paiement en cours de validation</div>
                        <div class="mm-callout-text">Délai estimé : 10 minutes. Vos billets seront disponibles après vérification par notre équipe.</div>
                    </div>
                </div>
                <div class="mm-callout mm-callout-info" id="statusProcessing" style="display:none;">
                    <div class="mm-dot" aria-hidden="true"></div>
                    <div>
                        <div class="mm-callout-title">Paiement en cours de validation</div>
                        <div class="mm-callout-text">Nous vérifions votre paiement. Merci de patienter.</div>
                    </div>
                </div>
                <div class="mm-callout mm-callout-success" id="statusPaid" style="display:none;">
                    <div class="mm-dot" aria-hidden="true"></div>
                    <div>
                        <div class="mm-callout-title">Paiement validé</div>
                        <div class="mm-callout-text">Vos billets ont été envoyés par email.</div>
                    </div>
                </div>
                <div class="mm-callout mm-callout-danger" id="statusExpired" style="display:none;">
                    <div class="mm-dot" aria-hidden="true"></div>
                    <div>
                        <div class="mm-callout-title">Commande expirée</div>
                        <div class="mm-callout-text">Le délai est dépassé. Recommencez un achat si besoin.</div>
                    </div>
                </div>

                <div class="mm-actions">
                    <button type="submit" class="mm-btn mm-btn-primary">Envoyer la capture</button>
                </div>
            </form>

            <form method="post"
                  action="{{ path('achat.annuler', {reference: commande.reference, token: token}) }}"
                  class="mm-actions"
                  onsubmit="return confirm('Êtes-vous sûr de vouloir annuler cette commande ?');">
                <input type="hidden" name="_token" value="{{ csrf_token('annuler_' ~ commande.reference) }}">
                <button type="submit" class="mm-btn mm-btn-ghost">Annuler cette commande</button>
            </form>
        {% else %}
            <div class="mm-form">
                <p class="mm-kicker">Paiement Mobile Money</p>
                <div class="mm-headline">
                    <div class="mm-line">
                        Votre preuve est déjà envoyée.
                    </div>
                    <div class="mm-help">Nous finalisons la vérification.</div>
                </div>

                <div class="mm-callout mm-callout-info" id="statusProcessing">
                    <div class="mm-dot" aria-hidden="true"></div>
                    <div>
                        <div class="mm-callout-title">Paiement en cours de validation</div>
                        <div class="mm-callout-text">Référence envoyée : <strong>{{ commande.referenceTransactionClient }}</strong></div>
                    </div>
                </div>

                <div class="mm-actions mm-actions-row">
                    <a href="{{ path('achat.commandes') }}" class="mm-btn mm-btn-secondary">Mes commandes</a>
                    <a href="https://wa.me/23563519678" class="mm-btn mm-btn-secondary" target="_blank" rel="noopener">Support WhatsApp</a>
                </div>
            </div>
        {% endif %}
    </div>
</section>
<script>
const ref = '{{ commande.reference }}';
const expiry = new Date('{{ commande.dateExpiration|date('c') }}');
const token = '{{ token }}';
const createdAt = new Date('{{ commande.createdAt|date('c') }}');

function updateCountdown() {
    const now = new Date();
    const timeEl = document.getElementById('timeLeft');
    const progressEl = document.getElementById('timeProgress');

    if (!timeEl || !progressEl) return;

    const total = Math.max(1, expiry - createdAt);
    const remaining = Math.max(0, expiry - now);

    if (remaining <= 0) {
        timeEl.textContent = '0:00';
        progressEl.style.width = '0%';
        const pending = document.getElementById('statusPending');
        const expired = document.getElementById('statusExpired');
        if (pending) pending.style.display = 'none';
        if (expired) expired.style.display = 'grid';
        return;
    }
    const d = expiry - now;
    const m = Math.floor(d / 60000);
    const s = Math.floor((d % 60000) / 1000);
    timeEl.textContent = m + ':' + s.toString().padStart(2, '0');

    const ratio = Math.max(0, Math.min(1, remaining / total));
    progressEl.style.width = (ratio * 100).toFixed(2) + '%';
}

function checkStatus() {
    fetch('/api/commande/statut/' + ref + '?token=' + encodeURIComponent(token))
        .then(r => r.json())
        .then(data => {
            if (data.statut === 'Paid') {
                const pending = document.getElementById('statusPending');
                const processing = document.getElementById('statusProcessing');
                const expired = document.getElementById('statusExpired');
                const paid = document.getElementById('statusPaid');
                if (pending) pending.style.display = 'none';
                if (processing) processing.style.display = 'none';
                if (expired) expired.style.display = 'none';
                if (paid) paid.style.display = 'grid';
            } else if (data.statut === 'Processing') {
                const pending = document.getElementById('statusPending');
                const processing = document.getElementById('statusProcessing');
                const expired = document.getElementById('statusExpired');
                const paid = document.getElementById('statusPaid');
                if (pending) pending.style.display = 'none';
                if (processing) processing.style.display = 'grid';
                if (expired) expired.style.display = 'none';
                if (paid) paid.style.display = 'none';
            } else if (data.statut === 'Expired') {
                const pending = document.getElementById('statusPending');
                const processing = document.getElementById('statusProcessing');
                const expired = document.getElementById('statusExpired');
                const paid = document.getElementById('statusPaid');
                if (pending) pending.style.display = 'none';
                if (processing) processing.style.display = 'none';
                if (paid) paid.style.display = 'none';
                if (expired) expired.style.display = 'grid';
            }
        })
        .catch(() => {});
}

function copyRef() {
    navigator.clipboard.writeText(ref);
    alert('Reference copiee !');
}

function copyMomo() {
    navigator.clipboard.writeText('{{ depotNumero }}');
    alert('Numero copie !');
}

// Afficher le bon statut au chargement
function showInitialStatus() {
    const currentStatus = '{{ commande.statut }}';
    if (currentStatus === 'Processing') {
        const pending = document.getElementById('statusPending');
        const processing = document.getElementById('statusProcessing');
        const expired = document.getElementById('statusExpired');
        const paid = document.getElementById('statusPaid');
        if (pending) pending.style.display = 'none';
        if (processing) processing.style.display = 'grid';
        if (expired) expired.style.display = 'none';
        if (paid) paid.style.display = 'none';
    } else if (currentStatus === 'Paid') {
        const pending = document.getElementById('statusPending');
        const processing = document.getElementById('statusProcessing');
        const expired = document.getElementById('statusExpired');
        const paid = document.getElementById('statusPaid');
        if (pending) pending.style.display = 'none';
        if (processing) processing.style.display = 'none';
        if (expired) expired.style.display = 'none';
        if (paid) paid.style.display = 'grid';
    } else if (currentStatus === 'Expired') {
        const pending = document.getElementById('statusPending');
        const processing = document.getElementById('statusProcessing');
        const expired = document.getElementById('statusExpired');
        const paid = document.getElementById('statusPaid');
        if (pending) pending.style.display = 'none';
        if (processing) processing.style.display = 'none';
        if (paid) paid.style.display = 'none';
        if (expired) expired.style.display = 'grid';
    }
}

updateCountdown();
setInterval(updateCountdown, 1000);
showInitialStatus();
checkStatus();
setInterval(checkStatus, 15000);

// JavaScript pour l'upload de capture
(function() {
    const input = document.getElementById('capture_transaction');
    const preview = document.getElementById('upload-preview');
    const placeholder = document.getElementById('upload-placeholder');
    const zone = document.getElementById('upload-zone');

    if (!input) return;

    if (zone) {
        zone.addEventListener('click', () => input.click());
        zone.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' || e.key === ' ') {
                e.preventDefault();
                input.click();
            }
        });
    }

    input.addEventListener('change', function() {
        const file = this.files[0];
        if (!file) return;

        // Vérification taille
        if (file.size > 5 * 1024 * 1024) {
            alert('Le fichier est trop lourd. Maximum 5 Mo.');
            this.value = '';
            return;
        }

        const reader = new FileReader();
        reader.onload = function(e) {
            if (preview) {
                preview.src = e.target.result;
                preview.style.display = 'block';
            }
            if (placeholder) placeholder.style.display = 'none';
            if (zone) zone.style.borderColor = 'rgba(167, 232, 193, .9)';
        };
        reader.readAsDataURL(file);
    });

    // Drag and drop
    if (!zone) return;

    zone.addEventListener('dragover', e => { e.preventDefault(); zone.style.borderColor = 'rgba(87,166,255,.9)'; });
    zone.addEventListener('dragleave', () => { zone.style.borderColor = 'rgba(255,255,255,.22)'; });
    zone.addEventListener('drop', e => {
        e.preventDefault();
        if (e.dataTransfer.files.length > 0) {
            input.files = e.dataTransfer.files;
            input.dispatchEvent(new Event('change'));
        }
    });
})();
</script>
{% endblock %}
