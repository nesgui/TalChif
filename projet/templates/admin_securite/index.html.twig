{% extends 'layout/dashboard.html.twig' %}

{% set section = 'admin' %}

{% block title %}Admin - Sécurité{% endblock %}

{% block dashboard_title %}Sécurité & anti-fraude{% endblock %}

{% block dashboard_content %}
<p class="page-subtitle">Contrôles, alertes et journalisation.</p>

<div class="grid">
    <section class="card">
        <h2 class="card-title">Accès Rapide</h2>
        <div class="quick-actions-grid">
            <a href="{{ path('validation.index') }}" class="quick-action-card">
                <div class="quick-action-content">
                    <h4>Validation des Billets</h4>
                    <p>Scanner et valider les QR Codes</p>
                </div>
            </a>
            <a href="{{ path('validation.historique') }}" class="quick-action-card">
                <div class="quick-action-content">
                    <h4>Historique</h4>
                    <p>Voir les validations récentes</p>
                </div>
            </a>
        </div>
    </section>

    <section class="card">
        <h2 class="card-title">Contrôles (UI)</h2>
        <div class="table-responsive admin-security-controls-wrap">
        <table class="table admin-security-controls-table" id="admin-securite-controles-table">
            <thead>
                <tr>
                    <th class="col-control">Contrôle</th>
                    <th class="col-status">Statut</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <th class="cell-control">Détection doublons billets</th>
                    <td class="cell-status"><span class="pill admin-security-pill">Actif</span></td>
                </tr>
                <tr>
                    <th class="cell-control">Anomalies (sur-génération)</th>
                    <td class="cell-status"><span class="pill admin-security-pill">Actif</span></td>
                </tr>
                <tr>
                    <th class="cell-control">Mode hors ligne</th>
                    <td class="cell-status"><span class="pill admin-security-pill">À cadrer</span></td>
                </tr>
            </tbody>
        </table>
        </div>
    </section>

    <section class="card">
        <h2 class="card-title">Logs (extraits)</h2>
        <div class="table-responsive admin-security-logs-wrap">
        <table class="table admin-security-logs-table" id="admin-securite-logs-table">
            <thead>
                <tr>
                    <th class="col-date">Date</th>
                    <th class="col-action">Action</th>
                    <th class="col-status">Statut</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td class="cell-date">2026-02-07 00:22</td>
                    <td class="cell-action">Scan billet QR-XXXXX</td>
                    <td class="cell-status"><span class="pill admin-security-pill">OK</span></td>
                </tr>
                <tr>
                    <td class="cell-date">2026-02-07 00:25</td>
                    <td class="cell-action">Scan billet QR-XXXXX (doublon)</td>
                    <td class="cell-status"><span class="pill admin-security-pill">ALERTE</span></td>
                </tr>
            </tbody>
        </table>
        </div>
    </section>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    if (typeof DataTableOS === 'undefined') {
        return;
    }

    if (document.querySelector('#admin-securite-controles-table')) {
        DataTableOS.init('#admin-securite-controles-table', {
            paging: false,
            searching: false,
            info: false,
            order: [],
        });
    }

    if (document.querySelector('#admin-securite-logs-table')) {
        DataTableOS.init('#admin-securite-logs-table', {
            paging: false,
            order: [[0, 'desc']],
        });
    }
});
</script>

<style>
.table-responsive {
    overflow-x: auto;
}

.quick-actions-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1rem;
    margin-bottom: 2rem;
}

.quick-action-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.5rem;
    background: var(--couleur-fond);
    border: 1px solid var(--couleur-bordure);
    border-radius: var(--rayon);
    text-decoration: none;
    color: var(--couleur-texte);
    transition: all var(--transition-rapide);
}

.quick-action-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--ombre-md);
    border-color: var(--couleur-primaire);
}

.quick-action-icon {
    font-size: 2rem;
    flex-shrink: 0;
}

.quick-action-content h4 {
    font-size: 1rem;
    font-weight: 600;
    margin: 0 0 0.25rem 0;
    color: var(--couleur-texte);
}

.quick-action-content p {
    font-size: 0.875rem;
    color: var(--couleur-texte-secondaire);
    margin: 0;
}

.admin-security-controls-table,
.admin-security-logs-table {
    width: 100%;
    table-layout: fixed;
}

.admin-security-controls-table .col-status,
.admin-security-controls-table .cell-status,
.admin-security-logs-table .col-status,
.admin-security-logs-table .cell-status {
    width: 110px;
    text-align: center;
}

.admin-security-logs-table .col-date,
.admin-security-logs-table .cell-date {
    width: 150px;
    white-space: nowrap;
}

.admin-security-controls-table .cell-control,
.admin-security-logs-table .cell-action {
    word-break: break-word;
}

.admin-security-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 84px;
    white-space: nowrap;
}

@media (max-width: 768px) {
    .admin-security-controls-table {
        min-width: 460px;
    }

    .admin-security-logs-table {
        min-width: 620px;
    }
}
</style>
{% endblock %}
