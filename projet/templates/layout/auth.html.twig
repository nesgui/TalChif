<!DOCTYPE html>
<html data-theme="light">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}TalChif{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        {% block stylesheets %}
            <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
            <!-- Load services via importmap to prevent module errors -->
            <script type="module" src="{{ asset('services/notification_service.js') }}"></script>
            <script type="module" src="{{ asset('services/theme_service.js') }}"></script>
            <!-- Load Stimulus controllers -->
            <script type="module" src="{{ asset('controllers/theme_controller.js') }}"></script>
        {% endblock %}
    </head>
    <body>
        {% block body %}
        <div class="auth-container">
            <div class="auth-background"></div>
            
            <!-- Auth Header -->
            <div class="auth-top-header">
                <div class="auth-header-content">
                    <div class="auth-brand">
                        <h1 class="auth-app-name">TalChif</h1>
                    </div>
                    <div class="auth-header-actions">
                        <a href="{{ path('accueil') }}" class="auth-back-home" title="Retour à l'accueil">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                                <polyline points="9,22 9,12 15,12 15,22"/>
                            </svg>
                            <span>Accueil</span>
                        </a>
                        <button class="auth-theme-toggle" id="theme-toggle" 
                        data-controller="theme" 
                        data-action="click->theme#toggle" 
                        title="Basculer le thème">
                            <svg class="theme-icon-light" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <circle cx="12" cy="12" r="5"/>
                                <line x1="12" y1="1" x2="12" y2="3"/>
                                <line x1="12" y1="21" x2="12" y2="23"/>
                                <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
                                <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
                                <line x1="1" y1="12" x2="3" y2="12"/>
                                <line x1="21" y1="12" x2="23" y2="12"/>
                                <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
                                <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
                            </svg>
                            <svg class="theme-icon-dark" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display: none;">
                                <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
                            </svg>
                        </button>
                    </div>
                </div>
            </div>
            
            <div class="auth-card">
                {% block auth_content %}
                <!-- Authentication content will be inserted here -->
                {% endblock %}
            </div>
            
            <!-- Auth Footer -->
            <div class="auth-bottom-footer">
                <div class="auth-footer-links">
                    <a href="#" class="auth-footer-link">Aide et commentaires</a>
                    <span class="auth-footer-separator">•</span>
                    <a href="#" class="auth-footer-link">Conditions d'utilisation</a>
                    <span class="auth-footer-separator">•</span>
                    <a href="#" class="auth-footer-link">Confidentialité et cookies</a>
                </div>
                <div class="auth-footer-privacy">
                    Utilisez la navigation privée si cet appareil n'est pas le vôtre. <a href="#" class="auth-footer-link">En savoir plus</a>
                </div>
            </div>
        </div>
        {% endblock %}
    </body>
</html>
