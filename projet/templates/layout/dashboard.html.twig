{% extends 'base.html.twig' %}

{% block site_header %}{% endblock %}

{% block site_main %}
    <input class="dashboard-toggle" type="checkbox" id="dashboard-menu" />

    <div class="dashboard">
        <aside class="dashboard-sidebar" aria-label="Menu latéral">
            <div class="dashboard-sidebar-top">
                <a class="dashboard-brand" href="{{ path('accueil') }}">TalChif</a>
                <label class="dashboard-close" for="dashboard-menu">Fermer</label>
            </div>

            {% if section is not defined %}
                {% set section = 'client' %}
            {% endif %}

            <nav class="dashboard-nav">
                {% if section == 'organisateur' %}
                    <div class="dashboard-nav-title">Organisateur</div>

                    <a class="dashboard-link" href="{{ path('organisateur.dashboard') }}">Tableau de bord</a>

                    <details class="dashboard-group" open>
                        <summary>Gestion des événements</summary>
                        <div class="dashboard-sub">
                            <a class="dashboard-sublink" href="{{ path('organisateur.evenement.index') }}">Liste des événements</a>
                            <a class="dashboard-sublink" href="{{ path('organisateur.evenement.create') }}">Ajouter un événement</a>
                            <a class="dashboard-sublink" href="{{ path('organisateur.dashboard') }}">Vue globale ventes</a>
                        </div>
                    </details>

                    <div class="dashboard-nav-title">Général</div>
                    <a class="dashboard-link" href="{{ path('evenement.index') }}">Vitrine événements</a>
                    <a class="dashboard-link" href="{{ path('accueil') }}">Retour site</a>
                {% elseif section == 'admin' %}
                    <div class="dashboard-nav-title">Administration</div>

                    <a class="dashboard-link" href="{{ path('admin.dashboard') }}">Tableau de bord</a>

                    <details class="dashboard-group" open>
                        <summary>Gestion</summary>
                        <div class="dashboard-sub">
                            <a class="dashboard-sublink" href="{{ path('admin.user.index') }}">Utilisateurs</a>
                            {# Événements, Organisateurs, Finance, Sécurité : masqués (voir etat_des_lieux_fonctionnalites.md) #}
                        </div>
                    </details>

                    <div class="dashboard-nav-title">Général</div>
                    <a class="dashboard-link" href="{{ path('accueil') }}">Retour site</a>
                {% endif %}
            </nav>
        </aside>

        <div class="dashboard-main">
            {% include 'partials/flashes.html.twig' %}
            <header class="dashboard-topbar">
                <label class="dashboard-burger" for="dashboard-menu" aria-label="Ouvrir le menu de navigation">
                    <span class="dashboard-burger-icon" aria-hidden="true">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="6" x2="20" y2="6"/><line x1="4" y1="18" x2="20" y2="18"/></svg>
                    </span>
                    <span class="dashboard-burger-text">Menu</span>
                </label>
                <div class="dashboard-topbar-title">
                    {% block dashboard_title %}{% endblock %}
                </div>
                <div class="dashboard-topbar-actions">
                    {% block dashboard_actions %}{% endblock %}
                </div>
            </header>

            <section class="dashboard-content">
                {% block dashboard_content %}{% endblock %}
            </section>
        </div>
    </div>
{% endblock %}
