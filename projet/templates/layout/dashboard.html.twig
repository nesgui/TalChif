{% extends 'base.html.twig' %}

{% block site_header %}{% endblock %}

{% block site_main %}
    {% if section is not defined %}
        {% set section = 'client' %}
    {% endif %}

    {% set current_route = app.request.attributes.get('_route') %}

    {% set dashboard_sidebar_content %}
        <div class="dashboard-sidebar-top">
            <a class="dashboard-brand" href="{{ path('accueil') }}" data-turbo-frame="_top">TalChif</a>
            <button type="button" class="dashboard-close" data-dashboard-close aria-label="Fermer le menu">Fermer</button>
        </div>

        <nav class="dashboard-nav">
            {% if section == 'organisateur' %}
                <div class="dashboard-nav-title">Organisateur</div>

                <a class="dashboard-link{{ current_route == 'organisateur.dashboard' ? ' active' : '' }}" href="{{ path('organisateur.dashboard') }}" data-turbo-frame="dashboard-main-frame">Tableau de bord</a>

                {% set organisateur_gestion_open = current_route starts with 'organisateur.evenement.' or current_route == 'organisateur.commande.references' %}
                <details class="dashboard-group" {% if organisateur_gestion_open %}open{% endif %}>
                    <summary>Gestion des événements</summary>
                    <div class="dashboard-sub">
                        <a class="dashboard-sublink{{ current_route == 'organisateur.evenement.index' ? ' active' : '' }}" href="{{ path('organisateur.evenement.index') }}" data-turbo-frame="dashboard-main-frame">Liste des événements</a>
                        <a class="dashboard-sublink{{ current_route == 'organisateur.evenement.create' ? ' active' : '' }}" href="{{ path('organisateur.evenement.create') }}" data-turbo-frame="dashboard-main-frame">Ajouter un événement</a>
                        <a class="dashboard-sublink{{ current_route == 'organisateur.ventes' ? ' active' : '' }}" href="{{ path('organisateur.ventes') }}" data-turbo-frame="dashboard-main-frame">Rapports ventes</a>
                        <a class="dashboard-sublink{{ current_route == 'organisateur.commande.references' ? ' active' : '' }}" href="{{ path('organisateur.commande.references') }}" data-turbo-frame="dashboard-main-frame">Références à vérifier</a>
                    </div>
                </details>

                <div class="dashboard-nav-title">Général</div>
                <a class="dashboard-link{{ current_route == 'profile.index' ? ' active' : '' }}" href="{{ path('profile.index') }}" data-turbo-frame="_top">Mon profil</a>
                <a class="dashboard-link{{ current_route == 'accueil' ? ' active' : '' }}" href="{{ path('accueil') }}" data-turbo-frame="_top">Retour site</a>
            {% elseif section == 'admin' %}
                <div class="dashboard-nav-title">Administration</div>

                <a class="dashboard-link{{ current_route == 'admin.dashboard' ? ' active' : '' }}" href="{{ path('admin.dashboard') }}" data-turbo-frame="dashboard-main-frame">Tableau de bord</a>

                {% set admin_gestion_open = current_route starts with 'admin.user.' or current_route starts with 'admin.organisateur.' or current_route starts with 'admin.commande.' %}
                <details class="dashboard-group" {% if admin_gestion_open %}open{% endif %}>
                    <summary>Gestion</summary>
                    <div class="dashboard-sub">
                        <a class="dashboard-sublink{{ current_route == 'admin.user.index' ? ' active' : '' }}" href="{{ path('admin.user.index') }}" data-turbo-frame="dashboard-main-frame">
                            Utilisateurs
                        </a>
                        <a class="dashboard-sublink{{ current_route == 'admin.organisateur.index' ? ' active' : '' }}" href="{{ path('admin.organisateur.index') }}" data-turbo-frame="dashboard-main-frame">
                            Organisateurs
                        </a>
                        <a class="dashboard-sublink{{ current_route == 'admin.commande.index' ? ' active' : '' }}" href="{{ path('admin.commande.index') }}" data-turbo-frame="dashboard-main-frame">
                            Commandes & validation
                        </a>
                        <a class="dashboard-sublink{{ current_route == 'admin.commande.references' ? ' active' : '' }}" href="{{ path('admin.commande.references') }}" data-turbo-frame="dashboard-main-frame">
                            Références à vérifier
                        </a>
                    </div>
                </details>

                {% set admin_finance_open = current_route starts with 'admin.finance.' or current_route starts with 'admin.evenement.' %}
                <details class="dashboard-group" {% if admin_finance_open %}open{% endif %}>
                    <summary>Finance & stats</summary>
                    <div class="dashboard-sub">
                        <a class="dashboard-sublink{{ current_route == 'admin.finance.index' ? ' active' : '' }}" href="{{ path('admin.finance.index') }}" data-turbo-frame="dashboard-main-frame">
                            Tableau financier
                        </a>
                        <a class="dashboard-sublink{{ current_route == 'admin.evenement.index' ? ' active' : '' }}" href="{{ path('admin.evenement.index') }}" data-turbo-frame="dashboard-main-frame">
                            Événements
                        </a>
                    </div>
                </details>

                {% set admin_securite_open = current_route starts with 'admin.securite.' %}
                <details class="dashboard-group" {% if admin_securite_open %}open{% endif %}>
                    <summary>Sécurité</summary>
                    <div class="dashboard-sub">
                        <a class="dashboard-sublink{{ current_route == 'admin.securite.index' ? ' active' : '' }}" href="{{ path('admin.securite.index') }}" data-turbo-frame="dashboard-main-frame">
                            Logs de sécurité
                        </a>
                    </div>
                </details>

                <div class="dashboard-nav-title">Général</div>
                <a class="dashboard-link{{ current_route == 'accueil' ? ' active' : '' }}" href="{{ path('accueil') }}" data-turbo-frame="_top">Retour au site</a>
            {% endif %}
        </nav>
    {% endset %}

    <div class="dashboard">
        <aside class="dashboard-sidebar" aria-label="Menu latéral">
            {{ dashboard_sidebar_content }}
        </aside>

        <dialog class="dashboard-sidebar-dialog" id="dashboard-sidebar-dialog" aria-label="Menu latéral mobile">
            <div class="dashboard-sidebar-dialog-panel">
                {{ dashboard_sidebar_content }}
            </div>
        </dialog>

        <turbo-frame id="dashboard-main-frame" data-turbo-action="advance" class="dashboard-main">
            {% include 'partials/flashes.html.twig' %}
            <header class="dashboard-topbar">
                <button type="button" class="dashboard-burger" aria-label="Ouvrir le menu de navigation" aria-haspopup="dialog" aria-controls="dashboard-sidebar-dialog" aria-expanded="false" data-dashboard-open>
                    <span class="dashboard-burger-icon" aria-hidden="true">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="6" x2="20" y2="6"/><line x1="4" y1="18" x2="20" y2="18"/></svg>
                    </span>
                    <span class="dashboard-burger-text">Menu</span>
                </button>
                <div class="dashboard-topbar-title">
                    {% block dashboard_title %}{% endblock %}
                </div>
                <div class="dashboard-topbar-actions">
                    {% block dashboard_actions %}{% endblock %}
                </div>
            </header>

            <section class="dashboard-content">
                {% block dashboard_content %}{% endblock %}
            </section>
        </turbo-frame>
    </div>
    
    {% block stylesheets %}
        {{ parent() }}
        <link rel="stylesheet" href="{{ asset('css/error-handling.css') }}">
    {% endblock %}
    
    {% block javascripts %}
        {{ parent() }}
        <script src="{{ asset('js/menu-error-handler.js') }}" defer></script>
        <script src="{{ asset('js/form-validator.js') }}" defer></script>
    {% endblock %}
{% endblock %}
