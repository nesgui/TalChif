<!DOCTYPE html>
<html data-theme="light">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}TalChif{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        {% block stylesheets %}
            <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
            <script src="{{ asset('services/auth_service.js') }}" defer></script>
            <!-- Load services via importmap to prevent module errors -->
            <script type="module" src="{{ asset('services/notification_service.js') }}"></script>
            <!-- Load Stimulus controllers -->
            <script type="module" src="{{ asset('controllers/theme_controller.js') }}"></script>
        {% endblock %}
    </head>
    <body>
        {% block body %}
        <div class="auth-container">
            <div class="auth-background"></div>
            <div class="auth-card">
                <!-- Auth Header with App Name and Theme Toggle -->
                <div class="auth-header-main">
                    <div class="auth-header-left">
                        <h1 class="auth-title">{% block auth_title %}Authentification{% endblock %}</h1>
                        <p class="auth-subtitle">{% block auth_subtitle %}{% endblock %}</p>
                    </div>
                    <div class="auth-header-right">
                        <div class="auth-nav">
                            <a href="{{ path('accueil') }}" class="auth-nav-link" aria-label="Retour à l'accueil">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M3 9l9 18-6 6-6 6 11l3 9"/>
                                    <path d="M9 21l12 15-12 15 6-6 6-3"/>
                                </svg>
                                <span>Retour</span>
                            </a>
                        </div>
                        <button class="auth-theme-toggle" id="theme-toggle" 
                        data-controller="theme" 
                        data-action="click->theme#toggle" 
                        aria-label="Basculer le thème">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M21 12.79A9 9 0 0 0-9 9H21"/>
                                <path d="M12 6v6a4 4 0 0-4-4h4a7 7 0 0 0 7 7h4"/>
                            </svg>
                        </button>
                    </div>
                </div>
                
                {% block auth_content %}
                    <!-- Authentication content will be inserted here -->
                {% endblock %}
            </div>
            
            <!-- Auth Footer -->
            <div class="auth-footer-main">
                <div class="auth-footer-links">
                    <a href="#" class="auth-footer-link">Aide et commentaires</a>
                    <span class="auth-footer-separator">•</span>
                    <a href="#" class="auth-footer-link">Conditions d&#39;utilisation</a>
                    <span class="auth-footer-separator">•</span>
                    <a href="#" class="auth-footer-link">Confidentialité et cookies</a>
                </div>
                <div class="auth-footer-text">
                    <small>© 2026 TalChif. Tous droits réservés.</small>
                    <p class="auth-footer-privacy">
                        <a href="#" class="auth-footer-link">Utilisez la navigation privée si cet appareil n&#39;est pas le vôtre.</a> En savoir plus
                    </p>
                </div>
            </div>
        </div>
        {% endblock %}
    </body>
</html>
